{% comment %}
  Standard Astro Premium Layout Snippet
  Usage: {% render 'main-product-layout', category: 'rudraksha' %}
{% endcomment %}

{{ 'component-price.css' | asset_url | stylesheet_tag }}

{%- style -%}
  @import url('https://fonts.googleapis.com/css2?family=Cinzel:wght@500;700&family=Inter:wght@400;600;800&display=swap');

  /* Category Specific Styles */
  {% if category == 'rudraksha' %}
    .f-premium { font-family: 'Cinzel', serif !important; color: #8b4513; }
    .bg-accent { background: #8b4513 !important; color: #fff; }
  {% elsif category == 'bracelet' %}
    .f-premium { font-family: 'Inter', sans-serif !important; font-weight: 800; color: #333; }
    .bg-accent { background: #000 !important; color: #fff; }
  {% else %}
    .f-premium { font-family: 'Cinzel', serif !important; }
    .bg-accent { background: #f3e05c !important; }
  {% endif %}

  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    font-family: 'Inter', sans-serif;
    background: #fff;
  }

  .ai-product-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; align-items: start; }
  .ai-gallery-col { position: sticky; top: 90px; align-self: start; }
  .ai-info-col { min-width: 0; }

  @media (max-width: 749px) {
    .ai-product-layout { grid-template-columns: 1fr; gap: 20px; }
    .ai-gallery-col { position: static; }
  }

  .ai-main-image-wrap {
    width: 100%; position: relative; border-radius: 10px; overflow: hidden;
    background: #fff; aspect-ratio: 1 / 1; border: 1px solid #f0f0f0; margin-bottom: 12px;
  }
  .ai-main-image-wrap img { width: 100%; height: 100%; object-fit: contain; }
  .ai-thumb-row { display: flex; gap: 8px; overflow-x: auto; padding: 2px; scrollbar-width: none; }
  .ai-thumb-item { flex: 0 0 65px; width: 65px; height: 65px; border-radius: 6px; border: 1px solid #ddd; cursor: pointer; opacity: 0.6; transition: 0.2s; }
  .ai-thumb-item.active { border-color: #000; opacity: 1; }
  .ai-thumb-item img { width: 100%; height: 100%; object-fit: cover; }

  .ai-price-row { display: flex; align-items: baseline; gap: 12px; margin-top: 20px; }
  .ai-current-price { font-size: 34px; font-weight: 900; color: #000; }
  .ai-old-price { font-size: 20px; color: #999; text-decoration: line-through; }
  .ai-discount-text { font-size: 16px; color: #34A853; font-weight: 800; }
{%- endstyle -%}

<section class="section-{{ section.id }}-padding page-width">
  <!-- CATEGORY BADGE -->
  <div style="margin-bottom: 20px; text-transform: uppercase; font-size: 12px; font-weight: 800; color: #888;">
    Home / {{ category | default: 'Collection' }} / {{ product.title }}
  </div>

  <div class="ai-product-layout">
    <div class="ai-gallery-col">
      <div class="ai-main-image-wrap">
        <img id="FeaturedImage-{{ section.id }}" src="{{ product.featured_image | image_url: width: 800 }}" alt="{{ product.title }}">
      </div>
      <div class="ai-thumb-row">
        {% for media in product.media %}
          <div class="ai-thumb-item {% if forloop.first %}active{% endif %}" onclick="document.getElementById('FeaturedImage-{{ section.id }}').src='{{ media | image_url: width: 800 }}'">
            <img src="{{ media | image_url: width: 150 }}" alt="thumb">
          </div>
        {% endfor %}
      </div>
    </div>

    <div class="ai-info-col">
       <h1 class="f-premium" style="margin:0; font-size: 32px;">{{ product.title }}</h1>
       
       <div class="ai-price-row">
         <span class="ai-current-price">{{ product.price | money }}</span>
         {% if product.compare_at_price > product.price %}
           <span class="ai-old-price">{{ product.compare_at_price | money }}</span>
         {% endif %}
       </div>

       <div style="margin: 30px 0;">
         {%- assign product_form_id = 'product-form-' | append: section.id -%}
         {% render 'buy-buttons', product: product, product_form_id: product_form_id %}
       </div>

       <div class="rte" style="margin-top: 30px; line-height: 1.6;">
         {{ product.description }}
       </div>
    </div>
  </div>
</section>
