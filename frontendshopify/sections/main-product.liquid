<!-- STICKY BOTTOM BAR -->
<div class="ai-sticky-bar" id="StickyBar-{{ section.id }}">
   <div class="ai-sticky-banner">₹{{ section.settings.cashback_amount | default: '500' }} Cashback on all prepaid orders*🥳</div>
   <div class="ai-sticky-content">
      <div class="ai-sticky-top-info">
         <img src="{{ product.featured_image | image_url: width: 150 }}" class="ai-sticky-img" alt="{{ product.title | escape }}">
         <div class="ai-sticky-info">
            <div class="ai-sticky-title">{{ product.title }}</div>
            <div class="ai-sticky-price-row">
               <span class="ai-sticky-price">
                  {% assign p_money = product.price | money %}
                  {% if p_money contains '₹' or p_money contains 'Rs.' %}
                    ₹{{ product.price | divided_by: 100.00 | round }}
                  {% else %}
                    {{ product.price | money }}
                  {% endif %}
               </span>
               {% if product.compare_at_price > product.price %}
                  <span class="ai-sticky-old">
                     {% assign cp_money = product.compare_at_price | money %}
                     {% if cp_money contains '₹' or cp_money contains 'Rs.' %}
                       ₹{{ product.compare_at_price | divided_by: 100.00 | round }}
                     {% else %}
                       {{ product.compare_at_price | money }}
                     {% endif %}
                  </span>
                  {% assign diff = product.compare_at_price | minus: product.price %}
                  {% assign percent = diff | times: 100.0 | divided_by: product.compare_at_price | round %}
                  <span class="ai-sticky-discount">{{ percent }}% + Extra 20% OFF</span>
               {% endif %}
            </div>
         </div>
      </div>
      <div class="ai-sticky-btns">
         <button class="ai-btn-atc" onclick="document.querySelector('.product-form__submit').click()">ADD TO CART</button>
         <button class="ai-btn-buy" onclick="document.querySelector('.product-form__submit').click()">BUY NOW</button>
      </div>
   </div>
</div>


<script>
  let curMediaIdx = 0;
  const totalMedia = {{ product.media.size }};

  function changeImg(el, fullUrl, idx) {
    const thumbs = document.querySelectorAll('.ai-thumb-item');
    thumbs.forEach(i => i.classList.remove('active'));
    el.classList.add('active');
    document.getElementById('FeaturedImage-{{ section.id }}').src = fullUrl;
    curMediaIdx = idx;
  }

  function moveGal(dir) {
    curMediaIdx = (curMediaIdx + dir + totalMedia) % totalMedia;
    const thumbs = document.querySelectorAll('.ai-thumb-item');
    thumbs[curMediaIdx].click();
    thumbs[curMediaIdx].scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
  }

  function toggleOffer(btn) {
    const content = btn.nextElementSibling;
    const isOpen = content.style.display === 'block';
    content.style.display = isOpen ? 'none' : 'block';
    btn.querySelector('small').innerText = isOpen ? '▼' : '▲';
  }

  function toggleAcc(btn) {
     const content = btn.nextElementSibling;
     const isOpen = content.style.display === 'block';
     content.style.display = isOpen ? 'none' : 'block';
     btn.querySelector('span').innerText = isOpen ? '+' : '−';
  }

  let curRev = 0;
  function setRev(idx) {
     const slides = document.querySelectorAll('.ai-review-slide');
     const dots = document.querySelectorAll('.ai-dot');
     if(!slides.length) return;
     slides.forEach(s => s.classList.remove('active'));
     dots.forEach(d => d.classList.remove('active'));
     slides[idx].classList.add('active');
     dots[idx].classList.add('active');
     curRev = idx;
  }

  // Auto-slide reviews
  setInterval(() => {
     const slides = document.querySelectorAll('.ai-review-slide');
     if(slides.length > 1) {
        curRev = (curRev + 1) % slides.length;
        setRev(curRev);
     }
  }, 4000);

      // Sticky Bar Logic
  window.addEventListener('scroll', () => {
     const bar = document.getElementById('StickyBar-{{ section.id }}');
     const atc = document.querySelector('.product-form__buttons');
     if(!atc || !bar) return;
     const atcTop = atc.getBoundingClientRect().top;
     if(atcTop < 0) bar.classList.add('visible');
     else bar.classList.remove('visible');
  });

  // Timer Logic
  (function() {
    function updateTimer() {
      if(!display) return;
      const now = new Date();
      const tomorrow = new Date(now.getFullYear(), now.getMonth(), now.getDate() + 1);
      const diff = tomorrow - now;
      const hours = Math.floor(diff / (1000 * 60 * 60));
      const mins = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
      const secs = Math.floor((diff % (1000 * 60)) / 1000);
      display.innerText = `${hours.toString().padStart(2, '0')} hr : ${mins.toString().padStart(2, '0')} min : ${secs.toString().padStart(2, '0')} sec`;
    }
    setInterval(updateTimer, 1000); updateTimer();
  })();

    // REVIEWS STAR INPUT
    document.querySelectorAll('#StarInput-{{ section.id }} span').forEach(star => {
       star.addEventListener('click', function() {
          const val = this.getAttribute('data-val');
          const parent = this.parentElement;
          parent.querySelectorAll('span').forEach((s, idx) => {
             if(idx < val) s.classList.add('active');
             else s.classList.remove('active');
          });
          parent.setAttribute('data-selected', val);
       });
    });

    function previewRevImgs(input) {
       const preview = document.getElementById('ImgPreview-{{ section.id }}');
       preview.innerHTML = '';
       if (input.files) {
          Array.from(input.files).forEach(file => {
             const reader = new FileReader();
             reader.onload = function(e) {
                const div = document.createElement('div');
                div.className = 'ai-img-preview-item';
                div.innerHTML = `<img src="${e.target.result}">`;
                preview.appendChild(div);
             }
             reader.readAsDataURL(file);
          });
       }
    }

    function submitMockReview(sid) {
       const nameInput = document.getElementById('RevName-'+sid);
       const name = nameInput.value;
       const text = document.getElementById('RevText-'+sid).value;
       const stars = document.getElementById('StarInput-'+sid).getAttribute('data-selected') || 5;
       
       if(!name || !text) { alert('Please fill in your name and review text.'); return; }

       const list = document.getElementById('RevList-'+sid);
       const newItem = document.createElement('div');
       newItem.className = 'ai-review-item';
       newItem.style.animation = 'slideDown 0.4s ease';
       
       let starsHtml = '';
       for(let i=0; i<5; i++) starsHtml += (i < stars ? '★' : '☆');

       newItem.innerHTML = `
          <div class="ai-review-user-row">
             <div class="ai-review-avatar">${name.charAt(0).toUpperCase()}</div>
             <div class="ai-review-user-info">
                <span class="ai-review-user-name">${name} <span class="ai-verified-badge">Just now ✓</span></span>
                <span class="ai-review-date">Today</span>
             </div>
          </div>
          <div class="ai-review-stars" style="color:#fbbc05;">${starsHtml}</div>
          <div class="ai-review-text">${text}</div>
          <div style="margin-top:10px; color:#34a853; font-weight:800; font-size:12px;">Review submitted successfully!</div>
       `;
       
       list.prepend(newItem);
       document.getElementById('ReviewForm-'+sid).classList.remove('visible');
       // Clear form
       if(!nameInput.hasAttribute('readonly')) nameInput.value = '';
       document.getElementById('RevText-'+sid).value = '';

       // Save to LocalStorage to "make it working" for this browser
       const existing = JSON.parse(localStorage.getItem('my_reviews') || '[]');
       existing.push({ name, text, stars, date: 'Today' });
       localStorage.setItem('my_reviews', JSON.stringify(existing));
    }

    function checkPincode(sid) {
       const pin = document.getElementById('PincodeInput-'+sid).value;
       const msg = document.getElementById('DeliveryMsg-'+sid);
       if(pin.length < 6) { alert('Please enter a valid 6-digit pincode'); return; }
       
       const tomorrow = new Date(); tomorrow.setDate(tomorrow.getDate() + 3);
       const days = ["Sunday","Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"];
       const months = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];
       
       msg.style.display = 'block';
       msg.innerText = `Expected delivery by ${days[tomorrow.getDay()]}, ${tomorrow.getDate()} ${months[tomorrow.getMonth()]}`;
    }
    // QUANTITY PACK SELECTOR LOGIC
    window.selectPack = function(el, qty) {
      // Toggle visual state
      document.querySelectorAll('.ai-qs-card').forEach(card => card.classList.remove('selected'));
      el.classList.add('selected');

      // Update Shopify Quantity Input
      const qtyInput = document.querySelector('input[name="quantity"]');
      if (qtyInput) qtyInput.value = qty;

      // Update Shopify Variant (based on index)
      const variantSelect = document.querySelector('select[name="id"]');
      if (variantSelect && variantSelect.options[qty - 1]) {
        variantSelect.selectedIndex = qty - 1;
        variantSelect.dispatchEvent(new Event('change', { bubbles: true }));
      }
      
      // Update Price display (optional sync)
      const priceVal = el.getAttribute('data-price');
      const priceDisplay = document.querySelector('.ai-current-price');
      if (priceDisplay) priceDisplay.innerText = priceVal;
    };

    // URGENCY TIMER LOGIC
    function initPackTimer() {
      const timerId = 'pack-timer-{{ section.id }}';
      const storageKey = 'astro_pack_timer_end';
      let endTime = localStorage.getItem(storageKey);

      if (!endTime) {
        const hours = {{ block.settings.timer_hours | default: 12 }};
        endTime = new Date().getTime() + (hours * 60 * 60 * 1000);
        localStorage.setItem(storageKey, endTime);
      }

      function updateTimer() {
        const now = new Date().getTime();
        const distance = endTime - now;

        if (distance < 0) {
          // Reset timer if ended
          const hours = {{ block.settings.timer_hours | default: 12 }};
          endTime = new Date().getTime() + (hours * 60 * 60 * 1000);
          localStorage.setItem(storageKey, endTime);
          return;
        }

        const h = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        const m = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
        const s = Math.floor((distance % (1000 * 60)) / 1000);

        const display = document.getElementById(timerId);
        if (display) {
          display.innerHTML = `${h} hr : ${m} min : ${s} sec`;
        }
      }

      setInterval(updateTimer, 1000);
      updateTimer();
    }
    
    // Auto-select Pack 2 on load and init timer
    document.addEventListener('DOMContentLoaded', () => {
      const pack2 = document.querySelector('.ai-qs-card:nth-child(2)');
      if (pack2) pack2.click();
      initPackTimer();
    });

    // GLOBAL REVIEW HELPERS
    window.setGStars = function(el, val) {
       const parent = el.parentElement;
       parent.querySelectorAll('span').forEach((s, idx) => {
          if(idx < val) s.classList.add('active');
          else s.classList.remove('active');
       });
       parent.setAttribute('data-selected', val);
    };

    window.submitGlobalReview = function(sid) {
       const name = document.getElementById('GRevName-' + sid).value;
       const text = document.getElementById('GRevText-' + sid).value;
       const stars = document.getElementById('GStarInput-' + sid).getAttribute('data-selected') || 5;
       if(!name || !text) { alert('Please enter your name and feedback.'); return; }
       const list = document.getElementById('GRevList-' + sid);
       const card = document.createElement('div');
       card.className = 'ai-g-rev-card';
       card.style.cssText = 'padding:15px; border:1px solid #f0f0f0; border-radius:10px; background:#fff; margin-bottom:15px;';
       let starsHtml = '';
       for(let i=0; i<5; i++) starsHtml += (i < stars ? '★' : '☆');
       card.innerHTML = `
          <div style="font-weight:800; font-size:14px; margin-bottom:5px;">${name} <span style="background:#e8f0fe; color:#1a73e8; font-size:9px; padding: 2px 8px; border-radius: 10px; margin-left: 5px;">Just now</span></div>
          <div style="color:#fbbc05; font-size:12px; margin-bottom:8px;">${starsHtml}</div>
          <div style="font-size:13px; line-height:1.4; color:#444;">${text}</div>
       `;
       list.prepend(card);
       list.classList.add('active');
       document.getElementById('GlobalRevForm-' + sid).classList.remove('active');
       alert('Thank you! Your review has been submitted.');
    };

</script>

