<section class="wallet-recharge-section" id="recharge-section">
  <div class="recharge-container">
    <div class="header-card">
      <div class="balance-info">
        <p>Available Balance</p>
        <h2 id="wallet-display-balance">₹--</h2>
      </div>
      <div class="wallet-icon">💳</div>
    </div>

    <div class="recharge-options">
      <h3>Add Money to Wallet</h3>
      <p class="subtitle">Quickly top-up your balance for instant consultations</p>

      <!-- Custom Amount Input -->
      <div class="custom-amount-box">
        <span class="currency-symbol">₹</span>
        <input type="number" id="custom-recharge-input" placeholder="Enter custom amount (e.g. 11)" min="1">
        <button class="add-btn" onclick="rechargeCustom()">Add Money</button>
      </div>

      <!-- Quick Packs Grid -->
      <div class="packs-grid">
        <div class="pack-card" onclick="rechargePack(100)">
          <div class="amount">₹100</div>
          <div class="label">Starter Pack</div>
        </div>
        <div class="pack-card recommended" onclick="rechargePack(500)">
          <div class="badge">Popular</div>
          <div class="amount">₹500</div>
          <div class="label">Best Value</div>
        </div>
        <div class="pack-card" onclick="rechargePack(2000)">
          <div class="amount">₹2000</div>
          <div class="label">Expert Pack</div>
        </div>
      </div>
    </div>

    <!-- My Bookings Section -->
    <div class="bookings-section" style="margin-top: 40px; background: #fff; border-radius: 25px; padding: 40px; box-shadow: 0 10px 30px rgba(0,0,0,0.05);">
      <h3 style="margin: 0 0 10px; font-size: 1.5rem; color: #222;">My Upcoming Bookings</h3>
      <p class="subtitle" style="margin-bottom: 20px;">Your scheduled advance sessions with astrologers</p>
      
      <div id="BookingsList" style="display: flex; flex-direction: column; gap: 15px;">
        <div style="color: #64748b; font-size: 14px;">Loading bookings...</div>
      </div>
    </div>
  </div>
</section>

{{ 'api.js' | asset_url | script_tag }}

<script>
const customerId = "{{ customer.id }}";
const masterVariantId = "48321609400420"; // Forced Variant ID

document.addEventListener('DOMContentLoaded', async () => {
    if (!customerId) {
        document.getElementById('recharge-section').innerHTML = `
          <div class="login-required">
            <h3>Login Required</h3>
            <p>Please log in to your account to recharge your wallet.</p>
            <a href="/account/login" class="login-btn">Log In Now</a>
          </div>
        `;
        return;
    }

    try {
        const { balance } = await AstroAPI.getWalletBalance(customerId);
        document.getElementById('wallet-display-balance').innerText = `₹${balance}`;
    } catch (e) {
        console.error("Failed to load balance", e);
    }

    try {
        await loadBookings();
    } catch (e) {
        console.error("Failed to load bookings", e);
    }
});

async function loadBookings() {
    const container = document.getElementById('BookingsList');
    try {
        const bookings = await AstroAPI.getCustomerBookings(customerId);
        if (!bookings || bookings.length === 0) {
            container.innerHTML = '<div style="color: #64748b; font-size: 14px; padding: 20px; background: #f8fafc; border-radius: 12px; text-align: center;">You have no upcoming bookings.</div>';
            return;
        }

        container.innerHTML = bookings.map(b => {
            const astro = b.astrologers;
            const scheduledDate = new Date(b.scheduled_at);
            const dateStr = scheduledDate.toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' });
            const timeStr = scheduledDate.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit', hour12: true });
            
            // Allow joining 5 mins before start time
            const now = new Date();
            const joinTime = new Date(scheduledDate.getTime() - 5 * 60000);
            const canJoin = now >= joinTime;

            return `
              <div class="booking-card" style="border: 1px solid #e2e8f0; border-radius: 16px; padding: 20px; display: flex; justify-content: space-between; align-items: center; background: #f8fafc;">
                <div style="display: flex; gap: 15px; align-items: center;">
                  <img src="${astro.profile_image || 'https://cdn-icons-png.flaticon.com/512/3135/3135715.png'}" style="width: 50px; height: 50px; border-radius: 50%; object-fit: cover;">
                  <div>
                    <h4 style="margin: 0 0 5px; color: #1e293b;">${astro.name}</h4>
                    <div style="font-size: 13px; color: #64748b; font-weight: 700;">📅 ${dateStr} at ${timeStr}</div>
                    <div style="font-size: 12px; color: #94a3b8; margin-top: 2px;">⏳ ${b.duration_minutes} Mins</div>
                  </div>
                </div>
                <div>
                  ${canJoin 
                    ? `<a href="/pages/chat?session_id=${b.id}" class="add-btn" style="text-decoration:none; padding:10px 20px; font-size:14px; background:#22c55e;">Join Chat</a>`
                    : `<button class="add-btn" style="background:#94a3b8; padding:10px 20px; font-size:14px; cursor:not-allowed;" disabled>Join at ${timeStr}</button>`
                  }
                </div>
              </div>
            `;
        }).join('');
    } catch (e) {
        container.innerHTML = '<div style="color: #ef4444; font-size: 14px;">Failed to load bookings.</div>';
    }
}

function rechargePack(amount) {
    addToCart(amount);
}

function rechargeCustom() {
    const amount = document.getElementById('custom-recharge-input').value;
    if (!amount || amount < 1) {
        alert("Please enter a valid amount.");
        return;
    }
    addToCart(parseInt(amount));
}

async function addToCart(quantity) {
    if (!masterVariantId || masterVariantId === "") {
        alert("Setup Required: Please go to Theme Editor -> 'Wallet Recharge' section and paste your ₹1 Product Variant ID.");
        return;
    }

    const btn = event.target.closest('button') || event.target;
    const originalText = btn.innerText;
    btn.innerText = "Processing...";
    btn.disabled = true;

    const formData = {
        'items': [{
            'id': parseInt(masterVariantId),
            'quantity': quantity,
            'properties': {
                '_is_wallet_recharge': 'true'
            }
        }]
    };

    try {
        const response = await fetch(window.Shopify.routes.root + 'cart/add.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(formData)
        });

        if (response.ok) {
            // Success! Send them to the checkout and ask checkout to return to the wallet page
            window.location.href = '/checkout?return_to=' + encodeURIComponent('/pages/wallet');
        } else {
            const data = await response.json();
            alert(`Error: ${data.description}`);
            btn.innerText = originalText;
            btn.disabled = false;
        }
    } catch (error) {
        console.error('Recharge failed:', error);
        alert('Could not connect to payment gateway.');
        btn.innerText = originalText;
        btn.disabled = false;
    }
}
</script>

<style>
.wallet-recharge-section {
  padding: 60px 20px;
  font-family: 'Outfit', sans-serif;
  background: #f8f9fa;
  min-height: 80vh;
}
.recharge-container {
  max-width: 600px;
  margin: 0 auto;
}
.header-card {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  border-radius: 25px;
  padding: 40px;
  color: #fff;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40px;
  box-shadow: 0 15px 35px rgba(0,0,0,0.2);
}
.balance-info p { margin: 0; opacity: 0.7; letter-spacing: 1px; text-transform: uppercase; font-size: 0.8rem; }
.balance-info h2 { margin: 10px 0 0; font-size: 3rem; font-weight: 700; color: #ff9800; }
.wallet-icon { font-size: 3.5rem; opacity: 0.2; }

.recharge-options {
  background: #fff;
  border-radius: 25px;
  padding: 40px;
  box-shadow: 0 10px 30px rgba(0,0,0,0.05);
}
.recharge-options h3 { margin: 0 0 10px; font-size: 1.5rem; color: #222; }
.subtitle { margin: 0 0 30px; color: #666; font-size: 0.95rem; }

.custom-amount-box {
  display: flex;
  background: #f1f3f5;
  border-radius: 15px;
  padding: 10px;
  margin-bottom: 40px;
  border: 2px solid transparent;
  transition: all 0.3s;
}
.custom-amount-box:focus-within { border-color: #ff9800; background: #fff; }
.currency-symbol { padding: 10px 15px; font-size: 1.5rem; font-weight: 700; color: #222; }
.custom-amount-box input {
  flex: 1;
  border: none;
  background: transparent;
  font-size: 1.5rem;
  font-weight: 700;
  outline: none;
  padding: 10px;
}
.add-btn {
  background: #ff9800;
  color: #fff;
  border: none;
  padding: 0 30px;
  border-radius: 12px;
  font-weight: 700;
  cursor: pointer;
}

.packs-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
}
.pack-card {
  background: #fff;
  border: 2px solid #eee;
  border-radius: 18px;
  padding: 25px 15px;
  text-align: center;
  cursor: pointer;
  transition: all 0.3s;
  position: relative;
}
.pack-card:hover { border-color: #ff9800; transform: translateY(-5px); box-shadow: 0 10px 20px rgba(0,0,0,0.05); }
.pack-card .amount { font-size: 1.4rem; font-weight: 800; color: #1a1a2e; margin-bottom: 5px; }
.pack-card .label { font-size: 0.75rem; color: #888; text-transform: uppercase; letter-spacing: 0.5px; }

.pack-card.recommended { border-color: #ff9800; background: #fffbf2; }
.badge {
  position: absolute;
  top: -12px;
  left: 50%;
  transform: translateX(-50%);
  background: #ff9800;
  color: #fff;
  font-size: 0.65rem;
  font-weight: 800;
  padding: 4px 10px;
  border-radius: 50px;
  text-transform: uppercase;
}

.login-required { text-align: center; padding: 100px 20px; }
.login-btn { display: inline-block; background: #1a1a2e; color: #fff; padding: 15px 40px; border-radius: 50px; text-decoration: none; margin-top: 20px; font-weight: bold; }

@media (max-width: 600px) {
  .packs-grid { grid-template-columns: 1fr; }
  .header-card { padding: 25px; flex-direction: column; align-items: flex-start; gap: 15px; }
  .balance-info h2 { font-size: 2.2rem; }
  .wallet-icon { display: none; }
  
  .custom-amount-box { flex-direction: column; background: transparent; padding: 0; gap: 10px; border: none; margin-bottom: 30px; }
  .custom-amount-box input { background: #f1f3f5; border-radius: 12px; padding: 15px; width: 100%; box-sizing: border-box; }
  .currency-symbol { display: none; }
  .add-btn { width: 100%; padding: 15px; box-sizing: border-box; text-align: center; display: block; }
  
  .recharge-options { padding: 25px 20px; }
  .bookings-section { padding: 25px 20px !important; }
  
  .booking-card { flex-direction: column !important; align-items: flex-start !important; gap: 15px; }
  .booking-card > div:last-child { width: 100%; }
}
</style>

