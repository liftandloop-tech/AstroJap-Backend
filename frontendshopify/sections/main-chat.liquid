{{ 'api.js' | asset_url | script_tag }}

{%- style -%}
  .chat-container {
    max-width: 1000px;
    margin: 120px auto 40px;
    height: calc(100vh - 200px);
    display: flex;
    background: #fff;
    border-radius: 24px;
    box-shadow: 0 20px 50px rgba(0,0,0,0.1);
    overflow: hidden;
    font-family: 'Outfit', sans-serif;
  }

  /* ── Sidebar ── */
  .chat-info-sidebar {
    width: 300px;
    background: #f8fafc;
    border-right: 1px solid #e2e8f0;
    display: flex;
    flex-direction: column;
    padding: 30px;
  }

  .astro-profile-mini {
    text-align: center;
    margin-bottom: 40px;
  }

  .astro-avatar {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    object-fit: cover;
    margin: 0 auto 15px;
    border: 4px solid #fff;
    box-shadow: 0 10px 20px rgba(0,0,0,0.1);
  }

  .timer-box {
    background: #1e293b;
    color: #fff;
    padding: 20px;
    border-radius: 16px;
    text-align: center;
    margin-top: auto;
  }

  .timer-value {
    font-size: 32px;
    font-weight: 800;
    font-variant-numeric: tabular-nums;
  }

  /* ── Chat Main ── */
  .chat-main {
    flex: 1;
    display: flex;
    flex-direction: column;
    background: #fff;
  }

  .chat-header {
    padding: 20px 30px;
    border-bottom: 1px solid #e2e8f0;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .chat-messages {
    flex: 1;
    padding: 30px;
    overflow-y: auto;
    background: #fdfdfd;
    display: flex;
    flex-direction: column;
    gap: 15px;
  }

  .msg {
    max-width: 70%;
    padding: 12px 18px;
    border-radius: 18px;
    font-size: 15px;
    line-height: 1.5;
    position: relative;
  }

  .msg-received {
    align-self: flex-start;
    background: #f1f5f9;
    color: #1e293b;
    border-bottom-left-radius: 4px;
  }

  .msg-sent {
    align-self: flex-end;
    background: #f97316;
    color: #fff;
    border-bottom-right-radius: 4px;
  }

  .chat-input-area {
    padding: 25px 30px;
    border-top: 1px solid #e2e8f0;
    display: flex;
    gap: 15px;
  }

  .chat-input-area input {
    flex: 1;
    padding: 15px 20px;
    border: 1px solid #e2e8f0;
    border-radius: 14px;
    outline: none;
    font-size: 15px;
  }

  .send-btn {
    background: #f97316;
    color: #fff;
    border: none;
    padding: 0 25px;
    border-radius: 14px;
    font-weight: 700;
    cursor: pointer;
  }

  .end-btn {
    background: #fee2e2;
    color: #ef4444;
    border: none;
    padding: 10px 20px;
    border-radius: 10px;
    font-weight: 700;
    cursor: pointer;
  }

  @media screen and (max-width: 768px) {
    .chat-container {
      margin: 80px 10px 20px;
      height: calc(100vh - 120px);
    }
    .chat-info-sidebar { display: none; }
  }
{%- endstyle -%}

<div id="ChatAuthWrapper">
  <div class="chat-container" id="ChatView" style="display:none;">
    <!-- Sidebar -->
    <aside class="chat-info-sidebar">
      <div class="astro-profile-mini">
        <img id="AstroImg" src="" class="astro-avatar" alt="">
        <h3 id="AstroName" style="margin:0;font-weight:800;">Loading...</h3>
        <p id="AstroExpertise" style="font-size:13px;color:#64748b;margin-top:5px;">Vedic Astrology</p>
      </div>
      
      <div class="timer-box">
        <div style="font-size:12px;opacity:0.7;margin-bottom:5px;">SESSION TIME REMAINING</div>
        <div class="timer-value" id="SessionTimer">20:00</div>
      </div>
    </aside>

    <!-- Main Chat -->
    <div class="chat-main">
      <div class="chat-header">
        <div>
          <span style="font-weight:800;color:#1e293b;">Live Consultation</span>
          <div id="ChatStatus" style="font-size:12px;color:#f59e0b;">● Waiting for Astrologer...</div>
        </div>
        <button class="end-btn" onclick="confirmEndChat()">End Session</button>
      </div>

      <div class="chat-messages" id="ChatMessages">
        <div class="msg msg-received">Namaste! I will be joining shortly. Please wait...</div>
      </div>

      <form class="chat-input-area" id="ChatForm">
        <input type="text" id="MsgInput" placeholder="Type your message here..." autocomplete="off">
        <button type="submit" class="send-btn">Send</button>
      </form>
    </div>
  </div>

  <div id="LoginView" style="display:none; text-align:center; padding:100px 20px; font-family:'Outfit', sans-serif;">
    <div style="font-size:64px; margin-bottom:20px;">🔒</div>
    <h2 style="font-weight:800; color:#1e293b;">Login Required</h2>
    <p style="color:#64748b; max-width:400px; margin:0 auto 30px;">You must be logged in to your account to start a consultation.</p>
    <a href="/account/login?checkout_url={{ request.path }}?id={{ astrologerId }}" class="btn-primary" style="text-decoration:none; display:inline-block; padding:12px 30px; background:#f97316; color:#fff; border-radius:12px; font-weight:700;">Login to Continue</a>
  </div>
</div>

<script>
  let pollInterval;
  let renderedMessages = new Set();
  const urlParams = new URLSearchParams(window.location.search);
  const sessionId = urlParams.get('session_id');
  const customerId = '{{ customer.id }}';
  const astroToken = localStorage.getItem('astro_token');
  const astroId = localStorage.getItem('astro_id');
  
  // Identify who is logging in
  const isAstrologer = !!astroToken;
  const currentUserId = isAstrologer ? astroId : customerId;
  const currentUserType = isAstrologer ? 'astrologer' : 'customer';

  async function initChat() {
    if (!sessionId) {
      alert('Invalid session. Returning to home.');
      window.location.href = '/';
      return;
    }

    if (!isAstrologer && !customerId) {
      document.getElementById('LoginView').style.display = 'block';
      return;
    }

    document.getElementById('ChatView').style.display = 'flex';

    // Fetch session details to get Astrologer info
    try {
      const res = await AstroAPI.getSessionById(sessionId);
      if (res && res.session && res.session.astrologers) {
        document.getElementById('AstroName').textContent = isAstrologer ? "Customer" : res.session.astrologers.name;
        document.getElementById('AstroImg').src = res.session.astrologers.profile_image || 'https://cdn-icons-png.flaticon.com/512/3135/3135715.png';
      }
    } catch (e) { console.error('Failed to load session details', e); }

    // Start Polling for messages
    pollMessages();
    pollInterval = setInterval(pollMessages, 2000);
    
    // Announce arrival
    try {
      if (isAstrologer) {
        // Start the session on the backend immediately when astrologer opens the chat!
        await AstroAPI.startSession(sessionId);
      }
      
      await AstroAPI.sendChatMessage(
        sessionId,
        currentUserId,
        currentUserType,
        isAstrologer ? 'Astrologer has joined the chat. Session has started!' : 'Customer has joined the chat.',
        true
      );
    } catch(e) {}

    // Handle form
    const chatForm = document.getElementById('ChatForm');
    if (chatForm) {
      chatForm.onsubmit = async (e) => {
        e.preventDefault();
        const input = document.getElementById('MsgInput');
        if (!input.value.trim()) return;
        
        const msgText = input.value.trim();
        input.value = '';
        
        // Optimistically render
        const tempId = 'temp_' + Date.now();
        renderedMessages.add(tempId);
        appendMessage(msgText, 'sent', false);

        try {
          await AstroAPI.sendChatMessage(sessionId, currentUserId, currentUserType, msgText, false);
          pollMessages(); // Fetch to confirm
        } catch(e) {
          console.error("Failed to send message", e);
        }
      };
    }
  }

  async function pollMessages() {
    try {
      const messages = await AstroAPI.getChatMessages(sessionId);
      if (!messages || !Array.isArray(messages)) return;
      
      let astrologerJoined = false;

      messages.forEach(msg => {
        if (!renderedMessages.has(msg.id)) {
          renderedMessages.add(msg.id);
          const isMine = msg.sender_id === currentUserId && msg.sender_type === currentUserType;
          
          if (!isMine || msg.is_system) {
            appendMessage(msg.text, isMine ? 'sent' : 'received', msg.is_system);
          }
          
          if (msg.is_system && msg.sender_type === 'astrologer') {
            astrologerJoined = true;
          }
        }
      });
      
      if (astrologerJoined || isAstrologer) {
        document.getElementById('ChatStatus').textContent = '● Connected';
        document.getElementById('ChatStatus').style.color = '#22c55e';
      }

      // Sync Timer with Backend
      if (astrologerJoined || isAstrologer) {
        const valRes = await AstroAPI.validateSession(sessionId);
        if (valRes && valRes.remaining_seconds !== undefined) {
          updateTimerDisplay(valRes.remaining_seconds);
          if (valRes.remaining_seconds <= 0) {
            alert("Session time is up!");
            window.location.href = '/';
          }
        }
      }

    } catch(e) {
      console.error("Poll error", e);
    }
  }

  function updateTimerDisplay(totalSeconds) {
    const timerEl = document.getElementById('SessionTimer');
    if (!timerEl) return;
    if (totalSeconds <= 0) {
      timerEl.textContent = "0:00";
      return;
    }
    const mins = Math.floor(totalSeconds / 60);
    const secs = Math.floor(totalSeconds % 60);
    timerEl.textContent = `${mins}:${secs.toString().padStart(2, '0')}`;
  }

  function appendMessage(text, type, isSystem = false) {
    const container = document.getElementById('ChatMessages');
    if (!container) return;
    const div = document.createElement('div');
    div.className = `msg msg-${type}`;
    if (isSystem) {
      div.style.background = 'transparent';
      div.style.color = '#64748b';
      div.style.fontSize = '12px';
      div.style.textAlign = 'center';
      div.style.width = '100%';
      div.style.maxWidth = '100%';
      div.style.alignSelf = 'center';
    }
    div.textContent = text;
    container.appendChild(div);
    container.scrollTop = container.scrollHeight;
  }

  function confirmEndChat() {
    if (confirm('Are you sure you want to end this session?')) {
      window.location.href = '/';
    }
  }

  document.addEventListener('DOMContentLoaded', initChat);
</script>

{% schema %}
{
  "name": "Main Chat",
  "settings": [],
  "presets": [
    {
      "name": "Main Chat"
    }
  ]
}
{% endschema %}
