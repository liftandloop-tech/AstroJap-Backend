{% doc %}
  @prompt
    🚨 IMPORTANT (STRICT INSTRUCTION)
    
    DO NOT create a simple banner.
    DO NOT create plain text with a button.
    
    Create a premium feature highlight section that clearly explains the kundli tool and encourages users to generate their kundli.
    
    🧾 SECTION PURPOSE
    
    This section should:
    
    Promote the Free Kundli Generator
    
    Explain benefits briefly
    
    Drive users to the Kundli page
    
    🧱 LAYOUT (MANDATORY)
    
    Use a 2-column layout:
    
    Left Side:
    
    Heading
    
    Subheading
    
    Feature points
    
    CTA button
    
    Right Side:
    
    Astrology-themed image (kundli chart / zodiac / birth chart illustration)
    
    🧾 CONTENT (Astrojap Data)
    Heading:
    
    Generate Your Free Kundli
    
    Subheading:
    
    Get your detailed Janam Kundli with accurate planetary positions and predictions based on your birth details.
    
    Feature Points (Bullet Style):
    
    Instant kundli generation
    
    Accurate Vedic astrology calculations
    
    Insights on career, marriage & health
    
    Easy and free to use
    
    🔘 CTA BUTTON (VERY IMPORTANT)
    
    Button text:
    
    Create Your Kundli
    
    Button link:
    
    /pages/free-kundli
    
    👉 This must redirect to the kundli page
    
    🎨 DESIGN STYLE
    
    Premium astrology feel
    
    Background:
    
    Light gradient OR soft dark theme
    
    Clean spacing
    
    Rounded elements
    
    Subtle shadows
    
    ⚙️ FULLY EDITABLE (VERY IMPORTANT)
    
    All elements must be editable from Shopify customizer:
    
    Heading
    
    Subheading
    
    Feature points
    
    Button text & link
    
    Image
    
    Background color
    
    📱 MOBILE BEHAVIOR
    
    Stack layout (image below text)
    
    Full-width CTA button
    
    Proper spacing
    
    ⚙️ TECHNICAL REQUIREMENTS
    
    Use Shopify Liquid + section schema
    
    Reusable section
    
    Optimized for performance
    
    🚀 GOAL
    
    Create a high-converting homepage section that:
    
    Promotes kundli feature
    
    Drives users to generate kundli
    
    Increases engagement
    
    ❗ FINAL INSTRUCTION
    
    Focus on:
    
    Strong CTA
    
    Clear value proposition
    
    Clean premium UI
    
    Do NOT make it look basic., create a different design 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-kundli-premium-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding_top }}px 20px {{ block.settings.section_padding_bottom }}px;
    background: {{ block.settings.background_gradient }};
    background-color: {{ block.settings.background_color }};
    position: relative;
    overflow: hidden;
  }

  .ai-kundli-premium-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -10%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, {{ block.settings.accent_color }}15 0%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
  }

  .ai-kundli-premium-{{ ai_gen_id }}::after {
    content: '';
    position: absolute;
    bottom: -30%;
    left: -5%;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, {{ block.settings.accent_color }}10 0%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
  }

  .ai-kundli-premium-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .ai-kundli-premium-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 45% 55%;
    gap: {{ block.settings.grid_gap }}px;
    align-items: center;
  }

  .ai-kundli-premium-content-{{ ai_gen_id }} {
    padding: 40px;
    background: {{ block.settings.content_bg_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    box-shadow: {{ block.settings.card_shadow_x }}px {{ block.settings.card_shadow_y }}px {{ block.settings.card_shadow_blur }}px rgba(0, 0, 0, {{ block.settings.card_shadow_opacity }});
    backdrop-filter: blur(10px);
    border: 1px solid {{ block.settings.card_border_color }};
  }

  .ai-kundli-premium-badge-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 16px;
    background: {{ block.settings.badge_bg_color }};
    color: {{ block.settings.badge_text_color }};
    font-size: 13px;
    font-weight: 600;
    border-radius: 50px;
    margin-bottom: 20px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-kundli-premium-badge-{{ ai_gen_id }} svg {
    width: 16px;
    height: 16px;
    stroke: currentColor;
  }

  .ai-kundli-premium-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 800;
    color: {{ block.settings.title_color }};
    margin: 0 0 16px 0;
    line-height: 1.1;
    letter-spacing: -0.5px;
  }

  .ai-kundli-premium-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0 0 32px 0;
    line-height: 1.6;
  }

  .ai-kundli-premium-features-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-bottom: 32px;
  }

  .ai-kundli-premium-feature-card-{{ ai_gen_id }} {
    background: {{ block.settings.feature_card_bg }};
    padding: 16px;
    border-radius: {{ block.settings.feature_card_radius }}px;
    border: 1px solid {{ block.settings.feature_card_border }};
    transition: all 0.3s ease;
  }

  .ai-kundli-premium-feature-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.1);
    border-color: {{ block.settings.accent_color }};
  }

  .ai-kundli-premium-feature-icon-wrapper-{{ ai_gen_id }} {
    width: 40px;
    height: 40px;
    background: {{ block.settings.feature_icon_bg }};
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 12px;
  }

  .ai-kundli-premium-feature-icon-wrapper-{{ ai_gen_id }} svg {
    width: 22px;
    height: 22px;
    stroke: {{ block.settings.feature_icon_color }};
  }

  .ai-kundli-premium-feature-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.feature_text_size }}px;
    color: {{ block.settings.feature_text_color }};
    font-weight: 600;
    line-height: 1.4;
  }

  .ai-kundli-premium-cta-wrapper-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .ai-kundli-premium-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: {{ block.settings.button_padding_y }}px {{ block.settings.button_padding_x }}px;
    background: {{ block.settings.button_bg }};
    color: {{ block.settings.button_text_color }};
    font-size: {{ block.settings.button_text_size }}px;
    font-weight: 700;
    text-decoration: none;
    border-radius: {{ block.settings.button_radius }}px;
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 4px 14px {{ block.settings.button_bg }}40;
    position: relative;
    overflow: hidden;
  }

  .ai-kundli-premium-button-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
    transition: left 0.5s ease;
  }

  .ai-kundli-premium-button-{{ ai_gen_id }}:hover::before {
    left: 100%;
  }

  .ai-kundli-premium-button-{{ ai_gen_id }}:hover {
    background: {{ block.settings.button_hover_bg }};
    transform: translateY(-2px);
    box-shadow: 0 6px 20px {{ block.settings.button_bg }}60;
  }

  .ai-kundli-premium-button-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
    stroke: currentColor;
    transition: transform 0.3s ease;
  }

  .ai-kundli-premium-button-{{ ai_gen_id }}:hover svg {
    transform: translateX(4px);
  }

  .ai-kundli-premium-trust-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    color: {{ block.settings.trust_text_color }};
  }

  .ai-kundli-premium-trust-{{ ai_gen_id }} svg {
    width: 18px;
    height: 18px;
    fill: {{ block.settings.accent_color }};
  }

  .ai-kundli-premium-image-section-{{ ai_gen_id }} {
    position: relative;
    height: 100%;
    min-height: 500px;
  }

  .ai-kundli-premium-image-main-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 100%;
    border-radius: {{ block.settings.image_radius }}px;
    overflow: hidden;
    box-shadow: {{ block.settings.image_shadow_x }}px {{ block.settings.image_shadow_y }}px {{ block.settings.image_shadow_blur }}px rgba(0, 0, 0, {{ block.settings.image_shadow_opacity }});
  }

  .ai-kundli-premium-image-main-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-kundli-premium-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 50%, #f093fb 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-kundli-premium-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 350px;
    max-height: 350px;
    opacity: 0.2;
  }

  .ai-kundli-premium-empty-message-{{ ai_gen_id }} {
    position: absolute;
    bottom: 40px;
    left: 50%;
    transform: translateX(-50%);
    background: rgba(255, 255, 255, 0.95);
    padding: 16px 28px;
    border-radius: 12px;
    font-size: 15px;
    font-weight: 600;
    color: #333;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
  }

  .ai-kundli-premium-floating-card-{{ ai_gen_id }} {
    position: absolute;
    background: {{ block.settings.floating_card_bg }};
    padding: 20px;
    border-radius: 16px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.2);
  }

  .ai-kundli-premium-floating-card-1-{{ ai_gen_id }} {
    top: 40px;
    right: -20px;
    width: 180px;
  }

  .ai-kundli-premium-floating-card-2-{{ ai_gen_id }} {
    bottom: 60px;
    left: -30px;
    width: 160px;
  }

  .ai-kundli-premium-floating-title-{{ ai_gen_id }} {
    font-size: 13px;
    color: {{ block.settings.floating_text_color }};
    margin-bottom: 8px;
    font-weight: 600;
  }

  .ai-kundli-premium-floating-value-{{ ai_gen_id }} {
    font-size: 24px;
    font-weight: 800;
    color: {{ block.settings.accent_color }};
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .ai-kundli-premium-floating-value-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
    stroke: {{ block.settings.accent_color }};
  }

  @media screen and (max-width: 989px) {
    .ai-kundli-premium-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .ai-kundli-premium-content-{{ ai_gen_id }} {
      padding: 32px 24px;
    }

    .ai-kundli-premium-features-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-kundli-premium-image-section-{{ ai_gen_id }} {
      min-height: 400px;
    }

    .ai-kundli-premium-floating-card-{{ ai_gen_id }} {
      display: none;
    }

    .ai-kundli-premium-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.75);
    }

    .ai-kundli-premium-cta-wrapper-{{ ai_gen_id }} {
      flex-direction: column;
      align-items: flex-start;
    }

    .ai-kundli-premium-button-{{ ai_gen_id }} {
      width: 100%;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-kundli-premium-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top | times: 0.6 }}px 16px {{ block.settings.section_padding_bottom | times: 0.6 }}px;
    }

    .ai-kundli-premium-content-{{ ai_gen_id }} {
      padding: 24px 20px;
    }

    .ai-kundli-premium-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.65);
    }

    .ai-kundli-premium-image-section-{{ ai_gen_id }} {
      min-height: 350px;
    }
  }
{% endstyle %}

