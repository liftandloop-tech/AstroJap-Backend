    {
      "type": "header",
      "content": "Icon style"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon size",
      "min": 40,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 70
    },
    {
      "type": "color",
      "id": "icon_background",
      "label": "Icon background",
      "default": "#f3f3f3"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
