{% doc %}
  @prompt
    Create a feature highlight section for Astrojap About page.
    
    Heading:
    
    Why Choose Astrojap
    
    Features:
    
    Accurate Vedic astrology calculations
    
    Easy-to-use kundli tools
    
    Trusted by thousands of users
    
    Personalized insights
    
    Layout:
    
    4 feature cards (grid)
    
    Icon + text
    
    Editable:
    
    Features
    
    Icons
    
    Text
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-feature-highlight-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-feature-highlight__container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-feature-highlight__heading-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.heading_spacing }}px;
  }

  .ai-feature-highlight__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-feature-highlight__card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    text-align: {{ block.settings.card_alignment }};
    border: {{ block.settings.card_border_thickness }}px solid {{ block.settings.card_border_color }};
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-feature-highlight__card-{{ ai_gen_id }}:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.1);
  }

  .ai-feature-highlight__icon-{{ ai_gen_id }} {
    font-size: {{ block.settings.icon_size }}px;
    margin-bottom: {{ block.settings.icon_spacing }}px;
    display: inline-block;
  }

  .ai-feature-highlight__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.feature_title_size }}px;
    color: {{ block.settings.feature_title_color }};
    margin: 0 0 {{ block.settings.title_spacing }}px;
    font-weight: 600;
  }

  .ai-feature-highlight__text-{{ ai_gen_id }} {
    font-size: {{ block.settings.feature_text_size }}px;
    color: {{ block.settings.feature_text_color }};
    margin: 0;
    line-height: 1.6;
  }

  @media screen and (max-width: 989px) {
    .ai-feature-highlight__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_tablet }}, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-feature-highlight__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }

    .ai-feature-highlight__heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }
  }
{% endstyle %}

<feature-highlight-{{ ai_gen_id }} class="ai-feature-highlight-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-feature-highlight__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-feature-highlight__heading-{{ ai_gen_id }}">
        {{ block.settings.heading }}
      </h2>
    {% endif %}

    <div class="ai-feature-highlight__grid-{{ ai_gen_id }}">
      {% for i in (1..4) %}
        {% liquid
          assign feature_enabled_key = 'feature_' | append: i | append: '_enabled'
          assign feature_icon_key = 'feature_' | append: i | append: '_icon'
          assign feature_title_key = 'feature_' | append: i | append: '_title'
          assign feature_text_key = 'feature_' | append: i | append: '_text'

          assign feature_enabled = block.settings[feature_enabled_key]
          assign feature_icon = block.settings[feature_icon_key]
          assign feature_title = block.settings[feature_title_key]
          assign feature_text = block.settings[feature_text_key]
        %}

        {% if feature_enabled %}
          <div class="ai-feature-highlight__card-{{ ai_gen_id }}">
            {% if feature_icon != blank %}
              <div class="ai-feature-highlight__icon-{{ ai_gen_id }}">
                {{ feature_icon }}
              </div>
            {% endif %}

            {% if feature_title != blank %}
              <h3 class="ai-feature-highlight__title-{{ ai_gen_id }}">
                {{ feature_title }}
              </h3>
            {% endif %}

            {% if feature_text != blank %}
              <p class="ai-feature-highlight__text-{{ ai_gen_id }}">
                {{ feature_text }}
              </p>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</feature-highlight-{{ ai_gen_id }}>

<script>
  (function() {
    class FeatureHighlight{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('feature-highlight-{{ ai_gen_id }}', FeatureHighlight{{ ai_gen_id }});
  })();
</script>

