{% doc %}
  @prompt
    Create a Shopify section named **astrologer-about**.
    
    Layout:
    
    * Section heading: About Astrologer
    * Long description text (bio, experience, approach)
    
    Design:
    
    * Center aligned content
    * Max-width container
    * Clean typography
    
    Settings:
    
    * Section title
    * Description text
    
    Responsive:
    Readable on mobile with proper spacing.
    
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .astrologer-about-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.padding_top }}px 0 {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .astrologer-about__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 20px;
    text-align: center;
  }

  .astrologer-about__title-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.title_spacing }}px;
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    font-weight: 600;
    line-height: 1.2;
  }

  .astrologer-about__description-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    line-height: 1.6;
    text-align: {{ block.settings.text_alignment }};
  }

  .astrologer-about__description-{{ ai_gen_id }} p {
    margin: 0 0 16px;
  }

  .astrologer-about__description-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  @media screen and (max-width: 749px) {
    .astrologer-about__container-{{ ai_gen_id }} {
      padding: 0 16px;
    }

    .astrologer-about__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
      margin-bottom: {{ block.settings.title_spacing | times: 0.8 }}px;
    }

    .astrologer-about__description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="astrologer-about-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="astrologer-about__container-{{ ai_gen_id }}">
    {% if block.settings.title != blank %}
      <h2 class="astrologer-about__title-{{ ai_gen_id }}">
        {{ block.settings.title }}
      </h2>
    {% endif %}

    {% if block.settings.description != blank %}
      <div class="astrologer-about__description-{{ ai_gen_id }}">
        {{ block.settings.description }}
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Astrologer about",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Title",
      "default": "About Astrologer"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>With over 15 years of experience in Vedic astrology, I specialize in providing personalized guidance for life's most important decisions. My approach combines traditional astrological wisdom with modern insights to help you navigate your path with clarity and confidence.</p><p>I believe that astrology is a powerful tool for self-discovery and transformation. Through detailed birth chart analysis and planetary transit readings, I help clients understand their unique strengths, challenges, and opportunities for growth.</p>"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Maximum width",
      "min": 600,
      "max": 1200,
      "step": 50,
      "unit": "px",
      "default": 800
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Title style"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Title size",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "title_spacing",
      "label": "Title spacing",
      "min": 8,
      "max": 48,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#121212"
    },
    {
      "type": "header",
      "content": "Description style"
    },
    {
      "type": "range",
      "id": "description_size",
      "label": "Description size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Description color",
      "default": "#121212"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Astrologer about"
    }
  ]
}
{% endschema %}
