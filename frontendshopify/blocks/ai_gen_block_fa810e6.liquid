        {% endif %}
        {% if block.settings.col3_sublinks != blank %}
          <ul class="ai-astro-footer__link-list-{{ ai_gen_id }}">
            {% assign sublinks = block.settings.col3_sublinks | newline_to_br | split: '<br />' %}
