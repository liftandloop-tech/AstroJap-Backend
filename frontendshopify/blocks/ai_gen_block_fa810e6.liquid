              {% endif %}
            {% endfor %}
          </ul>
        {% endif %}
      </div>

      <div class="ai-astro-footer__column-{{ ai_gen_id }}">
        {% if block.settings.col4_heading != blank %}
          <h3 class="ai-astro-footer__column-heading-{{ ai_gen_id }}">{{ block.settings.col4_heading }}</h3>
        {% endif %}
        {% if block.settings.col4_links != blank %}
          <ul class="ai-astro-footer__link-list-{{ ai_gen_id }}">
            {% assign links = block.settings.col4_links | newline_to_br | split: '<br />' %}
