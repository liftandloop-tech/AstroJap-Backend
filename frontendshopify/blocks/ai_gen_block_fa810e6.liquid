        {% endif %}
        {% if block.settings.contact_email != blank %}
          <div class="ai-astro-footer__contact-item-{{ ai_gen_id }}">
            <span class="ai-astro-footer__contact-label-{{ ai_gen_id }}">Email:</span>
            <a href="mailto:{{ block.settings.contact_email }}" class="ai-astro-footer__link-{{ ai_gen_id }} ai-astro-footer__contact-value-{{ ai_gen_id }}">
