{% doc %}
  @prompt
    Create a modern, clean, and fully customizable Shopify section for an astrology website named "Astrojab". The section should be designed for a Horoscope page and must include multiple sub-sections with pre-filled sample data.
    
    The design should follow a soft, spiritual theme with light purple, white, and subtle gradient tones. UI should be minimal, modern, and mobile responsive.
    
    IMPORTANT:
    
    * All content must be editable from Shopify customizer
    * Use dynamic blocks wherever possible
    * Keep sections modular and reusable
    * No hardcoded values that cannot be edited
    
    ---
    
    SECTION STRUCTURE:
    
    1. DAILY HOROSCOPE RESULT SECTION
    
    * Title: "Your Horoscope Today"
    * Subtext: "Personalized insights based on your zodiac sign"
    * Pre-filled sample (Leo):
    
      * Love: "Today brings warmth and deeper emotional connection. Express your feelings openly."
      * Career: "Opportunities may arise unexpectedly. Stay confident and take initiative."
      * Health: "Focus on mental relaxation. Avoid stress and take short breaks."
      * Luck: "A positive day overall with favorable outcomes in important matters."
    * Each category
    , didnt like this create somthing else 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-astro-horoscope-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.section_padding }}px 20px;
    background: linear-gradient(135deg, {{ block.settings.gradient_start }} 0%, {{ block.settings.gradient_end }} 100%);
    position: relative;
    overflow: hidden;
  }

  .ai-astro-horoscope-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -10%;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
  }

  .ai-astro-container-{{ ai_gen_id }} {
    position: relative;
    z-index: 1;
    max-width: 900px;
    margin: 0 auto;
  }

  .ai-astro-zodiac-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 40px;
  }

  .ai-astro-zodiac-icon-{{ ai_gen_id }} {
    font-size: {{ block.settings.zodiac_icon_size }}px;
    margin-bottom: 16px;
    display: block;
  }

  .ai-astro-zodiac-name-{{ ai_gen_id }} {
    font-size: {{ block.settings.zodiac_name_size }}px;
    color: {{ block.settings.zodiac_name_color }};
    margin: 0 0 8px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
  }

  .ai-astro-date-range-{{ ai_gen_id }} {
    font-size: {{ block.settings.date_size }}px;
    color: {{ block.settings.date_color }};
    margin: 0 0 20px;
    opacity: 0.9;
  }

  .ai-astro-main-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.main_title_size }}px;
    color: {{ block.settings.main_title_color }};
    margin: 0;
    font-weight: 600;
  }

  .ai-astro-reading-card-{{ ai_gen_id }} {
    background: {{ block.settings.card_background }};
    backdrop-filter: blur(10px);
    border-radius: {{ block.settings.card_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    margin-bottom: {{ block.settings.card_spacing }}px;
    border: 1px solid {{ block.settings.card_border_color }};
    box-shadow: 0 8px 32px rgba(0, 0, 0, {{ block.settings.shadow_opacity }});
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-astro-reading-card-{{ ai_gen_id }}:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, {{ block.settings.shadow_opacity | times: 1.5 }});
  }

  .ai-astro-reading-header-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 16px;
  }

  .ai-astro-reading-icon-wrapper-{{ ai_gen_id }} {
    width: {{ block.settings.reading_icon_size }}px;
    height: {{ block.settings.reading_icon_size }}px;
    background: {{ block.settings.icon_bg_color }};
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: {{ block.settings.reading_icon_size | times: 0.5 }}px;
    flex-shrink: 0;
  }

  .ai-astro-reading-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.reading_title_size }}px;
    color: {{ block.settings.reading_title_color }};
    margin: 0;
    font-weight: 600;
  }

  .ai-astro-reading-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.reading_text_size }}px;
    color: {{ block.settings.reading_text_color }};
    line-height: 1.7;
    margin: 0;
  }

  .ai-astro-footer-{{ ai_gen_id }} {
    text-align: center;
    margin-top: 40px;
    padding-top: 30px;
    border-top: 1px solid {{ block.settings.footer_border_color }};
  }

  .ai-astro-footer-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.footer_text_size }}px;
    color: {{ block.settings.footer_text_color }};
    margin: 0;
    font-style: italic;
    opacity: 0.8;
  }

  @media screen and (max-width: 749px) {
    .ai-astro-horoscope-{{ ai_gen_id }} {
      width: 100%;
      padding: {{ block.settings.section_padding | times: 0.6 }}px 16px;
    }

    .ai-astro-zodiac-icon-{{ ai_gen_id }} {
      font-size: {{ block.settings.zodiac_icon_size | times: 0.8 }}px;
    }

    .ai-astro-zodiac-name-{{ ai_gen_id }} {
      font-size: {{ block.settings.zodiac_name_size | times: 0.8 }}px;
    }

    .ai-astro-main-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.main_title_size | times: 0.8 }}px;
    }

    .ai-astro-reading-card-{{ ai_gen_id }} {
      padding: {{ block.settings.card_padding | times: 0.8 }}px;
    }
  }
{% endstyle %}

<astro-horoscope-{{ ai_gen_id }} class="ai-astro-horoscope-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-astro-container-{{ ai_gen_id }}">
    <div class="ai-astro-zodiac-header-{{ ai_gen_id }}">
      {% if block.settings.zodiac_icon != blank %}
        <span class="ai-astro-zodiac-icon-{{ ai_gen_id }}">{{ block.settings.zodiac_icon }}</span>
      {% endif %}
      {% if block.settings.zodiac_name != blank %}
        <h2 class="ai-astro-zodiac-name-{{ ai_gen_id }}">{{ block.settings.zodiac_name }}</h2>
      {% endif %}
      {% if block.settings.date_range != blank %}
        <p class="ai-astro-date-range-{{ ai_gen_id }}">{{ block.settings.date_range }}</p>
      {% endif %}
      {% if block.settings.main_title != blank %}
        <h3 class="ai-astro-main-title-{{ ai_gen_id }}">{{ block.settings.main_title }}</h3>
      {% endif %}
    </div>

    {% if block.settings.show_love and block.settings.love_text != blank %}
      <div class="ai-astro-reading-card-{{ ai_gen_id }}">
        <div class="ai-astro-reading-header-{{ ai_gen_id }}">
          <div class="ai-astro-reading-icon-wrapper-{{ ai_gen_id }}">
            {{ block.settings.love_icon }}
          </div>
          <h4 class="ai-astro-reading-title-{{ ai_gen_id }}">{{ block.settings.love_title }}</h4>
        </div>
        <p class="ai-astro-reading-text-{{ ai_gen_id }}">{{ block.settings.love_text }}</p>
      </div>
    {% endif %}

    {% if block.settings.show_career and block.settings.career_text != blank %}
      <div class="ai-astro-reading-card-{{ ai_gen_id }}">
        <div class="ai-astro-reading-header-{{ ai_gen_id }}">
          <div class="ai-astro-reading-icon-wrapper-{{ ai_gen_id }}">
            {{ block.settings.career_icon }}
          </div>
          <h4 class="ai-astro-reading-title-{{ ai_gen_id }}">{{ block.settings.career_title }}</h4>
        </div>
        <p class="ai-astro-reading-text-{{ ai_gen_id }}">{{ block.settings.career_text }}</p>
      </div>
    {% endif %}

    {% if block.settings.show_health and block.settings.health_text != blank %}
      <div class="ai-astro-reading-card-{{ ai_gen_id }}">
        <div class="ai-astro-reading-header-{{ ai_gen_id }}">
          <div class="ai-astro-reading-icon-wrapper-{{ ai_gen_id }}">
            {{ block.settings.health_icon }}
          </div>
          <h4 class="ai-astro-reading-title-{{ ai_gen_id }}">{{ block.settings.health_title }}</h4>
        </div>
        <p class="ai-astro-reading-text-{{ ai_gen_id }}">{{ block.settings.health_text }}</p>
      </div>
    {% endif %}

    {% if block.settings.show_wealth and block.settings.wealth_text != blank %}
      <div class="ai-astro-reading-card-{{ ai_gen_id }}">
        <div class="ai-astro-reading-header-{{ ai_gen_id }}">
          <div class="ai-astro-reading-icon-wrapper-{{ ai_gen_id }}">
            {{ block.settings.wealth_icon }}
          </div>
          <h4 class="ai-astro-reading-title-{{ ai_gen_id }}">{{ block.settings.wealth_title }}</h4>
        </div>
        <p class="ai-astro-reading-text-{{ ai_gen_id }}">{{ block.settings.wealth_text }}</p>
      </div>
    {% endif %}

    {% if block.settings.footer_text != blank %}
      <div class="ai-astro-footer-{{ ai_gen_id }}">
        <p class="ai-astro-footer-text-{{ ai_gen_id }}">{{ block.settings.footer_text }}</p>
      </div>
    {% endif %}
  </div>
</astro-horoscope-{{ ai_gen_id }}>

<script>
  (function() {
    class AstroHoroscope{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupAccessibility();
      }

      setupAccessibility() {
        const cards = this.querySelectorAll('.ai-astro-reading-card-{{ ai_gen_id }}');
        cards.forEach((card, index) => {
          card.setAttribute('role', 'article');
          card.setAttribute('aria-label', `Reading ${index + 1}`);
        });
      }
    }

    customElements.define('astro-horoscope-{{ ai_gen_id }}', AstroHoroscope{{ ai_gen_id }});
  })();
</script>

