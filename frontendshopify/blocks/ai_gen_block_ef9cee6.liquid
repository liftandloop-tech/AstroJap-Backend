<script>
  (function() {
    class AstrologyServices{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.slider = this.querySelector('.ai-astrology-services__slider-{{ ai_gen_id }}');
        this.cards = this.querySelectorAll('.ai-astrology-services__card-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.ai-astrology-services__arrow--left-{{ ai_gen_id }}');
        this.nextButton = this.querySelector('.ai-astrology-services__arrow--right-{{ ai_gen_id }}');
        this.totalCards = this.cards.length;
      }

      connectedCallback() {
        this.setupEventListeners();
        this.updateSlider();
      }

      setupEventListeners() {
        this.prevButton.addEventListener('click', () => this.prevSlide());
        this.nextButton.addEventListener('click', () => this.nextSlide());
      }

      getCardsPerView() {
        const width = window.innerWidth;
        if (width <= 749) return 1;
        if (width <= 989) return 2;
        return 4;
      }

      prevSlide() {
        const cardsPerView = this.getCardsPerView();
        this.currentIndex = Math.max(0, this.currentIndex - 1);
        this.updateSlider();
      }

      nextSlide() {
        const cardsPerView = this.getCardsPerView();
        const maxIndex = Math.max(0, this.totalCards - cardsPerView);
        this.currentIndex = Math.min(maxIndex, this.currentIndex + 1);
        this.updateSlider();
      }

      updateSlider() {
        const cardsPerView = this.getCardsPerView();
        const cardWidth = this.cards[0].offsetWidth;
        const gap = {{ block.settings.card_gap }};
        const offset = this.currentIndex * (cardWidth + gap);
        this.slider.style.transform = `translateX(-${offset}px)`;

        this.prevButton.disabled = this.currentIndex === 0;
        this.nextButton.disabled = this.currentIndex >= this.totalCards - cardsPerView;

        this.prevButton.style.opacity = this.prevButton.disabled ? '0.5' : '1';
        this.nextButton.style.opacity = this.nextButton.disabled ? '0.5' : '1';
        this.prevButton.style.cursor = this.prevButton.disabled ? 'not-allowed' : 'pointer';
        this.nextButton.style.cursor = this.nextButton.disabled ? 'not-allowed' : 'pointer';
      }
    }

    customElements.define('astrology-services-{{ ai_gen_id }}', AstrologyServices{{ ai_gen_id }});
  })();
</script>

