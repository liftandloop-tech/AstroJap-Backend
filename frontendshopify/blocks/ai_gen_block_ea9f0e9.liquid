{% doc %}
  @prompt
    🚨 IMPORTANT (STRICT INSTRUCTION)
    
    DO NOT create a basic banner.
    DO NOT create a simple text block.
    
    Create a premium hero section with strong visual impact, similar to modern ecommerce landing pages.
    
    🧾 HERO CONTENT
    Main Heading:
    
    Real Stories. Real Results.
    
    Subheading:
    
    Hear what our customers say about their experience with Astrojap and how our products transformed their lives.
    
    🧱 LAYOUT (MANDATORY)
    
    Full width section
    
    Height: 70vh – 90vh (hero style)
    
    Content aligned:
    
    Center OR left (configurable)
    
    Include:
    
    Background image OR gradient
    
    Text overlay
    
    Optional CTA button
    
    🎨 DESIGN STYLE
    
    Premium astrology feel
    
    Slight dark overlay on background image
    
    Clean typography
    
    Large heading (40–60px)
    
    Subheading smaller (16–20px)
    
    🔘 CTA BUTTON (OPTIONAL)
    
    Button text:
    
    Watch Customer Stories
    
    Button style:
    
    Rounded
    
    Dark background (#000 or deep maroon)
    
    White text
    
    ⚙️ FULLY EDITABLE (VERY IMPORTANT)
    
    All elements must be editable from Shopify customizer:
    
    Background image
    
    Heading text
    
    Subheading text
    
    Button text
    
    Button link
    
    Content alignment (left/center)
    
    Overlay opacity
    
    Section height
    
    📱 RESPONSIVE BEHAVIOR
    
    Maintain hero height on mobile (auto adjust)
    
    Center align text on mobile
    
    Proper spacing and font scaling
    
    ⚙️ TECHNICAL REQUIREMENTS
    
    Use Shopify Liquid + section schema
    
    Add settings for:
    
    Image picker
    
    Text fields
    
    Range sliders (height, overlay opacity)
    
    Use CSS:
    
    background-size: cover
    
    background-position: center
    
    🚀 GOAL
    
    Create a high-impact testimonial page hero section that:
    
    Builds trust
    
    Sets emotional tone
    
    Encourages users to explore testimonials
    
    ❗ FINAL INSTRUCTION
    
    Focus on:
    
    Strong visual hierarchy
    
    Clean spacing
    
    Premium look
    
    Do NOT make it look basic.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-testimonial-hero-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    min-height: {{ block.settings.hero_height }}vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background-color: #1a1a2e;
  }

  .ai-testimonial-hero-background-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .ai-testimonial-hero-background-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .ai-testimonial-hero-background-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-testimonial-hero-background-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 800px;
    max-height: 600px;
    opacity: 0.1;
  }

  .ai-testimonial-hero-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: {% if block.settings.use_gradient %}linear-gradient(135deg, rgba(26, 26, 46, {{ block.settings.overlay_opacity }}) 0%, rgba(22, 33, 62, {{ block.settings.overlay_opacity | times: 0.9 }}) 50%, rgba(15, 52, 96, {{ block.settings.overlay_opacity | times: 0.8 }}) 100%){% else %}rgba(0, 0, 0, {{ block.settings.overlay_opacity }}){% endif %};
    z-index: 2;
  }

  .ai-testimonial-hero-content-{{ ai_gen_id }} {
    position: relative;
    z-index: 3;
    max-width: 1200px;
    width: 100%;
    padding: 60px 40px;
    text-align: {{ block.settings.content_alignment }};
  }

  .ai-testimonial-hero-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 700;
    color: {{ block.settings.heading_color }};
    margin: 0 0 24px;
    line-height: 1.2;
    letter-spacing: -0.02em;
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.3);
  }

  .ai-testimonial-hero-subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    font-weight: 400;
    color: {{ block.settings.subheading_color }};
    margin: 0 0 40px;
    line-height: 1.6;
    max-width: 800px;
    {% if block.settings.content_alignment == 'center' %}
      margin-left: auto;
      margin-right: auto;
    {% endif %}
    opacity: 0.95;
  }

  .ai-testimonial-hero-cta-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 16px 36px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 600;
    transition: all 0.3s ease;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
    border: 2px solid transparent;
  }

  .ai-testimonial-hero-cta-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
    transform: translateY(-2px);
    box-shadow: 0 6px 30px rgba(0, 0, 0, 0.3);
    border-color: {{ block.settings.button_hover_text_color }};
  }

  .ai-testimonial-hero-cta-icon-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
    transition: transform 0.3s ease;
  }

  .ai-testimonial-hero-cta-{{ ai_gen_id }}:hover .ai-testimonial-hero-cta-icon-{{ ai_gen_id }} {
    transform: translateX(4px);
  }

  .ai-testimonial-hero-accent-{{ ai_gen_id }} {
    position: absolute;
    width: 300px;
    height: 300px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255, 215, 0, 0.15) 0%, transparent 70%);
    pointer-events: none;
    z-index: 2;
  }

  .ai-testimonial-hero-accent-{{ ai_gen_id }}--top-left {
    top: -150px;
    left: -150px;
  }

  .ai-testimonial-hero-accent-{{ ai_gen_id }}--bottom-right {
    bottom: -150px;
    right: -150px;
  }

  @media screen and (max-width: 989px) {
    .ai-testimonial-hero-{{ ai_gen_id }} {
      min-height: {{ block.settings.hero_height | times: 0.8 }}vh;
    }

    .ai-testimonial-hero-content-{{ ai_gen_id }} {
      padding: 40px 24px;
      text-align: center;
    }

    .ai-testimonial-hero-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.6 }}px;
      margin-bottom: 16px;
    }

    .ai-testimonial-hero-subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size | times: 0.9 }}px;
      margin-bottom: 32px;
      margin-left: auto;
      margin-right: auto;
    }

    .ai-testimonial-hero-cta-{{ ai_gen_id }} {
      padding: 14px 28px;
      font-size: {{ block.settings.button_font_size | times: 0.9 }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-testimonial-hero-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.5 }}px;
    }

    .ai-testimonial-hero-subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<div class="ai-testimonial-hero-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-testimonial-hero-background-{{ ai_gen_id }}">
    {% if block.settings.background_image %}
      <img
        src="{{ block.settings.background_image | image_url: width: 2400 }}"
        alt="{{ block.settings.background_image.alt | escape }}"
        loading="eager"
        width="{{ block.settings.background_image.width }}"
        height="{{ block.settings.background_image.height }}"
      >
    {% else %}
      <div class="ai-testimonial-hero-background-placeholder-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
      </div>
    {% endif %}
  </div>

  <div class="ai-testimonial-hero-overlay-{{ ai_gen_id }}"></div>

  {% if block.settings.show_accents %}
    <div class="ai-testimonial-hero-accent-{{ ai_gen_id }} ai-testimonial-hero-accent-{{ ai_gen_id }}--top-left"></div>
    <div class="ai-testimonial-hero-accent-{{ ai_gen_id }} ai-testimonial-hero-accent-{{ ai_gen_id }}--bottom-right"></div>
  {% endif %}

  <div class="ai-testimonial-hero-content-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h1 class="ai-testimonial-hero-heading-{{ ai_gen_id }}">
        {{ block.settings.heading }}
      </h1>
    {% endif %}

    {% if block.settings.subheading != blank %}
      <div class="ai-testimonial-hero-subheading-{{ ai_gen_id }}">
        {{ block.settings.subheading }}
      </div>
    {% endif %}

    {% if block.settings.show_cta and block.settings.button_text != blank %}
      <a
        href="{{ block.settings.button_link }}"
        class="ai-testimonial-hero-cta-{{ ai_gen_id }}"
      >
        {{ block.settings.button_text }}
        <svg
          class="ai-testimonial-hero-cta-icon-{{ ai_gen_id }}"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Testimonial hero",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Real Stories. Real Results.</p>"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheading",
      "default": "<p>Hear what our customers say about their experience with Astrojap and how our products transformed their lives.</p>"
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Content alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "checkbox",
      "id": "use_gradient",
      "label": "Use gradient overlay",
      "default": true
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "default": 0.7
    },
    {
      "type": "checkbox",
      "id": "show_accents",
      "label": "Show decorative accents",
      "default": true
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "hero_height",
      "label": "Section height",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "default": 80
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 30,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 56
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "subheading_size",
      "label": "Subheading size",
      "min": 14,
      "max": 28,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading color",
      "default": "#e0e0e0"
    },
    {
      "type": "header",
      "content": "Call to action button"
    },
    {
      "type": "checkbox",
      "id": "show_cta",
      "label": "Show button",
      "default": true
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Watch Customer Stories"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "range",
      "id": "button_font_size",
      "label": "Button font size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "button_radius",
      "label": "Button border radius",
      "min": 0,
      "max": 50,
      "step": 2,
      "unit": "px",
      "default": 30
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Button background",
      "default": "#8B0000"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_bg_color",
      "label": "Hover background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_hover_text_color",
      "label": "Hover text",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Testimonial hero"
    }
  ]
}
{% endschema %}
