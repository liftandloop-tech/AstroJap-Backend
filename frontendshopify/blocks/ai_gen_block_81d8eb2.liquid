    { "type": "image_picker", "id": "slide_2_image", "label": "Image" },
    { "type": "text", "id": "slide_2_badge", "label": "Badge text", "default": "Sacred Energy" },
    { "type": "text", "id": "slide_2_heading", "label": "Heading", "default": "RUDRAKSHA" },
    { "type": "text", "id": "slide_2_subheading", "label": "Subheading", "default": "Authentic Rudraksha Collection" },
    { "type": "richtext", "id": "slide_2_description", "label": "Description", "default": "<p>Experience Divine Protection & Spiritual Growth</p>" },
    { "type": "text", "id": "slide_2_button_text", "label": "Button text", "default": "SHOP NOW" },
