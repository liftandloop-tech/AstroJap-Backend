{% doc %}
  @prompt
    Create a Shopify section using Liquid + CSS for a responsive feature cards section (like homepage quick actions).
    
    Design Requirements:
    
    1. Layout:
    - 4 cards in a row on desktop
    - 4cards per row on tablet
    - 4card per row on mobile
    - Equal spacing between cards
    - Center aligned layout
    
    2. Card Design:
    - Rounded card (border-radius: 16px–24px)
    - Light background (#f5f5f5 or white)
    - Soft shadow (premium look)
    - Padding: 30px–40px
    - Hover effect (slight lift + shadow)
    
    3. Icon/Image:
    - Each card should have a circular icon container
    - Circle size: 80px–120px
    - Background color customizable per card
    - Image inside circle must:
      - Fully fit inside circle
      - Maintain aspect ratio
      - Use object-fit: cover
      - Center aligned
    - No image stretching or cropping issues
    
    4. Content:
    - Title below icon
    - Bold and centered text
    - Optional subtitle (if needed)
    
    5. Shopify Functionality:
    - Use section blocks for each card
    - Each block should include:
      - Image picker
      - Title text
      - Background color (for circle)
      - Link (optional)
    
    6. Responsiveness:
    - Fully responsive for mobile/tablet
    - Image and circle scale properly
    - Text remains centered
    
    7. Technical:
    - Use flexbox or grid
    - Ensure images use:
      object-fit: cover;
      width: 100%;
      height: 100%;
    - Circle container must have:
      overflow: hidden;
      border-radius: 50%;
    
    8. Output:
    - Provide full Shopify section code
    - Include:
      - Liquid loop (for blocks)
      - CSS styling
      - Schema JSON
    
    Goal:
    Create a clean, modern, premium card section similar to Astrotalk homepage where icons are perfectly centered and responsive without image distortion., make it mobile responsive , i need in one colomb , 4card per row on mobile , it is overflowing , give margin both side 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-feature-cards-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding_top }}px {{ block.settings.section_padding_left }}px {{ block.settings.section_padding_bottom }}px {{ block.settings.section_padding_right }}px;
    background-color: {{ block.settings.section_background }};
    overflow-x: hidden;
  }

  .ai-feature-cards-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
  }

  .ai-feature-cards-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: {{ block.settings.card_spacing }}px;
    width: 100%;
  }

  .ai-feature-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    text-align: center;
    transition: all 0.3s ease;
    box-shadow: {{ block.settings.card_shadow_horizontal }}px {{ block.settings.card_shadow_vertical }}px {{ block.settings.card_shadow_blur }}px rgba(0, 0, 0, {{ block.settings.card_shadow_opacity }});
    display: flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    color: inherit;
    min-width: 0;
  }

  .ai-feature-card-{{ ai_gen_id }}:hover {
    transform: translateY({{ block.settings.hover_lift }}px);
    box-shadow: {{ block.settings.hover_shadow_horizontal }}px {{ block.settings.hover_shadow_vertical }}px {{ block.settings.hover_shadow_blur }}px rgba(0, 0, 0, {{ block.settings.hover_shadow_opacity }});
  }

  .ai-feature-card-icon-wrapper-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    border-radius: 50%;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: {{ block.settings.icon_spacing }}px;
    flex-shrink: 0;
  }

  .ai-feature-card-icon-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-feature-card-icon-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-feature-card-icon-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
  }

  .ai-feature-card-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_font_size }}px;
    font-weight: {{ block.settings.title_font_weight }};
    color: {{ block.settings.title_color }};
    margin: 0;
    line-height: 1.3;
    word-wrap: break-word;
    overflow-wrap: break-word;
  }

  .ai-feature-card-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_font_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: {{ block.settings.subtitle_spacing }}px 0 0;
    line-height: 1.4;
    word-wrap: break-word;
    overflow-wrap: break-word;
  }

  @media screen and (max-width: 989px) {
    .ai-feature-cards-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top_mobile }}px {{ block.settings.section_padding_left_mobile }}px {{ block.settings.section_padding_bottom_mobile }}px {{ block.settings.section_padding_right_mobile }}px;
    }

    .ai-feature-cards-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(4, 1fr);
      gap: {{ block.settings.card_spacing_tablet }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-feature-cards-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top_mobile }}px {{ block.settings.section_padding_left_mobile }}px {{ block.settings.section_padding_bottom_mobile }}px {{ block.settings.section_padding_right_mobile }}px;
    }

    .ai-feature-cards-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(4, 1fr);
      gap: {{ block.settings.card_spacing_mobile }}px;
    }

    .ai-feature-card-{{ ai_gen_id }} {
      padding: {{ block.settings.card_padding_mobile }}px;
      border-radius: {{ block.settings.card_border_radius_mobile }}px;
    }

    .ai-feature-card-icon-wrapper-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size_mobile }}px;
      height: {{ block.settings.icon_size_mobile }}px;
      margin-bottom: {{ block.settings.icon_spacing_mobile }}px;
    }

    .ai-feature-card-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_font_size_mobile }}px;
    }

    .ai-feature-card-subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtitle_font_size_mobile }}px;
    }
  }
{% endstyle %}

<feature-cards-{{ ai_gen_id }} class="ai-feature-cards-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-feature-cards-container-{{ ai_gen_id }}">
    <div class="ai-feature-cards-grid-{{ ai_gen_id }}">
      {% for i in (1..4) %}
        {% liquid
          assign image_key = 'card_' | append: i | append: '_image'
          assign title_key = 'card_' | append: i | append: '_title'
          assign subtitle_key = 'card_' | append: i | append: '_subtitle'
          assign link_key = 'card_' | append: i | append: '_link'
          assign bg_key = 'card_' | append: i | append: '_icon_bg'

          assign card_image = block.settings[image_key]
          assign card_title = block.settings[title_key]
          assign card_subtitle = block.settings[subtitle_key]
          assign card_link = block.settings[link_key]
          assign icon_bg = block.settings[bg_key]
        %}

        {% if card_link != blank %}
          <a href="{{ card_link }}" class="ai-feature-card-{{ ai_gen_id }}">
        {% else %}
          <div class="ai-feature-card-{{ ai_gen_id }}">
        {% endif %}
          <div 
            class="ai-feature-card-icon-wrapper-{{ ai_gen_id }}"
            style="background-color: {{ icon_bg }};"
          >
            {% if card_image %}
              <img
                src="{{ card_image | image_url: width: 300 }}"
                alt="{{ card_image.alt | escape }}"
                class="ai-feature-card-icon-{{ ai_gen_id }}"
                loading="lazy"
                width="300"
                height="300"
              >
            {% else %}
              <div class="ai-feature-card-icon-placeholder-{{ ai_gen_id }}" style="background-color: {{ icon_bg }};">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>

          {% if card_title != blank %}
            <h3 class="ai-feature-card-title-{{ ai_gen_id }}">
              {{ card_title }}
            </h3>
          {% endif %}

          {% if card_subtitle != blank %}
            <p class="ai-feature-card-subtitle-{{ ai_gen_id }}">
              {{ card_subtitle }}
            </p>
          {% endif %}

        {% if card_link != blank %}
          </a>
        {% else %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</feature-cards-{{ ai_gen_id }}>

<script>
  (function() {
    class FeatureCards{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.cards = this.querySelectorAll('.ai-feature-card-{{ ai_gen_id }}');
      }
    }

    customElements.define('feature-cards-{{ ai_gen_id }}', FeatureCards{{ ai_gen_id }});
  })();
</script>

