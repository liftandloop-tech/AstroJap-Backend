{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-cg-section-{{ ai_gen_id }} {
    width: 100%;
    background-color: {{ block.settings.section_bg }};
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
    position: -webkit-sticky;
    position: sticky;
    top: var(--header-height, 0px);
    z-index: 999;
  }

  .ai-cg-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding: 00px;
  }

  .ai-cg-items-{{ ai_gen_id }} {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    gap: 15px;
    padding: 10px 20px 20px 20px;
    scrollbar-width: none; /* Hide scrollbar Firefox */
    -ms-overflow-style: none;  /* Hide scrollbar IE/Edge */
    -webkit-overflow-scrolling: touch;
  }

  .ai-cg-items-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none; /* Hide scrollbar Chrome/Safari */
  }

  .ai-cg-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    width: calc({{ block.settings.image_size_mobile }}px + 20px);
    flex-shrink: 0;
    scroll-snap-align: start;
    transition: transform 0.3s ease;
  }

  .ai-cg-item-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
  }

  @media (min-width: 768px) {
    .ai-cg-items-{{ ai_gen_id }} {
      gap: 30px;
      justify-content: flex-start;
      padding: 10px 0 20px 0;
    }
    .ai-cg-item-{{ ai_gen_id }} {
      width: calc({{ block.settings.image_size_desktop }}px + 30px);
    }
  }

  .ai-cg-image-wrap-{{ ai_gen_id }} {
    width: {{ block.settings.image_size_mobile }}px;
    height: {{ block.settings.image_size_mobile }}px;
    background-color: {{ block.settings.icon_bg }};
    border-radius: 50%;
    display: flex;
    justify-content: center;
    align-items: center;
    overflow: hidden;
    margin: 0 auto;
    flex-shrink: 0;
    border: 1px solid #f0f0f0;
    box-shadow: 0 4px 10px rgba(0,0,0,0.05);
  }

  @media (min-width: 768px) {
    .ai-cg-image-wrap-{{ ai_gen_id }} {
      width: {{ block.settings.image_size_desktop }}px;
      height: {{ block.settings.image_size_desktop }}px;
    }
  }

  .ai-cg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-cg-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: transparent;
    border-radius: 50%;
  }

  .ai-cg-label-{{ ai_gen_id }} {
    margin-top: 12px;
    font-size: 13px;
    color: {{ block.settings.text_color }};
    text-align: center;
    line-height: 1.3;
    font-weight: 700;
    white-space: nowrap;
  }

  @media (min-width: 768px) {
    .ai-cg-label-{{ ai_gen_id }} {
      font-size: 14px;
    }
  }
{% endstyle %}

<div class="ai-cg-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-cg-container-{{ ai_gen_id }}">
    
    <div class="ai-cg-items-{{ ai_gen_id }}" id="CategoryList-{{ ai_gen_id }}">
      {% for i in (1..26) %}
        {% assign enabled_key = 'category_' | append: i | append: '_enabled' %}
        {% assign image_key = 'category_' | append: i | append: '_image' %}
        {% assign label_key = 'category_' | append: i | append: '_label' %}
        {% assign link_key = 'category_' | append: i | append: '_link' %}

        {% assign is_enabled = block.settings[enabled_key] %}
        {% assign category_image = block.settings[image_key] %}
        {% assign category_label = block.settings[label_key] %}
        {% assign category_link = block.settings[link_key] %}

        {% if is_enabled %}
          <a href="{{ category_link | default: '#' }}" class="ai-cg-item-{{ ai_gen_id }}">
            <div class="ai-cg-image-wrap-{{ ai_gen_id }}">
              {% if category_image %}
                <img src="{{ category_image | image_url: width: 300 }}" alt="{{ category_label | escape }}" class="ai-cg-img" loading="lazy">
              {% else %}
                <div class="ai-cg-placeholder-{{ ai_gen_id }}">
                  {{ 'product-1' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>
            <div class="ai-cg-label-{{ ai_gen_id }}">
              {% if category_label != blank %}{{ category_label }}{% endif %}
            </div>
          </a>
        {% endif %}
      {% endfor %}
    </div>

  </div>
</div>

