{% assign id = block.id | default: section.id | replace: '_', '' | downcase %}
{% assign c_bg = block.settings.bg_color | default: section.settings.bg_color | default: '#ffffff' %}
{% assign c_ln = block.settings.line_color | default: section.settings.line_color | default: '#d32f2f' %}
{% assign c_tx = block.settings.text_color | default: section.settings.text_color | default: '#333333' %}
{% assign c_btn = block.settings.btn_bg | default: section.settings.btn_bg | default: '#d32f2f' %}

{% style %}
.ak-{{ id }}{width:100%;padding:60px 20px;background:{{ c_bg }};font-family:inherit;color:{{ c_tx }};}
.ak-wrap-{{ id }}{max-width:1200px;margin:0 auto;display:flex;align-items:flex-start;gap:60px;}
.ak-left-{{ id }}{flex:1.1;} .ak-right-{{ id }}{flex:1.3; display:flex; flex-direction:column; gap:30px;}
.ak-tt-{{ id }}{font-size:38px;color:{{ c_tx }};margin:0 0 10px;font-weight:800;line-height:1.2;}
.ak-sb-{{ id }}{font-size:16px;color:#555;margin:0 0 30px;line-height:1.5;}

.ak-card-{{ id }}{background:#f9f9f9;border:1px solid #eee;border-radius:12px;padding:30px;box-shadow:0 10px 30px rgba(0,0,0,0.03);}
.ak-grid-{{ id }}{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:25px;}
.ak-in-{{ id }}{display:flex;flex-direction:column;position:relative;}
.ak-in-{{ id }} label{font-size:13px;color:#666;margin-bottom:8px;text-transform:uppercase;font-weight:700;letter-spacing:0.5px;}
.ak-in-{{ id }} input{width:100%;padding:14px;background:#fff;border:1px solid #ddd;color:#333;font-size:15px;border-radius:6px;transition:all 0.3s;}
.ak-in-{{ id }} input:focus{outline:none;border-color:{{ c_ln }};box-shadow:0 0 0 3px rgba(211,47,47,0.1);}

.ak-drop-{{ id }}{position:absolute;top:100%;left:0;width:100%;background:#ffffff;border:1px solid #ddd;border-radius:6px;box-shadow:0 10px 25px rgba(0,0,0,0.1);z-index:100;list-style:none;padding:0;margin:4px 0 0;max-height:220px;overflow-y:auto;display:none;}
.ak-drop-{{ id }} li{padding:12px 16px;cursor:pointer;border-bottom:1px solid #f0f0f0;font-size:15px;color:#444;}
.ak-drop-{{ id }} li:last-child{border-bottom:none;}
.ak-drop-{{ id }} li:hover{background-color:rgba(211,47,47,0.05);color:{{ c_ln }};font-weight:600;}

.ak-btn-{{ id }}{width:100%;padding:18px;background:{{ c_btn }};color:#fff;border:none;border-radius:6px;font-size:16px;font-weight:700;text-transform:uppercase;cursor:pointer;transition:transform 0.2s;}
.ak-btn-{{ id }}:hover{transform:translateY(-2px);box-shadow:0 5px 15px rgba(211,47,47,0.3);}
.ak-btn-{{ id }}:disabled{opacity:0.7;cursor:not-allowed;}

.ak-chart-box-{{ id }}{background:#fff;border:1px solid #eee;border-radius:12px;padding:20px;box-shadow:0 10px 30px rgba(0,0,0,0.03);}
.ak-svg-{{ id }}{width:100%;max-width:450px;display:block;margin:0 auto;}
/* Modified original layout style with bold Hindi styling */
.ak-svg-{{ id }} text{dominant-baseline:middle;text-anchor:middle;font-family:sans-serif;}
.ak-svg-{{ id }} .sn{font-size:14px;fill:{{ c_ln }};font-weight:bold;}
.ak-svg-{{ id }} .pn{font-size:14px;fill:#444;font-weight:800;letter-spacing:1px;} 

.ak-panel-{{ id }}{background:#fff;border:1px solid #eee;border-left:4px solid {{ c_ln }};border-radius:8px;padding:25px;box-shadow:0 5px 20px rgba(0,0,0,0.04);display:none;}
.ak-panel-tt-{{ id }}{font-size:20px;margin:0 0:15px;font-weight:700;}
.ak-panel-grid-{{ id }}{display:grid;grid-template-columns:1fr 1fr;gap:15px;font-size:15px;}
.ak-p-item-{{ id }} b{color:#222;}
.ak-p-item-{{ id }} span{color:#666;float:right;font-weight:600;}

.ak-download-{{ id }}{margin-top:20px;width:100%;padding:14px;background:#fff;color:{{ c_ln }};border:2px solid {{ c_ln }};border-radius:6px;font-size:14px;font-weight:700;text-transform:uppercase;cursor:pointer;transition:0.3s;display:none;align-items:center;justify-content:center;gap:8px;}
.ak-download-{{ id }}:hover{background:{{ c_ln }};color:#fff;}

@media(max-width:850px){
  .ak-{{ id }}{padding:40px 15px;}
  .ak-wrap-{{ id }}{flex-direction:column; gap:40px;}
  .ak-left-{{ id }}, .ak-right-{{ id }}{width:100%; box-sizing:border-box;}
  .ak-grid-{{ id }}{grid-template-columns:1fr; gap:15px;}
  .ak-tt-{{ id }}{font-size:28px;}
  .ak-sb-{{ id }}{font-size:15px; margin-bottom: 20px;}
  .ak-card-{{ id }}{padding:20px;}
  .ak-btn-{{ id }}{padding:16px; font-size:15px;}
  .ak-panel-grid-{{ id }}{grid-template-columns:1fr; gap:10px;}
  .ak-svg-{{ id }} .sn{font-size:16px;}
  .ak-svg-{{ id }} .pn{font-size:13px;}
}
{% endstyle %}

<div class="ak-{{ id }}">
  <div class="ak-wrap-{{ id }}">
    
    <div class="ak-left-{{ id }}">
      <h2 class="ak-tt-{{ id }}">{{ section.settings.heading | default: "Discover Your Path" }}</h2>
      <p class="ak-sb-{{ id }}">{{ section.settings.subheading | default: "Enter your birth details accurately to cast your exact planetary alignments and cosmic analysis." }}</p>
      
      <div class="ak-card-{{ id }}">
        <form id="f-{{ id }}" autocomplete="off">
          <div class="ak-grid-{{ id }}">
            <div class="ak-in-{{ id }}" style="grid-column:1/-1;">
              <label>Full Name</label>
              <input type="text" id="n-{{ id }}" placeholder="E.g. Raj" required>
            </div>
            
            <div class="ak-in-{{ id }}">
              <label>Date of Birth</label>
              <input type="date" id="d-{{ id }}" required>
            </div>
            
            <div class="ak-in-{{ id }}">
              <label>Time of Birth</label>
              <input type="time" id="t-{{ id }}" required>
            </div>
            
            <div class="ak-in-{{ id }}" style="grid-column:1/-1;">
              <label>Birth Place</label>
              <input type="text" id="search-{{ id }}" placeholder="Type your city (e.g., Mumbai)..." required>
              <ul id="drop-{{ id }}" class="ak-drop-{{ id }}"></ul>
              
              <input type="hidden" id="lat-{{ id }}">
              <input type="hidden" id="lon-{{ id }}">
              <input type="hidden" id="tzid-{{ id }}">
            </div>
          </div>
          
          <button type="submit" class="ak-btn-{{ id }}" id="b-{{ id }}">अपनी कुंडली बनाएं (Generate)</button>
          <div id="m-{{ id }}" style="color:#d32f2f;margin-top:15px;display:none;font-size:14px;font-weight:600;"></div>
        </form>
      </div>
    </div>

    <!-- Original SVG layout -->
    <div class="ak-right-{{ id }}">
      <div class="ak-chart-box-{{ id }}">
        <svg id="svg-{{ id }}" class="ak-svg-{{ id }}" viewBox="0 0 400 400" xmlns="http://www.w3.org/2000/svg">
          <rect x="0" y="0" width="400" height="400" fill="#ffffff" stroke="{{ c_ln }}" stroke-width="2"/>
          <line x1="0" y1="0" x2="400" y2="400" stroke="{{ c_ln }}" stroke-width="1.5"/>
          <line x1="400" y1="0" x2="0" y2="400" stroke="{{ c_ln }}" stroke-width="1.5"/>
          <polygon points="200,0 400,200 200,400 0,200" fill="none" stroke="{{ c_ln }}" stroke-width="1.5"/>
          
          <g data-h="1"><text x="200" y="75" class="sn"></text><text x="200" y="115" class="pn"></text></g>
          <g data-h="2"><text x="100" y="20" class="sn"></text><text x="100" y="45" class="pn"></text></g>
          <g data-h="3"><text x="33" y="85" class="sn"></text><text x="33" y="115" class="pn"></text></g>
          <g data-h="4"><text x="100" y="175" class="sn"></text><text x="100" y="215" class="pn"></text></g>
          <g data-h="5"><text x="33" y="285" class="sn"></text><text x="33" y="315" class="pn"></text></g>
          <g data-h="6"><text x="100" y="350" class="sn"></text><text x="100" y="380" class="pn"></text></g>
          <g data-h="7"><text x="200" y="275" class="sn"></text><text x="200" y="315" class="pn"></text></g>
          <g data-h="8"><text x="300" y="350" class="sn"></text><text x="300" y="380" class="pn"></text></g>
          <g data-h="9"><text x="366" y="285" class="sn"></text><text x="366" y="315" class="pn"></text></g>
          <g data-h="10"><text x="300" y="175" class="sn"></text><text x="300" y="215" class="pn"></text></g>
          <g data-h="11"><text x="366" y="85" class="sn"></text><text x="366" y="115" class="pn"></text></g>
          <g data-h="12"><text x="300" y="20" class="sn"></text><text x="300" y="45" class="pn"></text></g>
        </svg>
      </div>

      <div id="panel-{{ id }}" class="ak-panel-{{ id }}">
        <h3 class="ak-panel-tt-{{ id }}">ज्योतिषीय सारांश (Summary)</h3>
        <p style="margin-top:0; margin-bottom: 20px; font-size:14px; color:#666;">के लिए: <b id="p-name-{{ id }}"></b></p>
        
        <div class="ak-panel-grid-{{ id }}">
          <div style="grid-column: 1 / -1; margin-bottom: 5px; border-bottom: 1px solid #eee; padding-bottom: 5px; font-weight: 700; color: {{ c_ln }}; text-transform: uppercase;">मूल स्तंभ (Core Pillars)</div>
          <div class="ak-p-item-{{ id }}"><b>लग्न (Lagna)</b> <span id="p-lagna-{{ id }}">-</span></div>
          <div class="ak-p-item-{{ id }}"><b>लग्नेश (Lagna Lord)</b> <span id="p-lagna-lord-{{ id }}">-</span></div>
          <div class="ak-p-item-{{ id }}"><b>चंद्र राशि (Moon Sign)</b> <span id="p-moon-{{ id }}">-</span></div>
          <div class="ak-p-item-{{ id }}"><b>सूर्य राशि (Sun Sign)</b> <span id="p-sun-{{ id }}">-</span></div>
        </div>

        <button type="button" id="dl-{{ id }}" class="ak-download-{{ id }}" style="display:flex;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"/></svg>
           डाउनलोड कुंडली (Download Chart)
        </button>
      </div>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const f = document.getElementById('f-{{ id }}');
  const searchInput = document.getElementById('search-{{ id }}');
  const dropList = document.getElementById('drop-{{ id }}');
  const msgBlock = document.getElementById('m-{{ id }}');
  const btn = document.getElementById('b-{{ id }}');
  const panel = document.getElementById('panel-{{ id }}');
  const dlBtn = document.getElementById('dl-{{ id }}');
  
  const hLat = document.getElementById('lat-{{ id }}');
  const hLon = document.getElementById('lon-{{ id }}');
  const hTz = document.getElementById('tzid-{{ id }}');
  
  const BACKEND_URL = 'https://kundli-api-1.vercel.app/api/kundli';

  const hindiPlanets = { "Su":"सू","Mo":"चं","Ma":"मं","Me":"बु","Ju":"गु","Ve":"शु","Sa":"श","Ra":"रा","Ke":"के","Ur":"यू","Ne":"ने","Pl":"प्लू" };
  const hindiSignsFull = { "Aries":"मेष","Taurus":"वृषभ","Gemini":"मिथुन","Cancer":"कर्क","Leo":"सिंह","Virgo":"कन्या","Libra":"तुला","Scorpio":"वृश्चिक","Sagittarius":"धनु","Capricorn":"मकर","Aquarius":"कुंभ","Pisces":"मीन" };
  const hindiLordsFull = { "Aries":"मंगल","Taurus":"शुक्र","Gemini":"बुध","Cancer":"चंद्र","Leo":"सूर्य","Virgo":"बुध","Libra":"शुक्र","Scorpio":"मंगल","Sagittarius":"गुरु","Capricorn":"शनि","Aquarius":"शनि","Pisces":"गुरु" };

  if(!f) return;

  searchInput.addEventListener('input', (e) => {
    let val = e.target.value.trim();
    if(val.length < 3) { dropList.style.display = 'none'; return; }
    setTimeout(async () => {
      try {
        let res = await fetch(BACKEND_URL, { method: 'POST', headers: { 'Content-Type':'application/json' }, body: JSON.stringify({ action:'geo', payload:{ place: val, maxRows:"5" } }) });
        let data = await res.json();
        dropList.innerHTML = '';
        if(data.geonames) {
          data.geonames.forEach(geo => {
            let li = document.createElement('li');
            li.textContent = `${geo.place_name}, ${geo.country_code}`;
            li.onclick = () => { searchInput.value = li.textContent; hLat.value = geo.latitude; hLon.value = geo.longitude; hTz.value = geo.timezone_id; dropList.style.display = 'none'; };
            dropList.appendChild(li);
          });
          dropList.style.display = 'block';
        }
      } catch(e){}
    }, 500);
  });

  f.addEventListener('submit', async(e) => {
    e.preventDefault(); msgBlock.style.display = 'none'; panel.style.display = 'none';
    btn.textContent = 'Calculating Stars...'; btn.disabled = true;
    try {
      let ds = document.getElementById('d-{{ id }}').value.split('-');
      let ts = document.getElementById('t-{{ id }}').value.split(':');
      let res = await fetch(BACKEND_URL, {
        method:'POST', headers:{'Content-Type':'application/json'},
        body: JSON.stringify({ action:'chart', payload: { day:parseInt(ds[2]), month:parseInt(ds[1]), year:parseInt(ds[0]), hour:parseInt(ts[0]), min:parseInt(ts[1]), lat:parseFloat(hLat.value), lon:parseFloat(hLon.value), tzone:5.5 } })
      });
      let data = await res.json();
      if(Array.isArray(data)) {
        data.forEach((h, i) => {
          let g = document.querySelector(`#svg-{{ id }} g[data-h="${i+1}"]`);
          if(g) {
            g.querySelector('.sn').textContent = h.sign;
            let trans = (h.planet_small || []).map(p => hindiPlanets[p.trim()] || p);
            g.querySelector('.pn').textContent = trans.join(', ');
          }
          if(i === 0) {
            document.getElementById('p-lagna-{{ id }}').textContent = hindiSignsFull[h.sign_name] || h.sign_name;
            document.getElementById('p-lagna-lord-{{ id }}').textContent = hindiLordsFull[h.sign_name] || "-";
          }
           if (h.planet && h.planet.length > 0) {
            if (h.planet.includes("SUN")) document.getElementById('p-sun-{{ id }}').textContent = hindiSignsFull[h.sign_name] || h.sign_name;
            if (h.planet.includes("MOON")) document.getElementById('p-moon-{{ id }}').textContent = hindiSignsFull[h.sign_name] || h.sign_name;
          }
        });
        document.getElementById('p-name-{{ id }}').textContent = document.getElementById('n-{{ id }}').value;
        panel.style.display = 'block';
      }
    } catch(err) { msgBlock.textContent = "Calculation error. Please check Birth Place."; msgBlock.style.display = 'block'; }
    btn.textContent = 'अपनी कुंडली बनाएं (Generate)'; btn.disabled = false;
  });

  // HIGH PERF SVG TO IMAGE LOGIC
  dlBtn.addEventListener('click', () => {
    const svg = document.getElementById('svg-{{ id }}');
    const xml = new XMLSerializer().serializeToString(svg);
    const svg64 = btoa(unescape(encodeURIComponent(xml)));
    const b64Start = 'data:image/svg+xml;base64,';
    const image64 = b64Start + svg64;
    
    const canvas = document.createElement('canvas');
    canvas.width = 800; canvas.height = 800;
    const ctx = canvas.getContext('2d');
    const img = new Image();
    img.src = image64;
    img.onload = () => {
      ctx.fillStyle = "#ffffff"; ctx.fillRect(0,0,800,800);
      ctx.drawImage(img, 0, 0, 800, 800);
      const link = document.createElement('a');
      link.download = `Astrojap_Kundli_${document.getElementById('n-{{ id }}').value}.png`;
      link.href = canvas.toDataURL('image/png');
      link.click();
    };
  });
});
</script>

{% schema %}
{
  "name": "Downloadable Kundli",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#ffffff" },
    { "type": "color", "id": "line_color", "label": "Line Color", "default": "#d32f2f" },
    { "type": "color", "id": "btn_bg", "label": "Button Color", "default": "#d32f2f" }
  ],
  "presets": [{"name": "Downloadable Kundli"}]
}
{% endschema %}
