{% doc %}
  @prompt
          🎯 Section Layout
    
    Full width section
    
    Title aligned left:
    
    Shop Our Collections
    
    Below the title, create a horizontal row of circular category items
    
    Show 6–8 items in one row (desktop)
    
    Enable horizontal scroll on mobile
    
    🎨 Design Style
    
    Clean premium ecommerce look
    
    White or light background
    
    Circular images (perfect round)
    
    Smooth hover effect (slight zoom or shadow)
    
    Text centered below each circle
    
    Proper spacing between items
    
    🧩 Category Item Structure (IMPORTANT)
    
    Each category item must include:
    
    Circular Image
    
    Category Name (text below image)
    
    Clickable link
    
    ⚙️ Dynamic & Editable (VERY IMPORTANT)
    
    Make the section fully dynamic using Shopify blocks.
    
    Each block should have:
    
    Image picker
    
    Text (category name)
    
    Collection or URL link
    
    Allow:
    
    Minimum: 4 items
    
    Maximum: 12 items
    
    All items must be:
    ✅ Editable
    ✅ Add/remove from customizer
    ✅ Reorderable
    
    📱 Mobile Behavior
    
    Horizontal scroll (swipe enabled)
    
    Show 2–3 items per row on small screens
    
    Maintain circular shape
    
    🧪 Sample Data (Astrojap)
    Item 1
    
    Title: Rudraksha Bracelets
    Link: /collections/rudraksha-bracelets
    
    Item 2
    
    Title: Rudraksha Malas
    Link: /collections/rudraksha-malas
    
    Item 3
    
    Title: Nepali/Indian Rudraksha
    Link: /collections/rudraksha
    
    Item 4
    
    Title: Spiritual Jewellery
    Link: /collections/spiritual-jewellery
    
    Item 5
    
    Title: Karungali Wearables
    Link: /collections/karungali
    
    Item 6
    
    Title: Energy Stones
    Link: /collections/energy-stones
    
    ⚙️ Technical Requirements
    
    Use Shopify Liquid + section schema
    
    Use blocks for each category
    
    Make everything editable from theme customizer
    
    Use CSS:
    
    border-radius: 50%
    
    object-fit: cover
    
    Ensure fast loading and responsive layout
    
    🚀 Goal
    
    Create a premium collection navigation section that improves:
    
    User experience
    
    Product discovery
    
    Conversion rate
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-collection-nav-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
  }

  .ai-collection-nav-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-collection-nav-header-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.title_spacing }}px;
    text-align: {{ block.settings.title_alignment }};
  }

  .ai-collection-nav-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0;
    font-weight: 600;
  }

  .ai-collection-nav-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.items_per_row }}, 1fr);
    gap: {{ block.settings.item_spacing }}px;
    overflow: visible;
  }

  .ai-collection-nav-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    transition: transform 0.3s ease;
  }

  .ai-collection-nav-item-{{ ai_gen_id }}:hover {
    transform: translateY(-{{ block.settings.hover_lift }}px);
  }

  .ai-collection-nav-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 100%;
    border-radius: 50%;
    overflow: hidden;
    background-color: #f4f4f4;
    margin-bottom: {{ block.settings.text_spacing }}px;
    box-shadow: 0 {{ block.settings.shadow_vertical }}px {{ block.settings.shadow_blur }}px rgba(0, 0, 0, {{ block.settings.shadow_opacity | divided_by: 100.0 }});
    transition: box-shadow 0.3s ease;
  }

  .ai-collection-nav-item-{{ ai_gen_id }}:hover .ai-collection-nav-image-wrapper-{{ ai_gen_id }} {
    box-shadow: 0 {{ block.settings.shadow_vertical | times: 1.5 }}px {{ block.settings.shadow_blur | times: 1.5 }}px rgba(0, 0, 0, {{ block.settings.shadow_opacity | times: 1.5 | divided_by: 100.0 }});
  }

  .ai-collection-nav-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .ai-collection-nav-item-{{ ai_gen_id }}:hover .ai-collection-nav-image-{{ ai_gen_id }} {
    transform: scale({{ block.settings.image_zoom }});
  }

  .ai-collection-nav-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-collection-nav-placeholder-{{ ai_gen_id }} svg {
    width: 50%;
    height: 50%;
    opacity: 0.3;
  }

  .ai-collection-nav-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    text-align: center;
    font-weight: 500;
    line-height: 1.3;
  }

  @media screen and (max-width: 989px) {
    .ai-collection-nav-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.items_per_row_tablet }}, 1fr);
    }

    .ai-collection-nav-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.85 }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-collection-nav-grid-{{ ai_gen_id }} {
      display: flex;
      overflow-x: auto;
      overflow-y: hidden;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      gap: {{ block.settings.item_spacing | times: 0.75 }}px;
      padding-bottom: 10px;
    }

    .ai-collection-nav-grid-{{ ai_gen_id }}::-webkit-scrollbar {
      height: 4px;
    }

    .ai-collection-nav-grid-{{ ai_gen_id }}::-webkit-scrollbar-track {
      background: #f1f1f1;
      border-radius: 10px;
    }

    .ai-collection-nav-grid-{{ ai_gen_id }}::-webkit-scrollbar-thumb {
      background: #888;
      border-radius: 10px;
    }

    .ai-collection-nav-item-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - {{ block.settings.item_spacing | times: 0.75 }}px) / {{ block.settings.items_per_row_mobile }});
      scroll-snap-align: start;
    }

    .ai-collection-nav-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.7 }}px;
    }

    .ai-collection-nav-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<collection-nav-{{ ai_gen_id }} class="ai-collection-nav-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-collection-nav-container-{{ ai_gen_id }}">
    {% if block.settings.title != blank %}
      <div class="ai-collection-nav-header-{{ ai_gen_id }}">
        <h2 class="ai-collection-nav-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
      </div>
    {% endif %}

    <div class="ai-collection-nav-grid-{{ ai_gen_id }}">
      {% for i in (1..12) %}
        {% assign image_key = 'image_' | append: i %}
        {% assign name_key = 'name_' | append: i %}
        {% assign link_key = 'link_' | append: i %}
        
        {% assign item_image = block.settings[image_key] %}
        {% assign item_name = block.settings[name_key] %}
        {% assign item_link = block.settings[link_key] %}
        
        {% if item_name != blank or item_image != blank %}
          <a
            href="{% if item_link != blank %}{{ item_link }}{% else %}#{% endif %}"
            class="ai-collection-nav-item-{{ ai_gen_id }}"
          >
            <div class="ai-collection-nav-image-wrapper-{{ ai_gen_id }}">
              {% if item_image %}
                <img
                  src="{{ item_image | image_url: width: 400 }}"
                  alt="{{ item_image.alt | escape }}"
                  class="ai-collection-nav-image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="400"
                  height="400"
                >
              {% else %}
                <div class="ai-collection-nav-placeholder-{{ ai_gen_id }}">
                  {{ 'collection-1' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>
            {% if item_name != blank %}
              <div class="ai-collection-nav-text-{{ ai_gen_id }}">
                {{ item_name }}
              </div>
            {% endif %}
          </a>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</collection-nav-{{ ai_gen_id }}>

<script>
  (function() {
    class CollectionNav{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupMobileScroll();
      }

      setupMobileScroll() {
        const grid = this.querySelector('.ai-collection-nav-grid-{{ ai_gen_id }}');
        if (!grid) return;

        let isDown = false;
        let startX;
        let scrollLeft;

        grid.addEventListener('mousedown', (e) => {
          if (window.innerWidth > 749) return;
          isDown = true;
          grid.style.cursor = 'grabbing';
          startX = e.pageX - grid.offsetLeft;
          scrollLeft = grid.scrollLeft;
        });

        grid.addEventListener('mouseleave', () => {
          isDown = false;
          grid.style.cursor = 'grab';
        });

        grid.addEventListener('mouseup', () => {
          isDown = false;
          grid.style.cursor = 'grab';
        });

        grid.addEventListener('mousemove', (e) => {
          if (!isDown) return;
          e.preventDefault();
          const x = e.pageX - grid.offsetLeft;
          const walk = (x - startX) * 2;
          grid.scrollLeft = scrollLeft - walk;
        });
      }
    }

    customElements.define('collection-nav-{{ ai_gen_id }}', CollectionNav{{ ai_gen_id }});
  })();
</script>

