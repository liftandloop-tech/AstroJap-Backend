{% doc %}
  @prompt
    Hi 👋
    
    Welcome to *SP ResearchVia Pvt. Ltd.*
    
    Make informed decisions with research-backed stock market insights 📊
    
    What you get:
    • Data-driven market analysis  
    • Stock insights based on research  
    • Trade reviews  
    • Structured planning  
    
    📲 Start using our app:
    https://play.google.com/store/apps/details?id=com.spresearchvia.ra  
    
    🌐 Learn more:
    www.researchvia.in  
    
    👨‍💼 SEBI Registered Research Analyst  
    
    ⚠️ Market investments are subject to risks.
    
    How can we assist you further?
    
    make it mobile responsive , Create a customer reviews section in a clean grid layout.
    
    Layout:
    - 2 columns on desktop
    - Cards with rounded corners and light grey background
    
    Each review card should include:
    - Star rating at the top (5 stars)
    - Customer name with "Verified" badge
    - Small date on top right
    - Review title (bold)
    - Review text below
    
    Design:
    - Soft shadows
    - Padding inside each card
    - Clean spacing between cards
    - Modern and minimal style
    
    Make it responsive for mobile (1 column).
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-reviews-section-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.section_padding }}px 20px;
  }

  .ai-reviews-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-reviews-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 700;
    color: {{ block.settings.title_color }};
    margin: 0 0 12px 0;
  }

  .ai-reviews-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
  }

  .ai-reviews-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr;
    gap: {{ block.settings.card_gap }}px;
  }

  .ai-review-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_bg_color }};
    border-radius: {{ block.settings.card_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    box-shadow: 0 {{ block.settings.shadow_vertical }}px {{ block.settings.shadow_blur }}px rgba(0, 0, 0, {{ block.settings.shadow_opacity }});
  }

  .ai-review-header-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 12px;
  }

  .ai-review-stars-{{ ai_gen_id }} {
    display: flex;
    gap: 4px;
    color: {{ block.settings.star_color }};
    font-size: {{ block.settings.star_size }}px;
  }

  .ai-review-date-{{ ai_gen_id }} {
    font-size: {{ block.settings.date_size }}px;
    color: {{ block.settings.date_color }};
    white-space: nowrap;
  }

  .ai-review-customer-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 12px;
  }

  .ai-review-name-{{ ai_gen_id }} {
    font-size: {{ block.settings.name_size }}px;
    font-weight: 600;
    color: {{ block.settings.name_color }};
  }

  .ai-review-verified-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 4px 10px;
    background-color: {{ block.settings.badge_bg_color }};
    color: {{ block.settings.badge_text_color }};
    border-radius: {{ block.settings.badge_radius }}px;
    font-size: {{ block.settings.badge_size }}px;
    font-weight: 600;
  }

  .ai-review-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.review_title_size }}px;
    font-weight: 700;
    color: {{ block.settings.review_title_color }};
    margin: 0 0 8px 0;
  }

  .ai-review-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.review_text_size }}px;
    line-height: 1.6;
    color: {{ block.settings.review_text_color }};
    margin: 0;
  }

  @media screen and (min-width: 750px) {
    .ai-reviews-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    }
  }
{% endstyle %}

<div class="ai-reviews-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.show_header %}
    <div class="ai-reviews-header-{{ ai_gen_id }}">
      {% if block.settings.section_title != blank %}
        <h2 class="ai-reviews-title-{{ ai_gen_id }}">{{ block.settings.section_title }}</h2>
      {% endif %}
      {% if block.settings.section_subtitle != blank %}
        <p class="ai-reviews-subtitle-{{ ai_gen_id }}">{{ block.settings.section_subtitle }}</p>
      {% endif %}
    </div>
  {% endif %}

  <div class="ai-reviews-grid-{{ ai_gen_id }}">
    {% for i in (1..6) %}
      {% liquid
        assign name_key = 'review_' | append: i | append: '_name'
        assign title_key = 'review_' | append: i | append: '_title'
        assign text_key = 'review_' | append: i | append: '_text'
        assign date_key = 'review_' | append: i | append: '_date'
        assign verified_key = 'review_' | append: i | append: '_verified'

        assign review_name = block.settings[name_key]
        assign review_title = block.settings[title_key]
        assign review_text = block.settings[text_key]
        assign review_date = block.settings[date_key]
        assign review_verified = block.settings[verified_key]
      %}

      {% if review_name != blank or review_title != blank or review_text != blank %}
        <div class="ai-review-card-{{ ai_gen_id }}">
          <div class="ai-review-header-{{ ai_gen_id }}">
            <div class="ai-review-stars-{{ ai_gen_id }}">
              {% for star in (1..5) %}
                <span>★</span>
              {% endfor %}
            </div>
            {% if review_date != blank %}
              <div class="ai-review-date-{{ ai_gen_id }}">{{ review_date }}</div>
            {% endif %}
          </div>

          <div class="ai-review-customer-{{ ai_gen_id }}">
            {% if review_name != blank %}
              <div class="ai-review-name-{{ ai_gen_id }}">{{ review_name }}</div>
            {% endif %}
            {% if review_verified %}
              <div class="ai-review-verified-{{ ai_gen_id }}">
                <span>✓</span>
                <span>Verified</span>
              </div>
            {% endif %}
          </div>

          {% if review_title != blank %}
            <h3 class="ai-review-title-{{ ai_gen_id }}">{{ review_title }}</h3>
          {% endif %}

          {% if review_text != blank %}
            <p class="ai-review-text-{{ ai_gen_id }}">{{ review_text }}</p>
          {% endif %}
        </div>
      {% endif %}
    {% endfor %}
  </div>
</div>

