{% doc %}
  @prompt
    Content Structure
    
    Intro Paragraph Block
    
    Two introductory paragraphs explaining how users can make their Janam Kundli online easily.
    
    Text should be readable with comfortable line spacing.
    
    Main Heading (H2)
    Free Kundli Online - Get Your Detailed Birth Chart with Predictions
    
    Content Paragraphs
    
    4–5 paragraphs explaining:
    
    How kundli generators work
    
    Planetary positions in birth charts
    
    Insights about career, marriage, and health
    
    Benefits of online kundli tools
    
    Prediction and life guidance
    
    Subheading (H3)
    Online Free Kundli For Future Predictions
    
    More descriptive text under the subheading
    
    Typography
    
    Heading font size: 32–36px
    
    Paragraph font size: 16–18px
    
    Line height: 1.6–1.8
    
    Dark gray text color (#333)
    
    Section Settings (Shopify Schema)
    Add customizable options:
    
    Section padding top/bottom
    
    Container width
    
    Heading text
    
    Paragraph content
    
    Background color
    
    Technical Requirements
    
    Use Shopify Liquid
    
    Use section schema
    
    Make the text editable from Shopify customizer
    
    Follow Shopify Online Store 2.0 standards
    
    Goal
    Create a clean SEO-friendly content section for an astrology/kundli page similar to a blog article layout.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-kundli-content-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.padding_top }}px 20px {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-kundli-content__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
  }

  .ai-kundli-content__intro-{{ ai_gen_id }} {
    margin-bottom: 40px;
  }

  .ai-kundli-content__intro-paragraph-{{ ai_gen_id }} {
    font-size: {{ block.settings.paragraph_font_size }}px;
    line-height: {{ block.settings.line_height }};
    color: {{ block.settings.text_color }};
    margin-bottom: 20px;
  }

  .ai-kundli-content__intro-paragraph-{{ ai_gen_id }}:last-child {
    margin-bottom: 0;
  }

  .ai-kundli-content__main-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_font_size }}px;
    line-height: 1.2;
    color: {{ block.settings.heading_color }};
    margin: 0 0 30px;
    font-weight: 600;
  }

  .ai-kundli-content__paragraph-{{ ai_gen_id }} {
    font-size: {{ block.settings.paragraph_font_size }}px;
    line-height: {{ block.settings.line_height }};
    color: {{ block.settings.text_color }};
    margin-bottom: 24px;
  }

  .ai-kundli-content__subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_font_size }}px;
    line-height: 1.3;
    color: {{ block.settings.heading_color }};
    margin: 40px 0 20px;
    font-weight: 600;
  }

  .ai-kundli-content__subheading-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.paragraph_font_size }}px;
    line-height: {{ block.settings.line_height }};
    color: {{ block.settings.text_color }};
    margin-bottom: 24px;
  }

  @media screen and (max-width: 749px) {
    .ai-kundli-content-{{ ai_gen_id }} {
      width: 100%;
      padding: {{ block.settings.padding_top | times: 0.7 }}px 16px {{ block.settings.padding_bottom | times: 0.7 }}px;
    }

    .ai-kundli-content__main-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_font_size | times: 0.75 }}px;
    }

    .ai-kundli-content__subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_font_size | times: 0.8 }}px;
    }

    .ai-kundli-content__paragraph-{{ ai_gen_id }},
    .ai-kundli-content__intro-paragraph-{{ ai_gen_id }},
    .ai-kundli-content__subheading-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.paragraph_font_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<kundli-content-{{ ai_gen_id }} class="ai-kundli-content-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-kundli-content__container-{{ ai_gen_id }}">
    {% if block.settings.intro_paragraph_1 != blank or block.settings.intro_paragraph_2 != blank %}
      <div class="ai-kundli-content__intro-{{ ai_gen_id }}">
        {% if block.settings.intro_paragraph_1 != blank %}
          <div class="ai-kundli-content__intro-paragraph-{{ ai_gen_id }}">
            {{ block.settings.intro_paragraph_1 }}
          </div>
        {% endif %}
        {% if block.settings.intro_paragraph_2 != blank %}
          <div class="ai-kundli-content__intro-paragraph-{{ ai_gen_id }}">
            {{ block.settings.intro_paragraph_2 }}
          </div>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.main_heading != blank %}
      <h2 class="ai-kundli-content__main-heading-{{ ai_gen_id }}">
        {{ block.settings.main_heading }}
      </h2>
    {% endif %}

    {% if block.settings.paragraph_1 != blank %}
      <div class="ai-kundli-content__paragraph-{{ ai_gen_id }}">
        {{ block.settings.paragraph_1 }}
      </div>
    {% endif %}

    {% if block.settings.paragraph_2 != blank %}
      <div class="ai-kundli-content__paragraph-{{ ai_gen_id }}">
        {{ block.settings.paragraph_2 }}
      </div>
    {% endif %}

    {% if block.settings.paragraph_3 != blank %}
      <div class="ai-kundli-content__paragraph-{{ ai_gen_id }}">
        {{ block.settings.paragraph_3 }}
      </div>
    {% endif %}

    {% if block.settings.paragraph_4 != blank %}
      <div class="ai-kundli-content__paragraph-{{ ai_gen_id }}">
        {{ block.settings.paragraph_4 }}
      </div>
    {% endif %}

    {% if block.settings.paragraph_5 != blank %}
      <div class="ai-kundli-content__paragraph-{{ ai_gen_id }}">
        {{ block.settings.paragraph_5 }}
      </div>
    {% endif %}

    {% if block.settings.subheading != blank %}
      <h3 class="ai-kundli-content__subheading-{{ ai_gen_id }}">
        {{ block.settings.subheading }}
      </h3>
    {% endif %}

    {% if block.settings.subheading_text != blank %}
      <div class="ai-kundli-content__subheading-text-{{ ai_gen_id }}">
        {{ block.settings.subheading_text }}
      </div>
    {% endif %}
  </div>
</kundli-content-{{ ai_gen_id }}>

<script>
  (function() {
    class KundliContent{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }
    }
    customElements.define('kundli-content-{{ ai_gen_id }}', KundliContent{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Kundli content",
  "settings": [
    {
      "type": "header",
      "content": "Introduction"
    },
    {
      "type": "richtext",
      "id": "intro_paragraph_1",
      "label": "Intro paragraph 1",
      "default": "<p>Create your Janam Kundli online in just a few simple steps. Our advanced kundli generator provides accurate birth chart analysis based on Vedic astrology principles.</p>"
    },
    {
      "type": "richtext",
      "id": "intro_paragraph_2",
      "label": "Intro paragraph 2",
      "default": "<p>Get detailed insights into your life path, personality traits, and future predictions with our free online kundli service. Simply enter your birth details to begin your astrological journey.</p>"
    },
    {
      "type": "header",
      "content": "Main content"
    },
    {
      "type": "inline_richtext",
      "id": "main_heading",
      "label": "Main heading (H2)",
      "default": "Free Kundli Online - Get Your Detailed Birth Chart with Predictions"
    },
    {
      "type": "richtext",
      "id": "paragraph_1",
      "label": "Paragraph 1",
      "default": "<p>Our online kundli generator uses advanced Vedic astrology algorithms to create your personalized birth chart. By analyzing the exact positions of planets at the time of your birth, we provide comprehensive insights into various aspects of your life.</p>"
    },
    {
      "type": "richtext",
      "id": "paragraph_2",
      "label": "Paragraph 2",
      "default": "<p>The planetary positions in your birth chart reveal important information about your personality, strengths, weaknesses, and life patterns. Each planet represents different energies and influences that shape your destiny and character.</p>"
    },
    {
      "type": "richtext",
      "id": "paragraph_3",
      "label": "Paragraph 3",
      "default": "<p>Your kundli provides valuable insights about career prospects, marriage compatibility, health predictions, and financial opportunities. Understanding these aspects helps you make informed decisions and navigate life's challenges with confidence.</p>"
    },
    {
      "type": "richtext",
      "id": "paragraph_4",
      "label": "Paragraph 4",
      "default": "<p>The benefits of using online kundli tools include instant access to your birth chart, detailed planetary analysis, and personalized predictions. Our platform makes ancient Vedic wisdom accessible to everyone, anywhere, at any time.</p>"
    },
    {
      "type": "richtext",
      "id": "paragraph_5",
      "label": "Paragraph 5",
      "default": "<p>Accurate predictions and life guidance based on your kundli can help you understand your true potential and life purpose. Discover favorable periods for important decisions and learn how to align your actions with cosmic energies for success and fulfillment.</p>"
    },
    {
      "type": "header",
      "content": "Subheading section"
    },
    {
      "type": "inline_richtext",
      "id": "subheading",
      "label": "Subheading (H3)",
      "default": "Online Free Kundli For Future Predictions"
    },
    {
      "type": "richtext",
      "id": "subheading_text",
      "label": "Subheading text",
      "default": "<p>Access detailed future predictions through your online kundli. Our comprehensive analysis covers all major life events, planetary transits, and dasha periods to help you prepare for what lies ahead and make the most of upcoming opportunities.</p>"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "container_width",
      "label": "Container width",
      "min": 600,
      "max": 1200,
      "step": 50,
      "unit": "px",
      "default": 900
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Heading size",
      "min": 24,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "range",
      "id": "subheading_font_size",
      "label": "Subheading size",
      "min": 18,
      "max": 36,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "paragraph_font_size",
      "label": "Paragraph size",
      "min": 14,
      "max": 22,
      "step": 1,
      "unit": "px",
      "default": 17
    },
    {
      "type": "range",
      "id": "line_height",
      "label": "Line height",
      "min": 1,
      "max": 2,
      "step": 0.1,
      "default": 1.7
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#333333"
    }
  ],
  "presets": [
    {
      "name": "Kundli content"
    }
  ]
}
{% endschema %}
