{% doc %}
  @prompt
    🚨 IMPORTANT
    
    DO NOT create a plain form.
    Create a modern 2-column contact section.
    
    🧱 LAYOUT
    Left Side (Form):
    
    Name
    
    Email
    
    Phone
    
    Message
    
    Submit button
    
    Right Side (Contact Info):
    
    Add cards or list:
    
    📍 Address
    
    📞 Phone Number
    
    📧 Email
    
    ⏰ Working Hours
    
    🧾 SAMPLE DATA
    
    Address:
    Astrojap, India
    
    Email:
    support@astrojap.com
    
    Phone:
    +91 XXXXX XXXXX
    
    🎨 DESIGN
    
    Card style form
    
    Rounded inputs
    
    Soft shadow
    
    Clean UI
    
    ⚙️ EDITABLE
    
    All fields editable
    
    Contact info editable
    
    Button text editable
    
    📱 MOBILE
    
    Stack layout
    
    Full width form
    
    🚀 GOAL
    
    Create a professional and easy-to-use contact form section.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-contact-section-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-contact-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ block.settings.column_gap }}px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-contact-form-wrapper-{{ ai_gen_id }} {
    background-color: {{ block.settings.form_background }};
    padding: {{ block.settings.form_padding }}px;
    border-radius: {{ block.settings.form_border_radius }}px;
    box-shadow: 0 {{ block.settings.shadow_vertical }}px {{ block.settings.shadow_blur }}px rgba(0, 0, 0, {{ block.settings.shadow_opacity }});
  }

  .ai-contact-form-title-{{ ai_gen_id }} {
    margin: 0 0 24px;
    font-size: {{ block.settings.form_title_size }}px;
    color: {{ block.settings.form_text_color }};
    font-weight: 600;
  }

  .ai-contact-form-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ai-contact-field-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-contact-label-{{ ai_gen_id }} {
    font-size: 14px;
    font-weight: 500;
    color: {{ block.settings.form_text_color }};
  }

  .ai-contact-input-{{ ai_gen_id }},
  .ai-contact-textarea-{{ ai_gen_id }} {
    padding: 12px 16px;
    border: 1px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    font-size: 14px;
    background-color: {{ block.settings.input_background }};
    color: {{ block.settings.form_text_color }};
    transition: border-color 0.3s ease;
  }

  .ai-contact-input-{{ ai_gen_id }}:focus,
  .ai-contact-textarea-{{ ai_gen_id }}:focus {
    outline: none;
    border-color: {{ block.settings.input_focus_color }};
  }

  .ai-contact-textarea-{{ ai_gen_id }} {
    min-height: 120px;
    resize: vertical;
    font-family: inherit;
  }

  .ai-contact-submit-{{ ai_gen_id }} {
    padding: 14px 28px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.3s ease;
  }

  .ai-contact-submit-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
  }

  .ai-contact-info-wrapper-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.info_card_gap }}px;
  }

  .ai-contact-info-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.info_card_background }};
    padding: {{ block.settings.info_card_padding }}px;
    border-radius: {{ block.settings.info_card_border_radius }}px;
    box-shadow: 0 {{ block.settings.shadow_vertical }}px {{ block.settings.shadow_blur }}px rgba(0, 0, 0, {{ block.settings.shadow_opacity }});
    display: flex;
    align-items: flex-start;
    gap: 16px;
  }

  .ai-contact-icon-{{ ai_gen_id }} {
    width: 48px;
    height: 48px;
    background-color: {{ block.settings.icon_background }};
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: {{ block.settings.icon_color }};
  }

  .ai-contact-icon-{{ ai_gen_id }} svg {
    width: 24px;
    height: 24px;
  }

  .ai-contact-info-content-{{ ai_gen_id }} {
    flex: 1;
  }

  .ai-contact-info-title-{{ ai_gen_id }} {
    margin: 0 0 8px;
    font-size: 16px;
    font-weight: 600;
    color: {{ block.settings.info_text_color }};
  }

  .ai-contact-info-text-{{ ai_gen_id }} {
    margin: 0;
    font-size: 14px;
    color: {{ block.settings.info_text_color }};
    line-height: 1.6;
  }

  .ai-contact-success-{{ ai_gen_id }} {
    padding: 12px 16px;
    background-color: #d4edda;
    color: #155724;
    border-radius: {{ block.settings.input_border_radius }}px;
    margin-bottom: 16px;
  }

  .ai-contact-error-{{ ai_gen_id }} {
    padding: 12px 16px;
    background-color: #f8d7da;
    color: #721c24;
    border-radius: {{ block.settings.input_border_radius }}px;
    margin-bottom: 16px;
  }

  @media screen and (max-width: 768px) {
    .ai-contact-container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .ai-contact-form-wrapper-{{ ai_gen_id }} {
      padding: {{ block.settings.form_padding | times: 0.75 }}px;
    }

    .ai-contact-info-card-{{ ai_gen_id }} {
      padding: {{ block.settings.info_card_padding | times: 0.75 }}px;
    }
  }
{% endstyle %}

<contact-section-{{ ai_gen_id }} class="ai-contact-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-contact-container-{{ ai_gen_id }}">
    <div class="ai-contact-form-wrapper-{{ ai_gen_id }}">
      {% if block.settings.form_title != blank %}
        <h2 class="ai-contact-form-title-{{ ai_gen_id }}">{{ block.settings.form_title }}</h2>
      {% endif %}

      {%- form 'contact' -%}
        {%- if form.posted_successfully? -%}
          <div class="ai-contact-success-{{ ai_gen_id }}">
            {{ block.settings.success_message }}
          </div>
        {%- endif -%}

        {%- if form.errors -%}
          <div class="ai-contact-error-{{ ai_gen_id }}">
            {{ form.errors.messages | first }}
          </div>
        {%- endif -%}

        <div class="ai-contact-form-{{ ai_gen_id }}">
          <div class="ai-contact-field-{{ ai_gen_id }}">
            <label for="contact-name-{{ ai_gen_id }}" class="ai-contact-label-{{ ai_gen_id }}">
              {{ block.settings.name_label }}
            </label>
            <input
              type="text"
              id="contact-name-{{ ai_gen_id }}"
              name="contact[name]"
              class="ai-contact-input-{{ ai_gen_id }}"
              value="{% if form.name %}{{ form.name }}{% endif %}"
              required
            >
          </div>

          <div class="ai-contact-field-{{ ai_gen_id }}">
            <label for="contact-email-{{ ai_gen_id }}" class="ai-contact-label-{{ ai_gen_id }}">
              {{ block.settings.email_label }}
            </label>
            <input
              type="email"
              id="contact-email-{{ ai_gen_id }}"
              name="contact[email]"
              class="ai-contact-input-{{ ai_gen_id }}"
              value="{% if form.email %}{{ form.email }}{% endif %}"
              autocomplete="email"
              required
            >
          </div>

          <div class="ai-contact-field-{{ ai_gen_id }}">
            <label for="contact-phone-{{ ai_gen_id }}" class="ai-contact-label-{{ ai_gen_id }}">
              {{ block.settings.phone_label }}
            </label>
            <input
              type="tel"
              id="contact-phone-{{ ai_gen_id }}"
              name="contact[phone]"
              class="ai-contact-input-{{ ai_gen_id }}"
              value="{% if form.phone %}{{ form.phone }}{% endif %}"
              autocomplete="tel"
            >
          </div>

          <div class="ai-contact-field-{{ ai_gen_id }}">
            <label for="contact-message-{{ ai_gen_id }}" class="ai-contact-label-{{ ai_gen_id }}">
              {{ block.settings.message_label }}
            </label>
            <textarea
              id="contact-message-{{ ai_gen_id }}"
              name="contact[body]"
              class="ai-contact-textarea-{{ ai_gen_id }}"
              required
            >{% if form.body %}{{ form.body }}{% endif %}</textarea>
          </div>

          <button type="submit" class="ai-contact-submit-{{ ai_gen_id }}">
            {{ block.settings.button_text }}
          </button>
        </div>
      {%- endform -%}
    </div>

    <div class="ai-contact-info-wrapper-{{ ai_gen_id }}">
      {% if block.settings.show_address %}
        <div class="ai-contact-info-card-{{ ai_gen_id }}">
          <div class="ai-contact-icon-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
          </div>
          <div class="ai-contact-info-content-{{ ai_gen_id }}">
            <h3 class="ai-contact-info-title-{{ ai_gen_id }}">{{ block.settings.address_title }}</h3>
            <p class="ai-contact-info-text-{{ ai_gen_id }}">{{ block.settings.address_text }}</p>
          </div>
        </div>
      {% endif %}

      {% if block.settings.show_phone %}
        <div class="ai-contact-info-card-{{ ai_gen_id }}">
          <div class="ai-contact-icon-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
            </svg>
          </div>
          <div class="ai-contact-info-content-{{ ai_gen_id }}">
            <h3 class="ai-contact-info-title-{{ ai_gen_id }}">{{ block.settings.phone_title }}</h3>
            <p class="ai-contact-info-text-{{ ai_gen_id }}">{{ block.settings.phone_text }}</p>
          </div>
        </div>
      {% endif %}

      {% if block.settings.show_email %}
        <div class="ai-contact-info-card-{{ ai_gen_id }}">
          <div class="ai-contact-icon-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
              <polyline points="22,6 12,13 2,6"></polyline>
            </svg>
          </div>
          <div class="ai-contact-info-content-{{ ai_gen_id }}">
            <h3 class="ai-contact-info-title-{{ ai_gen_id }}">{{ block.settings.email_title }}</h3>
            <p class="ai-contact-info-text-{{ ai_gen_id }}">{{ block.settings.email_text }}</p>
          </div>
        </div>
      {% endif %}

      {% if block.settings.show_hours %}
        <div class="ai-contact-info-card-{{ ai_gen_id }}">
          <div class="ai-contact-icon-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"></circle>
              <polyline points="12 6 12 12 16 14"></polyline>
            </svg>
          </div>
          <div class="ai-contact-info-content-{{ ai_gen_id }}">
            <h3 class="ai-contact-info-title-{{ ai_gen_id }}">{{ block.settings.hours_title }}</h3>
            <p class="ai-contact-info-text-{{ ai_gen_id }}">{{ block.settings.hours_text }}</p>
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</contact-section-{{ ai_gen_id }}>

<script>
  (function() {
    class ContactSection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        const form = this.querySelector('form');
        if (form) {
          form.addEventListener('submit', function() {
            const button = form.querySelector('button[type="submit"]');
            if (button) {
              button.disabled = true;
              button.textContent = 'Sending...';
            }
          });
        }
      }
    }

    customElements.define('contact-section-{{ ai_gen_id }}', ContactSection{{ ai_gen_id }});
  })();
</script>

