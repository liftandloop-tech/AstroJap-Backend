{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  /* ── MAIN GRID SECTION ── */
  .ai-all-sec-{{ ai_gen_id }} {
    padding: 60px 0;
    background: {{ block.settings.bg_color | default: '#ffffff' }};
    font-family: 'Inter', sans-serif;
  }

  .ai-all-win-{{ ai_gen_id }} {
    max-width: 1550px; 
    margin: 0 auto;
    padding: 0 10px;
  }

  .ai-all-head-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 40px;
  }

  .ai-all-title-{{ ai_gen_id }} {
    font-family: 'Cinzel', serif;
    font-size: clamp(28px, 6vw, 42px);
    color: #1a1a1a;
    text-transform: uppercase;
    letter-spacing: 2px;
  }

  /* ── GRID SYSTEM (6 per row desktop) ── */
  .ai-all-wrap-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 15px;
  }

  /* ── PRODUCT CARD ── */
  .ai-all-card-{{ ai_gen_id }} {
    background: #fff;
    border: 1px solid #f2f2f2;
    border-radius: 10px;
    overflow: hidden;
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
    height: 100%;
    position: relative;
  }

  .ai-all-card-{{ ai_gen_id }}:hover {
    box-shadow: 0 12px 30px rgba(0,0,0,0.06);
    border-color: #c9a84c;
    transform: translateY(-5px);
  }

  /* ── PREMIUM RIBBON/BADGE (From requested code) ── */
  .ai-all-badge-wrapper-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 12px;
    z-index: 3;
    filter: drop-shadow(0px 3px 4px rgba(0,0,0,0.25));
    transform: scale({{ block.settings.badge_size_desktop | divided_by: 100.0 }});
    transform-origin: top left;
  }
  .ai-all-badge-content-{{ ai_gen_id }} {
    background: {{ block.settings.badge_bg_color | default: '#ffdc00' }};
    color: {{ block.settings.badge_text_color | default: '#1a1a1a' }};
    padding: 8px 8px 14px 8px;
    clip-path: polygon(0 0, 100% 0, 100% calc(100% - 10px), 50% 100%, 0 calc(100% - 10px));
    text-align: center;
    min-width: 65px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .ai-all-badge-l1-{{ ai_gen_id }} { font-size: 16px; font-weight: 900; line-height: 1; }
  .ai-all-badge-l2-{{ ai_gen_id }} { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0px; }
  .ai-all-badge-l3-{{ ai_gen_id }} { font-size: 8px; font-weight: 600; max-width: 50px; margin: 0 auto; line-height: 1.1; }

  /* Media Gallery (Auto-Sliding) */
  .ai-all-media-{{ ai_gen_id }} {
    position: relative;
    padding-top: 110%; 
    background: #fdfdfd;
    overflow: hidden;
    cursor: pointer;
    display: block;
  }

  .ai-all-img-{{ ai_gen_id }} {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 0.6s ease-in-out;
  }

  .ai-all-img-{{ ai_gen_id }}.active { opacity: 1; }

  .ai-all-dots-{{ ai_gen_id }} {
    position: absolute;
    bottom: 8px;
    left: 0;
    right: 0;
    display: flex;
    justify-content: center;
    gap: 4px;
    z-index: 2;
  }

  .ai-all-dot-{{ ai_gen_id }} {
    width: 4px;
    height: 4px;
    background: rgba(0,0,0,0.1);
    border-radius: 50%;
  }

  .ai-all-dot-{{ ai_gen_id }}.active {
    background: #c9a84c;
    width: 10px;
    border-radius: 2px;
  }

  /* ── RATING ── */
  .ai-all-rating-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 4px;
    margin-bottom: 6px;
    color: #ffb400;
    font-size: 10px;
    line-height: 1;
  }
  .ai-review-count-{{ ai_gen_id }} {
    color: #888;
    font-size: 9px;
  }

  /* ── CONTENT ── */
  .ai-all-info-{{ ai_gen_id }} {
    padding: 10px 8px;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    text-align: center;
  }

  .ai-all-btitle-{{ ai_gen_id }} {
    font-size: 11px;
    font-weight: 600;
    color: #111;
    text-decoration: none;
    margin-bottom: 8px;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    height: 2.8em;
  }

  .ai-all-price-{{ ai_gen_id }} {
    font-size: 14px;
    font-weight: 700;
    color: #c9a84c;
    margin-bottom: 12px;
    margin-top: auto;
  }

  .ai-all-btn-{{ ai_gen_id }} {
    width: 100%;
    padding: 10px 5px;
    background: #111;
    color: #fff;
    border: none;
    border-radius: 6px;
    font-size: 9px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    cursor: pointer;
    transition: 0.3s;
  }
  .ai-all-btn-{{ ai_gen_id }}:hover { background: #c9a84c; color: #000; }

  /* ── MOBILE RESPONSIVE ── */
  @media (max-width: 1200px) {
    .ai-all-wrap-{{ ai_gen_id }} { grid-template-columns: repeat(4, 1fr); }
  }

  @media (max-width: 900px) {
    .ai-all-wrap-{{ ai_gen_id }} { grid-template-columns: repeat(3, 1fr); }
  }

  @media (max-width: 768px) {
    .ai-all-wrap-{{ ai_gen_id }} { 
      grid-template-columns: repeat(2, 1fr); 
      gap: 10px; 
    }
    .ai-all-badge-wrapper-{{ ai_gen_id }} { 
      left: 6px; 
      transform: scale({{ block.settings.badge_size_mobile | divided_by: 100.0 }}); 
    }
  }
{% endstyle %}

<div class="ai-all-sec-{{ ai_gen_id }}">
  <div class="ai-all-win-{{ ai_gen_id }}">
    
    <div class="ai-all-head-{{ ai_gen_id }}">
      {% if block.settings.title != blank %}
        <h2 class="ai-all-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
      {% endif %}
    </div>

    {% if block.settings.collection != blank %}
      <div class="ai-all-wrap-{{ ai_gen_id }}" id="grid-{{ ai_gen_id }}">
        
        {% for product in block.settings.collection.products limit: 120 %}
          {% assign product_seed = product.id | modulo: 40 | plus: 15 %}
          
          <div class="ai-all-card-{{ ai_gen_id }}" data-images="{{ product.images.size }}">
            
            <a href="{{ product.url }}" class="ai-all-media-{{ ai_gen_id }}">

              {% if block.settings.show_badge %}
                <div class="ai-all-badge-wrapper-{{ ai_gen_id }}">
                  <div class="ai-all-badge-content-{{ ai_gen_id }}">
                    {% if block.settings.badge_l1 != blank %}<span class="ai-all-badge-l1-{{ ai_gen_id }}">{{ block.settings.badge_l1 }}</span>{% endif %}
                    {% if block.settings.badge_l2 != blank %}<span class="ai-all-badge-l2-{{ ai_gen_id }}">{{ block.settings.badge_l2 }}</span>{% endif %}
                    {% if block.settings.badge_l3 != blank %}<span class="ai-all-badge-l3-{{ ai_gen_id }}">{{ block.settings.badge_l3 }}</span>{% endif %}
                  </div>
                </div>
              {% endif %}

              {% for image in product.images limit: 4 %}
                <img src="{{ image | image_url: width: 450 }}" class="ai-all-img-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}" data-idx="{{ forloop.index0 }}" alt="{{ product.title }}">
              {% endfor %}

              {% if product.images.size > 1 %}
                <div class="ai-all-dots-{{ ai_gen_id }}">
                  {% for image in product.images limit: 4 %}
                    <span class="ai-all-dot-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}" data-idx="{{ forloop.index0 }}"></span>
                  {% endfor %}
                </div>
              {% endif %}
            </a>

            <div class="ai-all-info-{{ ai_gen_id }}">
              
              <div class="ai-all-rating-{{ ai_gen_id }}">
                <span class="stars">★★★★★</span>
                <span class="ai-review-count-{{ ai_gen_id }}">({{ product_seed }})</span>
              </div>

              <a href="{{ product.url }}" class="ai-all-btitle-{{ ai_gen_id }}">{{ product.title }}</a>
              
              <div class="ai-all-price-{{ ai_gen_id }}">
                {{ product.price | money_without_trailing_zeros }}
              </div>

              {% if product.available %}
                <form method="post" action="/cart/add">
                  <input type="hidden" name="id" value="{{ product.variants.first.id }}">
                  <button type="submit" class="ai-all-btn-{{ ai_gen_id }}">Add To Cart</button>
                </form>
              {% else %}
                <button type="button" class="ai-all-btn-{{ ai_gen_id }} ai-all-btn-soldout-{{ ai_gen_id }}" disabled>Sold Out</button>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    {% endif %}

  </div>
</div>

<script>
  (function() {
    // ── Auto-Gallery Logic ──
    const updG = (card, idx) => {
      card.querySelectorAll('.ai-all-dot-{{ ai_gen_id }}').forEach(d => d.classList.toggle('active', d.dataset.idx == idx));
      card.querySelectorAll('.ai-all-img-{{ ai_gen_id }}').forEach(im => im.classList.toggle('active', im.dataset.idx == idx));
      card.dataset.current = idx;
    };

    setInterval(() => {
      document.querySelectorAll('.ai-all-card-{{ ai_gen_id }}').forEach(card => {
        const count = Math.min(parseInt(card.dataset.images || 0), 4);
        if (count <= 1) return;
        let curr = parseInt(card.dataset.current || 0);
        let next = (curr + 1) % count;
        updG(card, next);
      });
    }, 4000);
  })();
</script>

{% schema %}
{
  "name": "Infinite Product Grid",
  "settings": [
    { "type": "text", "id": "title", "label": "Heading", "default": "Our Collection" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#ffffff" },
    { "type": "header", "content": "Badge Settings" },
    { "type": "checkbox", "id": "show_badge", "label": "Show Badge", "default": true },
    { "type": "range", "id": "badge_size_desktop", "label": "Badge Size (Desktop)", "min": 50, "max": 150, "step": 5, "unit": "%", "default": 100 },
    { "type": "range", "id": "badge_size_mobile", "label": "Badge Size (Mobile)", "min": 50, "max": 150, "step": 5, "unit": "%", "default": 80 },
    { "type": "text", "id": "badge_l1", "label": "Line 1 (Large)", "default": "100%*" },
    { "type": "text", "id": "badge_l2", "label": "Line 2 (Medium)", "default": "CASHBACK" },
    { "type": "text", "id": "badge_l3", "label": "Line 3 (Small)", "default": "on prepaid order" },
    { "type": "color", "id": "badge_bg_color", "label": "Badge Background", "default": "#ffdc00" },
    { "type": "color", "id": "badge_text_color", "label": "Badge Text", "default": "#1a1a1a" }
  ],
  "presets": [{ "name": "Premium Infinite Grid" }]
}
{% endschema %}
