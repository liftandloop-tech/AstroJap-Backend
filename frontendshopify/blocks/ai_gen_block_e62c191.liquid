{% doc %}
  @prompt Astrojap - Multi-Source Reels Block (Responsive Grid 4x2)
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  /* ── SECTION SHELL ── */
  .ai-vt-section-{{ ai_gen_id }} {
    padding: 80px 0;
    background: {{ block.settings.bg_color | default: '#f9f9f9' }};
  }

  .ai-vt-win-{{ ai_gen_id }} {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
  }

  /* ── HEADERS ── */
  .ai-vt-head-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 50px;
  }

  .ai-vt-small-{{ ai_gen_id }} {
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: #c9a84c;
    font-weight: 700;
    margin-bottom: 10px;
  }

  .ai-vt-main-{{ ai_gen_id }} {
    font-family: 'Cinzel', serif;
    font-size: clamp(28px, 5vw, 42px);
    color: #1a1a1a;
  }

  /* ── RESPONSIVE GRID ── */
  .ai-vt-list-{{ ai_gen_id }} {
    display: grid;
    gap: 20px;
    /* Desktop: 4 in a row */
    grid-template-columns: repeat(4, 1fr);
    padding-bottom: 20px;
  }

  /* Tablet: 3 in a row */
  @media (max-width: 1024px) {
    .ai-vt-list-{{ ai_gen_id }} {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* Mobile: 2 in a row */
  @media (max-width: 768px) {
    .ai-vt-list-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px; /* Smaller gap for mobile */
    }
  }

  /* Small Mobile: 1 in a row (Optional, for very small screens) */
  @media (max-width: 480px) {
    .ai-vt-list-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr); /* Staying with 2 per user request */
    }
  }

  /* ── CARD ── */
  .ai-vt-card-{{ ai_gen_id }} {
    background: #fff;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 10px 35px rgba(0,0,0,0.06);
    display: flex;
    flex-direction: column;
    transition: transform 0.3s ease;
    height: 100%;
  }

  .ai-vt-card-{{ ai_gen_id }}:hover {
    transform: translateY(-5px);
  }

  /* 🎥 MEDIA */
  .ai-vt-media-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: 9 / 16;
    background: #000;
    overflow: hidden;
  }

  .ai-vt-iframe-{{ ai_gen_id }} { width: 100%; height: 100%; border: none; display: block; }
  .ai-vt-video-{{ ai_gen_id }} { width: 100%; height: 100%; object-fit: cover; }

  .ai-vt-play-{{ ai_gen_id }} {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 5;
    transition: 0.3s;
  }

  .ai-vt-card-{{ ai_gen_id }}.playing .ai-vt-play-{{ ai_gen_id }} {
    opacity: 0;
    pointer-events: none;
  }

  /* ⭐ COMMENTS & DROPDOWN */
  .ai-vt-content-{{ ai_gen_id }} {
    padding: 15px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    border-bottom: 1px solid #f8f8f8;
  }

  .ai-vt-dropdown-trigger-{{ ai_gen_id }} {
    font-size: 12px;
    color: #c9a84c;
    font-weight: 700;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .ai-vt-dropdown-trigger-{{ ai_gen_id }} svg { transition: 0.3s; width: 10px; height: 10px; }
  .ai-vt-dropdown-trigger-{{ ai_gen_id }}.active svg { transform: rotate(180deg); }

  .ai-vt-comments-list-{{ ai_gen_id }} {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s ease;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ai-vt-comments-list-{{ ai_gen_id }}.active {
    max-height: 200px;
    overflow-y: auto;
    padding: 8px 0;
  }

  .ai-vt-single-review-{{ ai_gen_id }} {
    border-bottom: 1px solid #f0f0f0;
    padding-bottom: 10px;
  }
  .ai-vt-single-review-{{ ai_gen_id }}:last-child { border: none; }

  .ai-vt-stars-{{ ai_gen_id }} { display: flex; gap: 2px; color: #ffb400; margin-bottom: 3px;}
  .ai-vt-comm-text-{{ ai_gen_id }} { font-size: 12px; color: #444; line-height: 1.4; margin: 0; font-style: italic; }

  /* Form */
  .ai-vt-form-wrap-{{ ai_gen_id }} {
    padding: 12px;
    background: #fafafa;
    flex-grow: 1; /* Ensures form pushes footer down */
    display: flex;
    flex-direction: column;
  }

  .ai-vt-input-{{ ai_gen_id }} {
    width: 100%;
    border: 1px solid #eee;
    border-radius: 8px;
    padding: 10px;
    font-size: 12px;
    margin-bottom: 8px;
    outline: none;
    background: #fff;
    font-family: inherit;
  }

  .ai-vt-btn-{{ ai_gen_id }} {
    width: 100%;
    background: #1a1a1a;
    color: #fff;
    border: none;
    padding: 10px;
    border-radius: 8px;
    font-size: 10px;
    font-weight: 800;
    text-transform: uppercase;
    cursor: pointer;
    transition: 0.3s;
    letter-spacing: 0.5px;
  }

  .ai-vt-btn-{{ ai_gen_id }}:hover { background: #c9a84c; }

  /* Product info */
  .ai-vt-prod-{{ ai_gen_id }} {
    padding: 12px;
    display: flex;
    align-items: center;
    gap: 10px;
    background: #fff;
    border-top: 1px solid #f0f0f0;
    text-decoration: none !important;
  }
  .ai-vt-pimg-{{ ai_gen_id }} { width: 40px; height: 40px; border-radius: 8px; object-fit: cover; }
  .ai-vt-pttl-{{ ai_gen_id }} { font-size: 12px; font-weight: 600; color: #111; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .ai-vt-ppri-{{ ai_gen_id }} { font-size: 13px; font-weight: 700; color: #c9a84c; }
{% endstyle %}

<div class="ai-vt-section-{{ ai_gen_id }}">
  <div class="ai-vt-win-{{ ai_gen_id }}">
    
    <div class="ai-vt-head-{{ ai_gen_id }}">
      <div class="ai-vt-small-{{ ai_gen_id }}">{{ block.settings.sub_heading }}</div>
      <h2 class="ai-vt-main-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    </div>

    <div class="ai-vt-list-{{ ai_gen_id }}">
      {% for i in (1..8) %}
        {% capture t_key %}v_type_{{ i }}{% endcapture %}
        {% capture u_key %}v_url_{{ i }}{% endcapture %}
        {% capture p_key %}p_{{ i }}{% endcapture %}
        {% capture r_key %}r_{{ i }}{% endcapture %}
        {% capture c_key %}c_{{ i }}{% endcapture %}
        {% capture img_key %}v_img_{{ i }}{% endcapture %}
        
        {% assign t = block.settings[t_key] %}
        {% assign u = block.settings[u_key] %}
        {% assign p = block.settings[p_key] %}
        {% assign r = block.settings[r_key] | default: 5 %}
        {% assign c = block.settings[c_key] %}
        {% assign img = block.settings[img_key] %}
        
        {% if u != blank or img != blank or p != blank %}
          <div class="ai-vt-card-{{ ai_gen_id }}" id="card-{{ ai_gen_id }}-{{ i }}">
            <div class="ai-vt-media-{{ ai_gen_id }}">
              {% if t == 'insta' %}
                 {% assign i_url = u | split: '?' | first | append: 'embed/' %}
                 <iframe class="ai-vt-iframe-{{ ai_gen_id }}" src="{{ i_url }}" allowtransparency="true" frameborder="0"></iframe>
              {% elsif t == 'youtube' %}
                 {% assign v_id = u | split: 'v=' | last | split: '/' | last | split: '?' | first %}
                 <iframe class="ai-vt-iframe-{{ ai_gen_id }}" src="https://www.youtube.com/embed/{{ v_id }}?modestbranding=1" allowfullscreen></iframe>
              {% elsif t == 'photo' %}
                 <img class="ai-vt-video-{{ ai_gen_id }}" src="{{ img | image_url: width: 800 }}" loading="lazy">
              {% else %}
                 <video class="ai-vt-video-{{ ai_gen_id }}" loop muted playsinline preload="metadata">
                   <source src="{{ u }}" type="video/mp4">
                 </video>
                 <div class="ai-vt-play-{{ ai_gen_id }}" onclick="tgV('card-{{ ai_gen_id }}-{{ i }}')">
                    <svg width="40" height="40" viewBox="0 0 60 60" fill="none"><circle cx="30" cy="30" r="30" fill="white" fill-opacity="0.9"/><path d="M38 30L26 37L26 23L38 30Z" fill="black"/></svg>
                 </div>
              {% endif %}
            </div>

            <div class="ai-vt-content-{{ ai_gen_id }}">
              <div class="ai-vt-dropdown-trigger-{{ ai_gen_id }}" id="toggle-{{ ai_gen_id }}-{{ i }}" onclick="toggleC('{{ ai_gen_id }}-{{ i }}')">
                <span id="label-{{ ai_gen_id }}-{{ i }}">View reviews (1)</span>
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
              </div>

              <div class="ai-vt-comments-list-{{ ai_gen_id }}" id="list-{{ ai_gen_id }}-{{ i }}">
                <div class="ai-vt-single-review-{{ ai_gen_id }}">
                  <div class="ai-vt-stars-{{ ai_gen_id }}">
                    {% for star in (1..r) %}<svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>{% endfor %}
                  </div>
                  <p class="ai-vt-comm-text-{{ ai_gen_id }}">"{{ c | default: 'Truly a unique experience!' }}"</p>
                </div>
              </div>
            </div>

            <div class="ai-vt-form-wrap-{{ ai_gen_id }}">
              <div class="ai-vt-stars-{{ ai_gen_id }} interactive" style="margin-bottom: 8px;">
                {% for star in (1..5) %}
                  <svg onclick="setRating('{{ ai_gen_id }}-{{ i }}', {{ star }})" id="star-{{ ai_gen_id }}-{{ i }}-{{ star }}" width="16" height="16" viewBox="0 0 24 24" fill="#ddd" style="cursor:pointer"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                {% endfor %}
              </div>
              <textarea class="ai-vt-input-{{ ai_gen_id }}" id="input-{{ ai_gen_id }}-{{ i }}" placeholder="Add comment..." rows="1"></textarea>
              <button class="ai-vt-btn-{{ ai_gen_id }}" onclick="postComment('{{ ai_gen_id }}-{{ i }}')">Post Comment</button>
            </div>

            {% if p != blank %}
              <a href="{{ p.url }}" class="ai-vt-prod-{{ ai_gen_id }}">
                <img src="{{ p.featured_image | image_url: width: 80 }}" class="ai-vt-pimg-{{ ai_gen_id }}">
                <div class="ai-vt-pinfo-{{ ai_gen_id }}">
                  <div class="ai-vt-pttl-{{ ai_gen_id }}">{{ p.title }}</div>
                  <div class="ai-vt-ppri-{{ ai_gen_id }}">{{ p.price | money }}</div>
                </div>
              </a>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>

  </div>
</div>

<script>
  const globalState = {};

  function toggleC(id) {
    const list = document.getElementById('list-' + id);
    const trigger = document.getElementById('toggle-' + id);
    list.classList.toggle('active');
    trigger.classList.toggle('active');
  }

  function tgV(id) {
    const c = document.getElementById(id);
    const v = c ? c.querySelector('video') : null;
    if (!v) return;
    if (v.paused) { v.play(); c.classList.add('playing'); } else { v.pause(); c.classList.remove('playing'); }
  }

  function setRating(id, val) {
    if(!globalState[id]) globalState[id] = { rating: 5, total: 1 };
    globalState[id].rating = val;
    for (let i = 1; i <= 5; i++) {
        document.getElementById('star-' + id + '-' + i).setAttribute('fill', i <= val ? '#ffb400' : '#ddd');
    }
  }

  function postComment(id) {
    const input = document.getElementById('input-' + id);
    const list = document.getElementById('list-' + id);
    const label = document.getElementById('label-' + id);
    const text = input.value.trim();
    if (!text) return;

    if(!globalState[id]) globalState[id] = { rating: 5, total: 1 };
    const rating = globalState[id].rating;
    const div = document.createElement('div');
    div.className = 'ai-vt-single-review-{{ ai_gen_id }}';
    
    let starSvg = '<div class="ai-vt-stars-{{ ai_gen_id }}">';
    for(let j=1; j<=5; j++) {
      starSvg += `<svg width="12" height="12" viewBox="0 0 24 24" fill="${j <= rating ? '#ffb400' : '#ddd'}"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>`;
    }
    starSvg += '</div>';

    div.innerHTML = `${starSvg}<p class="ai-vt-comm-text-{{ ai_gen_id }}">"${text}"</p>`;
    list.prepend(div);
    
    globalState[id].total += 1;
    label.innerText = `View reviews (${globalState[id].total})`;

    list.classList.add('active');
    document.getElementById('toggle-' + id).classList.add('active');
    input.value = '';
  }
</script>

