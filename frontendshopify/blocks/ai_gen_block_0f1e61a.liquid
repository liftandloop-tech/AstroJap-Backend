<script>
  (function() {
    class ShopPurpose{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        const grid = this.querySelector('.ai-shop-purpose-grid-{{ ai_gen_id }}');
        if (!grid) return;

        if (window.innerWidth <= 749) {
          this.enableTouchScroll(grid);
        }

        window.addEventListener('resize', () => {
          if (window.innerWidth <= 749) {
            this.enableTouchScroll(grid);
          }
        });
      }

      enableTouchScroll(grid) {
        let isDown = false;
        let startX;
        let scrollLeft;

        grid.addEventListener('mousedown', (e) => {
          isDown = true;
          startX = e.pageX - grid.offsetLeft;
          scrollLeft = grid.scrollLeft;
        });

        grid.addEventListener('mouseleave', () => {
          isDown = false;
        });

        grid.addEventListener('mouseup', () => {
          isDown = false;
        });

        grid.addEventListener('mousemove', (e) => {
          if (!isDown) return;
          e.preventDefault();
          const x = e.pageX - grid.offsetLeft;
          const walk = (x - startX) * 2;
          grid.scrollLeft = scrollLeft - walk;
        });
      }
    }

    customElements.define('shop-purpose-{{ ai_gen_id }}', ShopPurpose{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Shop by purpose",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by Purpose"
    },
    {
      "type": "font_picker",
      "id": "heading_font",
      "label": "Heading font",
      "default": "serif"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 36
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#121212"
    },
    {
      "type": "range",
      "id": "heading_spacing",
      "min": 20,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Spacing below heading",
      "default": 48
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "cards_per_row",
      "min": 4,
      "max": 10,
      "step": 1,
      "label": "Cards per row (desktop)",
      "default": 7
    },
    {
      "type": "range",
      "id": "cards_per_row_tablet",
      "min": 3,
      "max": 6,
      "step": 1,
      "label": "Cards per row (tablet)",
      "default": 4
    },
    {
      "type": "range",
      "id": "card_spacing",
      "min": 8,
      "max": 40,
      "step": 4,
      "unit": "px",
      "label": "Space between cards",
      "default": 16
    },
    {
      "type": "range",
      "id": "mobile_card_width",
      "min": 120,
      "max": 200,
      "step": 10,
      "unit": "px",
      "label": "Card width (mobile)",
      "default": 140
    },
    {
      "type": "header",
      "content": "Card style"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Background color",
      "default": "#f5f1ea"
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Border radius",
      "default": 14
    },
    {
      "type": "range",
      "id": "card_padding",
      "min": 12,
      "max": 40,
      "step": 4,
      "unit": "px",
      "label": "Inner padding",
      "default": 20
    },
    {
      "type": "range",
      "id": "card_shadow_opacity",
