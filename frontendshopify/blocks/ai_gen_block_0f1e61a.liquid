{% doc %}
  @prompt
    🚨 IMPORTANT (STRICT INSTRUCTION)
    
    DO NOT create a circle layout.
    DO NOT create uneven grid.
    DO NOT create large banners.
    
    Create a clean horizontal card layout with equal-sized square cards, exactly like a “Shop by Purpose” category section.
    
    🧾 SECTION TITLE
    
    Centered heading:
    
    Shop by Purpose
    
    Font: elegant / serif style
    
    Medium-large size
    
    Proper spacing below heading
    
    🧱 LAYOUT (MANDATORY)
    
    One single row of 7 cards
    
    Cards must be:
    
    Equal width and height (square)
    
    Proper spacing between each card
    
    On mobile:
    
    Horizontal scroll (swipe enabled)
    
    🧩 CARD DESIGN (VERY IMPORTANT)
    
    Each card must include:
    
    1. BACKGROUND
    
    Light beige background (#f5f1ea or similar)
    
    Subtle texture or soft gradient (optional)
    
    2. IMAGE
    
    Centered object image (PNG style look)
    
    Example: crystal, bracelet, evil eye, gemstone
    
    Image should NOT fill entire card
    
    Keep proper padding inside card
    
    3. TITLE
    
    Text below image
    
    Center aligned
    
    Medium font weight
    
    🎨 DESIGN STYLE
    
    Border radius: 12px–16px
    
    Clean minimal luxury UI
    
    Soft shadow (very light)
    
    Hover effect:
    
    Slight lift or zoom
    
    ⚙️ DYNAMIC & EDITABLE (VERY IMPORTANT)
    
    Use Shopify blocks (not static content)
    
    Each block should have:
    
    Image picker
    
    Title text
    
    Link (collection or page)
    
    Allow:
    
    Minimum: 4
    
    Maximum: 10
    
    Blocks must be:
    ✅ Editable
    ✅ Reorderable
    ✅ Removable
    
    🧪 SAMPLE DATA (Astrojap)
    
    Create default items:
    
    Money
    
    Love
    
    Protection
    
    Career
    
    Evil Eye
    
    Health
    
    Gifting
    
    📱 MOBILE BEHAVIOR
    
    Horizontal scroll
    
    Show 2–3 cards per screen
    
    Maintain spacing and square shape
    
    ⚙️ TECHNICAL REQUIREMENTS
    
    Use Shopify Liquid + schema
    
    Use flexbox or grid
    
    Keep performance optimized
    
    Maintain consistent card size
    
    🚀 GOAL
    
    Create a clean, premium category navigation section that helps users quickly browse products based on purpose.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-shop-purpose-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 60px 20px;
  }

  .ai-shop-purpose-container-{{ ai_gen_id }} {
    max-width: {{ settings.page_width }}px;
    margin: 0 auto;
  }

  .ai-shop-purpose-heading-{{ ai_gen_id }} {
    text-align: center;
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.heading_spacing }}px 0;
    letter-spacing: 0.5px;
  }

  .ai-shop-purpose-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.cards_per_row }}, 1fr);
    gap: {{ block.settings.card_spacing }}px;
    margin: 0 auto;
  }

  .ai-shop-purpose-card-{{ ai_gen_id }} {
    position: relative;
    aspect-ratio: 1 / 1;
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.card_padding }}px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, {{ block.settings.card_shadow_opacity }});
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-shop-purpose-card-{{ ai_gen_id }}:hover {
    transform: translateY(-{{ block.settings.hover_lift }}px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, {{ block.settings.card_shadow_opacity | times: 1.5 }});
  }

  .ai-shop-purpose-card-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 12px;
  }

  .ai-shop-purpose-card-image-{{ ai_gen_id }} {
    max-width: 70%;
    max-height: 70%;
    width: auto;
    height: auto;
    object-fit: contain;
  }

  .ai-shop-purpose-card-placeholder-{{ ai_gen_id }} {
    width: 70%;
    height: 70%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: rgba(0, 0, 0, 0.05);
    border-radius: 8px;
  }

  .ai-shop-purpose-card-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-shop-purpose-card-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_title_size }}px;
    font-weight: {{ block.settings.card_title_weight }};
    color: {{ block.settings.card_title_color }};
    text-align: center;
    margin: 0;
    line-height: 1.3;
  }

  @media screen and (max-width: 989px) {
    .ai-shop-purpose-{{ ai_gen_id }} {
      padding: 40px 16px;
    }

    .ai-shop-purpose-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-shop-purpose-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.cards_per_row_tablet }}, 1fr);
      gap: {{ block.settings.card_spacing | times: 0.75 }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-shop-purpose-{{ ai_gen_id }} {
      padding: 32px 0;
    }

    .ai-shop-purpose-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
      padding: 0 16px;
    }

    .ai-shop-purpose-grid-{{ ai_gen_id }} {
      display: flex;
      overflow-x: auto;
      overflow-y: hidden;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      gap: {{ block.settings.card_spacing | times: 0.5 }}px;
      padding: 0 16px;
      grid-template-columns: none;
    }

    .ai-shop-purpose-grid-{{ ai_gen_id }}::-webkit-scrollbar {
      display: none;
    }

    .ai-shop-purpose-grid-{{ ai_gen_id }} {
      -ms-overflow-style: none;
      scrollbar-width: none;
    }

    .ai-shop-purpose-card-{{ ai_gen_id }} {
      flex: 0 0 {{ block.settings.mobile_card_width }}px;
      min-width: {{ block.settings.mobile_card_width }}px;
      height: {{ block.settings.mobile_card_width }}px;
      scroll-snap-align: start;
    }

    .ai-shop-purpose-card-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.card_title_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

