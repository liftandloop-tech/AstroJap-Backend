{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-astro-hero-wrap-{{ ai_gen_id }} {
    position: relative; 
    width: 100%; 
    height: {{ block.settings.height_desktop | default: 75 }}vh;
    min-height: 500px;
    background: #000;
    overflow: hidden;
  }

  /* ── SLIDE ENGINE ── */
  .ai-slide-{{ ai_gen_id }} {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    opacity: 0; visibility: hidden;
    transition: opacity 1.5s ease-in-out;
    z-index: 1;
    display: flex; 
    align-items: {{ block.settings.vertical_alignment | default: 'center' }}; 
    justify-content: center;
    overflow: hidden;
  }

  .ai-slide-{{ ai_gen_id }}.active {
    opacity: 1; visibility: visible;
    z-index: 2;
  }

  /* ── KEN BURNS ZOOM ENGINE ── */
  .ai-zoom-wrap-{{ ai_gen_id }} {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    overflow: hidden;
  }

  .ai-img-{{ ai_gen_id }} {
    width: 100%; height: 100%;
    object-fit: cover;
    transform: scale(1.3);
    will-change: transform;
  }

  .ai-slide-{{ ai_gen_id }}.active .ai-img-{{ ai_gen_id }} {
    animation: zoomOutHero-{{ ai_gen_id }} {{ block.settings.zoom_speed | default: 10 }}s linear forwards;
  }

  @keyframes zoomOutHero-{{ ai_gen_id }} {
    from { transform: scale(1.3); }
    to { transform: scale(1); }
  }

  /* ── OVERLAY & CONTENT ── */
  .ai-overlay-{{ ai_gen_id }} {
    position: absolute; inset: 0;
    background: {{ block.settings.overlay_color | default: '#000' }};
    opacity: {{ block.settings.overlay_opacity | default: 0.4 }};
    z-index: 3;
  }

  .ai-container-{{ ai_gen_id }} {
    position: relative; z-index: 10;
    max-width: {{ block.settings.content_width | default: 1200 }}px;
    width: 90%; 
    text-align: {{ block.settings.text_alignment | default: 'center' }};
    padding: 20px;
    opacity: 0; transform: translateY(30px);
    transition: all 1s ease 0.8s;
  }

  .ai-slide-{{ ai_gen_id }}.active .ai-container-{{ ai_gen_id }} {
    opacity: 1; transform: translateY(0);
  }

  /* ── TYPOGRAPHY ── */
  .ai-badge-{{ ai_gen_id }} {
    display: inline-block; padding: 8px 18px;
    background: {{ block.settings.badge_bg | default: '#FFD700' }};
    color: {{ block.settings.badge_color_text | default: '#000' }};
    font-size: 13px; font-weight: 700; border-radius: 20px;
    margin-bottom: 20px; text-transform: uppercase; letter-spacing: 1px;
  }

  .ai-h-{{ ai_gen_id }} {
    font-size: clamp(32px, 5vw, {{ block.settings.heading_font_size }}px);
    font-weight: 700; color: {{ block.settings.heading_color | default: '#fff' }};
    line-height: 1.1; margin: 0 0 15px; text-transform: uppercase;
  }

  .ai-sub-{{ ai_gen_id }} {
    font-size: clamp(18px, 2.5vw, 24px);
    color: {{ block.settings.subheading_color | default: '#f3f3f3' }};
    margin-bottom: 30px; line-height: 1.4;
  }

  /* ── BUTTONS ── */
  .ai-btn-group-{{ ai_gen_id }} {
    display: flex; gap: 15px; flex-wrap: wrap;
    justify-content: {% if block.settings.text_alignment == 'center' %}center{% elsif block.settings.text_alignment == 'right' %}flex-end{% else %}flex-start{% endif %};
  }

  .ai-btn-{{ ai_gen_id }} {
    padding: 15px 35px; border-radius: 30px; font-weight: 700; text-decoration: none;
    transition: 0.3s; font-size: 15px; display: inline-block;
  }

  .ai-btn-pri-{{ ai_gen_id }} { background: {{ block.settings.pri_btn_bg | default: '#FFD700' }}; color: {{ block.settings.pri_btn_text | default: '#000' }}; }
  .ai-btn-sec-{{ ai_gen_id }} { background: transparent; color: #fff; border: 2px solid #fff; }

  /* ── MOBILE OPTIMIZATION ── */
  @media (max-width: 749px) {
    .ai-astro-hero-wrap-{{ ai_gen_id }} { height: {{ block.settings.height_mobile | default: 60 }}vh; min-height: unset; }
    .ai-img-desk-{{ ai_gen_id }} { display: none; }
    .ai-img-mob-{{ ai_gen_id }} { display: block; }
    .ai-btn-group-{{ ai_gen_id }} { flex-direction: column; }
    .ai-btn-{{ ai_gen_id }} { width: 100%; text-align: center; }
  }
  @media (min-width: 750px) {
    .ai-img-mob-{{ ai_gen_id }} { display: none; }
  }
{% endstyle %}

<div class="ai-astro-hero-wrap-{{ ai_gen_id }}">
  <div id="hero-engine-{{ ai_gen_id }}" style="position: absolute; inset: 0;">
    
    {% for i in (1..3) %}
      {% capture img_d %}image_{{ i }}_d{% endcapture %}
      {% capture img_m %}image_{{ i }}_m{% endcapture %}
      {% capture head %}heading_{{ i }}{% endcapture %}
      {% capture sub %}subheading_{{ i }}{% endcapture %}

      {% assign desk_img = block.settings[img_d] %}
      {% assign mob_img = block.settings[img_m] %}

      {% if desk_img != blank or forloop.first %}
        <div class="ai-slide-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}">
           <div class="ai-zoom-wrap-{{ ai_gen_id }}">
             <!-- DESKTOP BANNER -->
             {% if desk_img != blank %}
               <img src="{{ desk_img | image_url: width: 2800 }}" 
                    width="{{ desk_img.width | default: 1920 }}" 
                    height="{{ desk_img.height | default: 1080 }}"
                    class="ai-img-{{ ai_gen_id }} ai-img-desk-{{ ai_gen_id }}" 
                    alt="Hero Slide {{ i }}"
                    loading="lazy">
             {% else %}
               {{ 'lifestyle-1' | placeholder_svg_tag: 'ai-img-placeholder' }}
             {% endif %}

             <!-- MOBILE BANNER (SQUARE) -->
             {% if mob_img != blank %}
               <img src="{{ mob_img | image_url: width: 1200 }}" 
                    width="{{ mob_img.width | default: 1200 }}" 
                    height="{{ mob_img.height | default: 1200 }}"
                    class="ai-img-{{ ai_gen_id }} ai-img-mob-{{ ai_gen_id }}" 
                    alt="Hero Mobile Slide {{ i }}"
                    loading="lazy">
             {% elsif desk_img != blank %}
               <img src="{{ desk_img | image_url: width: 1200 }}" 
                    width="1200" height="1200"
                    class="ai-img-{{ ai_gen_id }} ai-img-mob-{{ ai_gen_id }}" 
                    alt="Hero Mobile Fallback {{ i }}"
                    loading="lazy">
             {% endif %}

             <div class="ai-overlay-{{ ai_gen_id }}"></div>
           </div>

           <div class="ai-container-{{ ai_gen_id }}">
              {% if block.settings.badge_content != blank %}
                <span class="ai-badge-{{ ai_gen_id }}">{{ block.settings.badge_content }}</span>
              {% endif %}

              <h1 class="ai-h-{{ ai_gen_id }}">{{ block.settings[head] | default: 'Discover Your Destiny' }}</h1>
              <p class="ai-sub-{{ ai_gen_id }}">{{ block.settings[sub] | default: 'Expert Astrology Guidance 24/7' }}</p>

              <div class="ai-btn-group-{{ ai_gen_id }}">
                <a href="{{ block.settings.pri_url | default: '#' }}" class="ai-btn-{{ ai_gen_id }} ai-btn-pri-{{ ai_gen_id }}">Consult Now</a>
                <a href="{{ block.settings.sec_url | default: '#' }}" class="ai-btn-{{ ai_gen_id }} ai-btn-sec-{{ ai_gen_id }}">View Experts</a>
              </div>
           </div>
        </div>
      {% endif %}
    {% endfor %}

  </div>
</div>

<script>
  (function() {
    const root = document.querySelector('#hero-engine-{{ ai_gen_id }}');
    if(!root) return;
    const slides = root.querySelectorAll('.ai-slide-{{ ai_gen_id }}');
    if (slides.length <= 1) return;
    let cur = 0;
    setInterval(() => {
      slides[cur].classList.remove('active');
      cur = (cur + 1) % slides.length;
      slides[cur].classList.add('active');
    }, {{ block.settings.slide_duration | default: 5 }} * 1000);
  })();
</script>

{% schema %}
{
  "name": "Cinematic Astro Hero",
  "settings": [
    { "type": "header", "content": "Height & Speed" },
    { "type": "range", "id": "height_desktop", "min": 40, "max": 100, "unit": "vh", "label": "Desktop Height", "default": 75 },
    { "type": "range", "id": "height_mobile", "min": 30, "max": 100, "unit": "vh", "label": "Mobile Height", "default": 60 },
    { "type": "range", "id": "zoom_speed", "min": 5, "max": 20, "unit": "s", "label": "Zoom Duration", "default": 10 },
    { "type": "range", "id": "slide_duration", "min": 3, "max": 15, "unit": "s", "label": "Slide Duration", "default": 6 },
    
    { "type": "header", "content": "Master Style" },
    { "type": "color", "id": "overlay_color", "label": "Overlay Color", "default": "#000000" },
    { "type": "range", "id": "overlay_opacity", "min": 0, "max": 1, "step": 0.1, "label": "Overlay Darkness", "default": 0.4 },
    { "type": "select", "id": "text_alignment", "label": "Alignment", "options": [{"value":"left","label":"Left"},{"value":"center","label":"Center"},{"value":"right","label":"Right"}], "default": "center" },
    { "type": "select", "id": "vertical_alignment", "label": "Vertical Pos", "options": [{"value":"flex-start","label":"Top"},{"value":"center","label":"Center"},{"value":"flex-end","label":"Bottom"}], "default": "center" },
    { "type": "range", "id": "content_width", "min": 600, "max": 1400, "step": 100, "unit": "px", "label": "Content Max Width", "default": 1200 },
    
    { "type": "header", "content": "Badge & Typography" },
    { "type": "text", "id": "badge_content", "label": "Badge Text", "default": "Trusted Experts" },
    { "type": "color", "id": "badge_bg", "label": "Badge BG", "default": "#FFD700" },
    { "type": "color", "id": "badge_color_text", "label": "Badge Style Color", "default": "#000000" },
    { "type": "range", "id": "heading_font_size", "min": 30, "max": 80, "unit": "px", "label": "Heading Size", "default": 55 },
    { "type": "color", "id": "heading_color", "label": "Heading Color", "default": "#ffffff" },
    { "type": "color", "id": "subheading_color", "label": "Subheading Color", "default": "#f3f3f3" },

    { "type": "header", "content": "Slide 1" },
    { "type": "image_picker", "id": "image_1_d", "label": "Desktop Image 1" },
    { "type": "image_picker", "id": "image_1_m", "label": "Mobile Image 1 (Small Screen)" },
    { "type": "text", "id": "heading_1", "label": "Heading 1", "default": "Discover Your Destiny" },
    { "type": "text", "id": "subheading_1", "label": "Subheading 1", "default": "Vedic Astrology guidance from top professionals." },

    { "type": "header", "content": "Slide 2" },
    { "type": "image_picker", "id": "image_2_d", "label": "Desktop Image 2" },
    { "type": "image_picker", "id": "image_2_m", "label": "Mobile Image 2 (Small Screen)" },
    { "type": "text", "id": "heading_2", "label": "Heading 2", "default": "Connect with Experts" },
    { "type": "text", "id": "subheading_2", "label": "Subheading 2", "default": "Fast, accurate, and confidential readings." },

    { "type": "header", "content": "Buttons" },
    { "type": "color", "id": "pri_btn_bg", "label": "Primary BG", "default": "#FFD700" },
    { "type": "color", "id": "pri_btn_text", "label": "Primary Text color", "default": "#000" },
    { "type": "url", "id": "pri_url", "label": "Primary Link" },
    { "type": "url", "id": "sec_url", "label": "Secondary Link" }
  ]
}
{% endschema %}
