    font-weight: 700;
    color: #121212;
    margin-bottom: 10px;
  }

  .ai-chat-astrologer-chat-btn-{{ ai_gen_id }} {
    width: 100%;
    padding: 10px;
    background-color: #fff;
    border: 2px solid #4CAF50;
    border-radius: 8px;
    color: #4CAF50;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
