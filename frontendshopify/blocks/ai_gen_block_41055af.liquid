<script>
  (function() {
    class ChatAstrologerchatastrologer extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.searchInput = this.querySelector('.ai-chat-astrologer-search-chatastrologer');
        this.categoryPills = this.querySelectorAll('.ai-chat-astrologer-category-pill-chatastrologer');
        this.cards = this.querySelectorAll('.ai-chat-astrologer-card-chatastrologer');
        
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.searchInput.addEventListener('input', (e) => {
          this.filterCards(e.target.value.toLowerCase());
        });

        this.categoryPills.forEach(pill => {
          pill.addEventListener('click', () => {
            this.categoryPills.forEach(p => p.classList.remove('active'));
            pill.classList.add('active');
            
            const category = pill.getAttribute('data-category');
            this.filterByCategory(category);
          });
        });
      }

      filterCards(searchTerm) {
        this.cards.forEach(card => {
          const name = card.getAttribute('data-name').toLowerCase();
          if (name.includes(searchTerm)) {
            card.style.display = 'block';
          } else {
            card.style.display = 'none';
          }
        });
      }

      filterByCategory(category) {
        this.cards.forEach(card => {
          if (category === 'all') {
            card.style.display = 'block';
          } else {
            const cardCategories = card.getAttribute('data-category');
            if (cardCategories && cardCategories.includes(category)) {
              card.style.display = 'block';
            } else {
              card.style.display = 'none';
            }
          }
        });
      }
    }

    customElements.define('chat-astrologer-chatastrologer', ChatAstrologerchatastrologer);
  })();
</script>

