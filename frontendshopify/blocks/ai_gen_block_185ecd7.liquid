{% comment %}
  BLOCK VERSION - This will save in the blocks/ folder without errors.
{% endcomment %}
<div style="border:1px solid #eee; padding:15px; border-radius:12px; margin-bottom:15px; display:flex; gap:15px; position:relative; overflow:hidden;">
  {% if block.settings.product != blank %}
    {% assign p = block.settings.product %}
    
    {% if block.settings.badge != 'none' %}
       <div style="position:absolute; top:10px; left:-35px; background:#5d4037; color:white; padding:2px 40px; transform:rotate(-45deg); font-size:10px; font-weight:bold;">{{ block.settings.badge }}</div>
    {% endif %}

    <img src="{{ p.featured_image | image_url: width: 140 }}" width="70" height="70" style="border-radius:50%; border:2px solid #ffdf00; object-fit:cover;">
    
    <div style="flex:1;">
      <h3 style="margin:0; font-size:16px;">{{ p.title }} ✅</h3>
      <p style="font-size:12px; color:#666; margin:4px 0;">{{ block.settings.manual_skills | default: "Vedic, Tarot" }}</p>
      <p style="font-size:14px; color:red; font-weight:bold;">₹{{ p.price | money_without_currency | round }}/session</p>
      <a href="{{ routes.cart_add_url }}?id={{ p.selected_or_first_available_variant.id }}&quantity=1" 
         style="display:inline-block; margin-top:10px; border:1px solid #28a745; color:#28a745; padding:5px 15px; border-radius:8px; text-decoration:none; font-weight:bold;">Chat Now</a>
    </div>
  {% else %}
    <p>Please select an astrologer product in settings.</p>
  {% endif %}
</div>

{% schema %}
{
  "name": "Astrologer Card",
  "settings": [
    { "type": "product", "id": "product", "label": "Astrologer Product" },
    { "type": "select", "id": "badge", "label": "Badge", "options": [
        { "value": "none", "label": "None" },
        { "value": "Celebrity", "label": "Celebrity" },
        { "value": "Top Choice", "label": "Top Choice" }
      ], "default": "none" },
    { "type": "text", "id": "manual_skills", "label": "Skills Override" }
  ]
}
{% endschema %}
