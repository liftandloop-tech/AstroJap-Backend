{% doc %}
  @prompt
    Create a Shopify section using Liquid + CSS for a responsive feature cards section (like homepage quick actions).
    
    Design Requirements:
    
    1. Layout:
    - 4 cards in a row on desktop
    - 2 cards per row on tablet
    - 1 card per row on mobile
    - Equal spacing between cards
    - Center aligned layout
    
    2. Card Design:
    - Rounded card (border-radius: 16px–24px)
    - Light background (#f5f5f5 or white)
    - Soft shadow (premium look)
    - Padding: 30px–40px
    - Hover effect (slight lift + shadow)
    
    3. Icon/Image:
    - Each card should have a circular icon container
    - Circle size: 80px–120px
    - Background color customizable per card
    - Image inside circle must:
      - Fully fit inside circle
      - Maintain aspect ratio
      - Use object-fit: cover
      - Center aligned
    - No image stretching or cropping issues
    
    4. Content:
    - Title below icon
    - Bold and centered text
    - Optional subtitle (if needed)
    
    5. Shopify Functionality:
    - Use section blocks for each card
    - Each block should include:
      - Image picker
      - Title text
      - Background color (for circle)
      - Link (optional)
    
    6. Responsiveness:
    - Fully responsive for mobile/tablet
    - Image and circle scale properly
    - Text remains centered
    
    7. Technical:
    - Use flexbox or grid
    - Ensure images use:
      object-fit: cover;
      width: 100%;
      height: 100%;
    - Circle container must have:
      overflow: hidden;
      border-radius: 50%;
    
    8. Output:
    - Provide full Shopify section code
    - Include:
      - Liquid loop (for blocks)
      - CSS styling
      - Schema JSON
    
    Goal:
    Create a clean, modern, premium card section similar to Astrotalk homepage where icons are perfectly centered and responsive without image distortion.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-feature-cards-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
  }

  .ai-feature-cards__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-feature-cards__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: {{ block.settings.card_gap }}px;
    justify-items: center;
  }

  .ai-feature-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    text-align: center;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    box-shadow: 0 {{ block.settings.shadow_vertical }}px {{ block.settings.shadow_blur }}px rgba(0, 0, 0, {{ block.settings.shadow_opacity }});
    width: 100%;
    max-width: 100%;
    text-decoration: none;
    display: block;
    color: inherit;
  }

  .ai-feature-card-{{ ai_gen_id }}:hover {
    transform: translateY(-{{ block.settings.hover_lift }}px);
    box-shadow: 0 {{ block.settings.hover_shadow_vertical }}px {{ block.settings.hover_shadow_blur }}px rgba(0, 0, 0, {{ block.settings.hover_shadow_opacity }});
  }

  .ai-feature-card__icon-wrapper-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    border-radius: 50%;
    margin: 0 auto {{ block.settings.icon_margin_bottom }}px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .ai-feature-card__icon-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-feature-card__icon-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-feature-card__icon-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
  }

  .ai-feature-card__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_font_size }}px;
    font-weight: {{ block.settings.title_font_weight }};
    color: {{ block.settings.title_color }};
    margin: 0;
    line-height: 1.3;
  }

  .ai-feature-card__subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_font_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: {{ block.settings.subtitle_margin_top }}px 0 0;
    line-height: 1.5;
  }

  @media screen and (max-width: 989px) {
    .ai-feature-cards__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-feature-cards__grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.card_gap_mobile }}px;
    }

    .ai-feature-card__icon-wrapper-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size_mobile }}px;
      height: {{ block.settings.icon_size_mobile }}px;
    }

    .ai-feature-card__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_font_size_mobile }}px;
    }

    .ai-feature-card__subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtitle_font_size_mobile }}px;
    }
  }
{% endstyle %}

<feature-cards-{{ ai_gen_id }} class="ai-feature-cards-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-feature-cards__container-{{ ai_gen_id }}">
    <div class="ai-feature-cards__grid-{{ ai_gen_id }}">
      {% if block.settings.card_1_link != blank %}
        <a href="{{ block.settings.card_1_link }}" class="ai-feature-card-{{ ai_gen_id }}">
      {% else %}
        <div class="ai-feature-card-{{ ai_gen_id }}">
      {% endif %}
        <div 
          class="ai-feature-card__icon-wrapper-{{ ai_gen_id }}"
          style="background-color: {{ block.settings.card_1_icon_bg }};"
        >
          {% if block.settings.card_1_image %}
            <img
              src="{{ block.settings.card_1_image | image_url: width: 300 }}"
              alt="{{ block.settings.card_1_image.alt | escape }}"
              class="ai-feature-card__icon-{{ ai_gen_id }}"
