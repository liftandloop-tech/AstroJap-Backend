{% doc %}
  @prompt
    Create a Shopify section using Liquid, HTML, and CSS for a homepage block called "Today's Featured Pick".
    
    Layout requirements:
    - The section should be full width with a light beige background.
    - At the top center add a heading: "Today's Featured Pick".
    - Below the heading create a two column layout.
    
    Left side:
    - Display a large featured image of an astrologer holding a phone.
    - The image should be large and slightly left aligned.
    
    Right side:
    - Create a white card box overlapping slightly over the image.
    - Inside the card add:
       small text: "Only Limited Slots Available!"
       main heading: "Personalised Gemstone Consultation by Experts"
       description paragraph explaining gemstone recommendation based on birth chart and career goals.
       CTA button with text: "Book Consultation @ ₹499"
    
    Design requirements:
    - Card should have padding and subtle shadow.
    - Button should be black with white text.
    - Section should be responsive for mobile (stack columns).
    - Image left, text card right on desktop.
    
    Shopify requirements:
    - The image should be dynamic using section settings.
    - The heading, description, and button text should be editable from the theme editor.
    - The button should allow a dynamic link.
    
    Output:
    - Complete Shopify section file code with schema.
    - File name: featured-consultation.liquid
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-featured-consultation-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
  }

  .ai-featured-consultation__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-featured-consultation__heading-{{ ai_gen_id }} {
    text-align: center;
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    color: {{ block.settings.heading_color }};
  }

  .ai-featured-consultation__layout-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: center;
    position: relative;
  }

  .ai-featured-consultation__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
  }

  .ai-featured-consultation__image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-featured-consultation__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 3 / 4;
    background-color: #f4f4f4;
    border-radius: {{ block.settings.image_border_radius }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-featured-consultation__image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-featured-consultation__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-featured-consultation__card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    padding: {{ block.settings.card_padding }}px;
    border-radius: {{ block.settings.card_border_radius }}px;
    box-shadow: {{ block.settings.card_shadow_horizontal }}px {{ block.settings.card_shadow_vertical }}px {{ block.settings.card_shadow_blur }}px rgba(0, 0, 0, {{ block.settings.card_shadow_opacity }});
    position: relative;
    z-index: 2;
  }

  .ai-featured-consultation__badge-{{ ai_gen_id }} {
    font-size: {{ block.settings.badge_font_size }}px;
    color: {{ block.settings.badge_color }};
    margin: 0 0 {{ block.settings.badge_spacing }}px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-featured-consultation__card-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_heading_size }}px;
    color: {{ block.settings.card_heading_color }};
    margin: 0 0 {{ block.settings.card_heading_spacing }}px;
    line-height: 1.3;
  }

  .ai-featured-consultation__description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    line-height: 1.6;
    margin: 0 0 {{ block.settings.description_spacing }}px;
  }

  .ai-featured-consultation__button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 600;
    transition: all 0.3s ease;
    border: none;
    cursor: pointer;
    text-align: center;
  }

  .ai-featured-consultation__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-featured-consultation__layout-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 30px;
    }

    .ai-featured-consultation__card-{{ ai_gen_id }} {
      margin-top: -40px;
    }

    .ai-featured-consultation__heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }

    .ai-featured-consultation__card-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.card_heading_size }}px * 0.85);
    }
  }
{% endstyle %}

<div class="ai-featured-consultation-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-featured-consultation__container-{{ ai_gen_id }}">
    {% if block.settings.section_heading != blank %}
      <h2 class="ai-featured-consultation__heading-{{ ai_gen_id }}">
        {{ block.settings.section_heading }}
      </h2>
    {% endif %}

    <div class="ai-featured-consultation__layout-{{ ai_gen_id }}">
      <div class="ai-featured-consultation__image-wrapper-{{ ai_gen_id }}">
        {% if block.settings.featured_image %}
          <img
            src="{{ block.settings.featured_image | image_url: width: 1000 }}"
            alt="{{ block.settings.featured_image.alt | escape }}"
            class="ai-featured-consultation__image-{{ ai_gen_id }}"
            loading="lazy"
            width="{{ block.settings.featured_image.width }}"
            height="{{ block.settings.featured_image.height }}"
          >
        {% else %}
          <div class="ai-featured-consultation__image-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
            <div class="ai-featured-consultation__empty-state-{{ ai_gen_id }}">
              Add a featured image
            </div>
          </div>
        {% endif %}
      </div>

      <div class="ai-featured-consultation__card-{{ ai_gen_id }}">
        {% if block.settings.badge_text != blank %}
          <p class="ai-featured-consultation__badge-{{ ai_gen_id }}">
            {{ block.settings.badge_text }}
          </p>
        {% endif %}

        {% if block.settings.card_heading != blank %}
          <h3 class="ai-featured-consultation__card-heading-{{ ai_gen_id }}">
            {{ block.settings.card_heading }}
          </h3>
        {% endif %}

        {% if block.settings.description != blank %}
          <div class="ai-featured-consultation__description-{{ ai_gen_id }}">
            {{ block.settings.description }}
          </div>
        {% endif %}

        {% if block.settings.button_text != blank %}
          <a
            href="{{ block.settings.button_link }}"
            class="ai-featured-consultation__button-{{ ai_gen_id }}"
          >
            {{ block.settings.button_text }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</div>

