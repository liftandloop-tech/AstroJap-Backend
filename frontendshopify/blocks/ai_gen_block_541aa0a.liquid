  "settings": [
    {
      "type": "header",
      "content": "Section content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Kundli Generator"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Discover your cosmic blueprint with our advanced Kundli generator. Get personalized insights into your life path, relationships, career, and spiritual journey based on Vedic astrology.</p>"
    },
    {
      "type": "header",
      "content": "Form settings"
    },
    {
      "type": "text",
      "id": "form_title",
      "label": "Form title",
      "default": "New Kundli"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Generate Horoscope"
    },
    {
      "type": "text",
      "id": "api_url",
      "label": "API endpoint URL",
      "info": "Enter the full URL of your Kundli API endpoint"
    },
    {
      "type": "header",
      "content": "Saved Kundli card"
    },
    {
      "type": "text",
      "id": "saved_title",
      "label": "Card title",
      "default": "Saved Kundli"
    },
    {
