{% doc %}
  @prompt
    🧾 CONTENT
    Heading:
    
    We’re Here to Help You
    
    Subheading:
    
    Have questions about astrology, kundli, or our services? Reach out to Astrojap and our team will assist you.
    
    🧱 LAYOUT
    
    Full width section
    
    Height: 50–70vh
    
    Center aligned content
    
    Background: astrology theme (stars / zodiac)
    
    🎨 DESIGN
    
    Dark overlay on background
    
    Large heading
    
    Clean typography
    
    ⚙️ EDITABLE SETTINGS
    
    Background image
    
    Heading
    
    Subheading
    
    Overlay opacity
    
    📱 RESPONSIVE
    
    Center content on mobile
    
    Maintain spacing
    
    🚀 GOAL
    
    Create a welcoming and professional first impression for the contact page.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-contact-hero-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    min-height: {{ block.settings.min_height }}vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .ai-contact-hero-background-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .ai-contact-hero-background-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-contact-hero-background-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
    position: relative;
  }

  .ai-contact-hero-background-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    opacity: 0.1;
  }

  .ai-contact-hero-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};
    z-index: 2;
  }

  .ai-contact-hero-content-{{ ai_gen_id }} {
    position: relative;
    z-index: 3;
    text-align: center;
    padding: 40px 20px;
    max-width: 900px;
    margin: 0 auto;
  }

  .ai-contact-hero-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 700;
    color: {{ block.settings.heading_color }};
    margin: 0 0 20px;
    line-height: 1.2;
    letter-spacing: -0.02em;
  }

  .ai-contact-hero-subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.subheading_color }};
    margin: 0;
    line-height: 1.6;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }

  @media screen and (max-width: 749px) {
    .ai-contact-hero-{{ ai_gen_id }} {
      min-height: {{ block.settings.min_height | times: 0.7 }}vh;
    }

    .ai-contact-hero-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.6 }}px;
      margin-bottom: 16px;
    }

    .ai-contact-hero-subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size | times: 0.85 }}px;
    }

    .ai-contact-hero-content-{{ ai_gen_id }} {
      padding: 30px 16px;
    }
  }

  @media screen and (min-width: 750px) and (max-width: 989px) {
    .ai-contact-hero-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-contact-hero-subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-contact-hero-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-contact-hero-background-{{ ai_gen_id }}">
    {% if block.settings.background_image %}
      <img
        src="{{ block.settings.background_image | image_url: width: 2000 }}"
        alt="{{ block.settings.background_image.alt | escape }}"
        loading="eager"
        width="{{ block.settings.background_image.width }}"
        height="{{ block.settings.background_image.height }}"
      >
    {% else %}
      <div class="ai-contact-hero-background-placeholder-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
      </div>
    {% endif %}
  </div>

  <div class="ai-contact-hero-overlay-{{ ai_gen_id }}"></div>

  <div class="ai-contact-hero-content-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h1 class="ai-contact-hero-heading-{{ ai_gen_id }}">
        {{ block.settings.heading }}
      </h1>
    {% endif %}

    {% if block.settings.subheading != blank %}
      <div class="ai-contact-hero-subheading-{{ ai_gen_id }}">
        {{ block.settings.subheading }}
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Contact hero",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "We're Here to Help You"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheading",
      "default": "<p>Have questions about astrology, kundli, or our services? Reach out to Astrojap and our team will assist you.</p>"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "min_height",
      "min": 30,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "label": "Section height",
      "default": 60
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Overlay opacity",
      "default": 50
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 24,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 56
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "subheading_size",
      "min": 14,
      "max": 32,
      "step": 2,
      "unit": "px",
      "label": "Subheading size",
      "default": 18
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading color",
      "default": "#e0e0e0"
    }
  ],
  "presets": [
    {
      "name": "Contact hero"
    }
  ]
}
{% endschema %}
