{% doc %}
  @prompt
    🤖 High-End Shopify Development Prompt
    Task: Create a premium Shopify Liquid section named "Astrologer Purchased Sessions" that displays a grid of sessions a customer has already bought.
    
    Design Requirements (Aesthetic: "Shop by Purpose"):
    
    Layout: A responsive horizontal grid of cards.
    Card Style:
    Square cards with highly rounded corners (border-radius: 24px).
    Background color: A soft, luxurious cream or light beige (#fcf8f1).
    Subtle shadow for a "floating" look.
    Content:
    Centered profile image/icon inside the card.
    Bold, clean typography for the Astrologer's Name below the card.
    Secondary small text for "Duration" (e.g., 20 Min Session).
    Action: A prominent "Chat Now" button at the bottom of each item, styled with a vibrant orange gradient and rounded edges.
    Functional Requirements:
    
    Authentication: The section should only render if customer is logged in.
    Data Fetching: Use vanilla JavaScript and DOMContentLoaded to fetch session data from an external API (AstroAPI.getCustomerSessions(customerId)).
    Dynamic Grid:
    Start with the section hidden (display: none).
    If the API returns active sessions, populate the grid and show the section.
    If no sessions are found, keep it hidden.
    Navigation: The "Chat Now" button should redirect the user to a dedicated chat page (e.g., /pages/chat).
    Technical Stack:
    
    Liquid: Component structure and schema settings.
    CSS: Modern Flexbox/Grid for the "Shop by Purpose" look, using Outfit or Inter Google Fonts.
    JS: Async/Await for API communication, handling profile image fallbacks.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700&display=swap');

  .ai-astro-sessions-{{ ai_gen_id }} {
    display: none;
    width: 100%;
    padding: {{ block.settings.section_padding_top }}px 20px {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
    font-family: 'Outfit', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  }

  .ai-astro-sessions-{{ ai_gen_id }}.ai-astro-sessions-visible-{{ ai_gen_id }} {
    display: block;
  }

  .ai-astro-sessions-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_max_width }}px;
    margin: 0 auto;
  }

  .ai-astro-sessions-header-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin-bottom: {{ block.settings.heading_spacing }}px;
  }

  .ai-astro-sessions-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 700;
    color: {{ block.settings.heading_color }};
    margin: 0 0 12px;
    line-height: 1.2;
  }

  .ai-astro-sessions-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    font-weight: 400;
    color: {{ block.settings.subheading_color }};
    margin: 0;
    line-height: 1.5;
  }

  .ai-astro-sessions-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax({{ block.settings.card_min_width }}px, 1fr));
    gap: {{ block.settings.grid_gap }}px;
    margin-top: {{ block.settings.grid_spacing }}px;
  }

  .ai-astro-session-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    box-shadow: 0 4px 16px rgba(0, 0, 0, {{ block.settings.card_shadow_opacity }});
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .ai-astro-session-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, {{ block.settings.card_shadow_opacity | times: 1.5 }});
  }

  .ai-astro-session-image-wrapper-{{ ai_gen_id }} {
    width: {{ block.settings.image_size }}px;
    height: {{ block.settings.image_size }}px;
    border-radius: 50%;
    overflow: hidden;
    margin-bottom: {{ block.settings.image_spacing }}px;
    background-color: #e8e8e8;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-astro-session-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-astro-session-placeholder-{{ ai_gen_id }} {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-astro-session-name-{{ ai_gen_id }} {
    font-size: {{ block.settings.name_size }}px;
    font-weight: 600;
    color: {{ block.settings.name_color }};
    margin: 0 0 8px;
    line-height: 1.3;
  }

  .ai-astro-session-duration-{{ ai_gen_id }} {
    font-size: {{ block.settings.duration_size }}px;
    font-weight: 400;
    color: {{ block.settings.duration_color }};
    margin: 0 0 {{ block.settings.button_spacing }}px;
    line-height: 1.4;
  }

  .ai-astro-session-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background: {{ block.settings.button_gradient }};
    color: {{ block.settings.button_text_color }};
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 600;
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    border: none;
    cursor: pointer;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    box-shadow: 0 2px 8px rgba(255, 107, 0, 0.3);
  }

  .ai-astro-session-button-{{ ai_gen_id }}:hover {
    transform: scale(1.05);
    box-shadow: 0 4px 12px rgba(255, 107, 0, 0.4);
  }

  .ai-astro-sessions-loading-{{ ai_gen_id }} {
    text-align: center;
    padding: 40px;
    color: {{ block.settings.heading_color }};
    font-size: 16px;
  }

  .ai-astro-sessions-error-{{ ai_gen_id }} {
    text-align: center;
    padding: 40px;
    color: #d32f2f;
    font-size: 16px;
  }

  @media screen and (max-width: 768px) {
    .ai-astro-sessions-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(auto-fill, minmax({{ block.settings.card_min_width | times: 0.8 }}px, 1fr));
      gap: {{ block.settings.grid_gap | times: 0.75 }}px;
    }

    .ai-astro-sessions-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-astro-sessions-subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size | times: 0.9 }}px;
    }

    .ai-astro-session-card-{{ ai_gen_id }} {
      padding: {{ block.settings.card_padding | times: 0.8 }}px;
    }

    .ai-astro-session-image-wrapper-{{ ai_gen_id }} {
      width: {{ block.settings.image_size | times: 0.85 }}px;
      height: {{ block.settings.image_size | times: 0.85 }}px;
    }
  }
{% endstyle %}

<astrologer-sessions-{{ ai_gen_id }}
  class="ai-astro-sessions-{{ ai_gen_id }}"
  data-customer-id="{{ customer.id }}"
  data-api-endpoint="{{ block.settings.api_endpoint }}"
  data-chat-page-url="{{ block.settings.chat_page_url }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-astro-sessions-container-{{ ai_gen_id }}">
    {% if block.settings.show_heading %}
      <div class="ai-astro-sessions-header-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-astro-sessions-title-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}
        {% if block.settings.subheading != blank %}
          <p class="ai-astro-sessions-subtitle-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-astro-sessions-loading-{{ ai_gen_id }}">
      Loading your sessions...
    </div>

    <div class="ai-astro-sessions-grid-{{ ai_gen_id }}" style="display: none;"></div>
  </div>
</astrologer-sessions-{{ ai_gen_id }}>

<script>
  (function() {
    class AstrologerSessions{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.customerId = this.dataset.customerId;
        this.apiEndpoint = this.dataset.apiEndpoint;
        this.chatPageUrl = this.dataset.chatPageUrl;
        this.container = this.querySelector('.ai-astro-sessions-grid-{{ ai_gen_id }}');
        this.loadingEl = this.querySelector('.ai-astro-sessions-loading-{{ ai_gen_id }}');
      }

      connectedCallback() {
        if (!this.customerId) {
          this.hideSection();
          return;
        }

        document.addEventListener('DOMContentLoaded', () => {
          this.fetchSessions();
        });

        if (document.readyState === 'complete' || document.readyState === 'interactive') {
          this.fetchSessions();
        }
      }

      async fetchSessions() {
        try {
          if (typeof window.AstroAPI === 'undefined' || typeof window.AstroAPI.getActiveSession !== 'function') {
            console.error('AstroAPI.getActiveSession is not available');
            this.showError('API not available');
            return;
          }

          const sessions = await window.AstroAPI.getActiveSession(this.customerId);

          if (!sessions || sessions.length === 0) {
            this.hideSection();
            return;
          }

          this.renderSessions(sessions);
          this.showSection();
        } catch (error) {
          console.error('Error fetching sessions:', error);
          this.hideSection();
        }
      }

      renderSessions(sessions) {
        this.container.innerHTML = '';

        sessions.forEach((session) => {
          const card = this.createSessionCard(session);
          this.container.appendChild(card);
        });

        this.loadingEl.style.display = 'none';
        this.container.style.display = 'grid';
      }

      createSessionCard(session) {
        const card = document.createElement('div');
        card.className = 'ai-astro-session-card-{{ ai_gen_id }}';

        const imageWrapper = document.createElement('div');
        imageWrapper.className = 'ai-astro-session-image-wrapper-{{ ai_gen_id }}';

        if (session.profileImage) {
          const img = document.createElement('img');
          img.src = session.profileImage;
          img.alt = session.astrologerName || 'Astrologer';
          img.className = 'ai-astro-session-image-{{ ai_gen_id }}';
          img.loading = 'lazy';
          img.onerror = () => {
            img.style.display = 'none';
            const placeholder = this.createPlaceholderSVG();
            imageWrapper.appendChild(placeholder);
          };
          imageWrapper.appendChild(img);
        } else {
          const placeholder = this.createPlaceholderSVG();
          imageWrapper.appendChild(placeholder);
        }

        const name = document.createElement('h3');
        name.className = 'ai-astro-session-name-{{ ai_gen_id }}';
        name.textContent = session.astrologerName || 'Astrologer';

        const duration = document.createElement('p');
        duration.className = 'ai-astro-session-duration-{{ ai_gen_id }}';
        duration.textContent = session.duration ? `${session.duration} Min Session` : 'Session';

        const button = document.createElement('a');
        button.href = this.chatPageUrl || '/pages/chat';
        button.className = 'ai-astro-session-button-{{ ai_gen_id }}';
        button.textContent = 'Chat Now';

        if (session.sessionId) {
          button.href += `?session=${session.sessionId}`;
        }

        card.appendChild(imageWrapper);
        card.appendChild(name);
        card.appendChild(duration);
        card.appendChild(button);

        return card;
      }

      createPlaceholderSVG() {
        const svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
        svg.setAttribute('class', 'ai-astro-session-placeholder-{{ ai_gen_id }}');
        svg.setAttribute('viewBox', '0 0 24 24');
        svg.setAttribute('fill', 'none');
        svg.setAttribute('stroke', 'currentColor');
        svg.setAttribute('stroke-width', '2');

        const circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
        circle.setAttribute('cx', '12');
        circle.setAttribute('cy', '8');
        circle.setAttribute('r', '4');

        const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
        path.setAttribute('d', 'M6 21v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2');

        svg.appendChild(circle);
        svg.appendChild(path);

        return svg;
      }

      showSection() {
        this.classList.add('ai-astro-sessions-visible-{{ ai_gen_id }}');
      }

      hideSection() {
        this.style.display = 'none';
      }

      showError(message) {
        this.loadingEl.className = 'ai-astro-sessions-error-{{ ai_gen_id }}';
        this.loadingEl.textContent = message;
      }
    }

    customElements.define('astrologer-sessions-{{ ai_gen_id }}', AstrologerSessions{{ ai_gen_id }});
  })();
</script>

