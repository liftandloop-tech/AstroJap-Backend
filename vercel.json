{
  "version": 2,
  "builds": [
    {
      "src": "src/index.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "src/index.js"
    }
  ],
  "crons": [
    {
      "path": "/api/sessions/expire-old",
      "schedule": "*/5 * * * *"
    }
  ]
}
